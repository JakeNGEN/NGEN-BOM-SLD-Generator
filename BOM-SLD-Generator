// ─── ZOOM / PAN ───────────────────────────────────────────────────
// Zoom by scaling the SVG's width/height attributes (viewBox stays put,
// so drag math via getScreenCTM keeps working automatically). Pan via
// container scroll, driven by space-drag or middle-mouse drag.

function applyZoom() {
  const svg = document.querySelector('#svg-container svg');
  if (!svg) return;
  const vb = svg.viewBox.baseVal;
  if (!vb || !vb.width) return;
  svg.setAttribute('width', vb.width * state.zoom);
  svg.setAttribute('height', vb.height * state.zoom);
  const ind = document.getElementById('zoom-level');
  if (ind) ind.textContent = Math.round(state.zoom * 100) + '%';
}

function setZoom(newZoom, pivotClientX, pivotClientY) {
  const container = document.getElementById('svg-container');
  const oldZoom = state.zoom;
  newZoom = Math.max(0.2, Math.min(4, newZoom));
  if (newZoom === oldZoom) return;
  const rect = container.getBoundingClientRect();
  let pivotX, pivotY;
  if (typeof pivotClientX === 'number') {
    pivotX = pivotClientX - rect.left + container.scrollLeft;
    pivotY = pivotClientY - rect.top + container.scrollTop;
  } else {
    pivotX = container.scrollLeft + rect.width / 2;
    pivotY = container.scrollTop + rect.height / 2;
  }
  state.zoom = newZoom;
  applyZoom();
  const k = newZoom / oldZoom;
  container.scrollLeft = pivotX * k - (typeof pivotClientX === 'number' ? (pivotClientX - rect.left) : rect.width / 2);
  container.scrollTop = pivotY * k - (typeof pivotClientY === 'number' ? (pivotClientY - rect.top) : rect.height / 2);
}

function zoomFit() {
  const container = document.getElementById('svg-container');
  const svg = container && container.querySelector('svg');
  if (!svg) return;
  const vb = svg.viewBox.baseVal;
  if (!vb || !vb.width || !vb.height) return;
  // Container has padding (24px on each side per CSS).
  const padding = 48;
  const fitW = (container.clientWidth - padding) / vb.width;
  const fitH = (container.clientHeight - padding) / vb.height;
  const z = Math.max(0.2, Math.min(4, Math.min(fitW, fitH)));
  state.zoom = z;
  applyZoom();
  container.scrollLeft = 0;
  container.scrollTop = 0;
}

function zoomReset() {
  state.zoom = 1;
  applyZoom();
  const container = document.getElementById('svg-container');
  if (container) { container.scrollLeft = 0; container.scrollTop = 0; }
}

(function initZoomPan() {
  const container = document.getElementById('svg-container');
  if (!container) return;

  // Ctrl + wheel = zoom toward cursor. Plain wheel scrolls naturally.
  container.addEventListener('wheel', (e) => {
    if (!e.ctrlKey && !e.metaKey) return;
    e.preventDefault();
    const factor = e.deltaY < 0 ? 1.12 : 1 / 1.12;
    setZoom(state.zoom * factor, e.clientX, e.clientY);
  }, { passive: false });

  // Space-drag and middle-mouse pan
  let spaceHeld = false;
  let panStart = null;

  function isTypingTarget(el) {
    if (!el) return false;
    const tag = (el.tagName || '').toLowerCase();
    return tag === 'input' || tag === 'textarea' || tag === 'select' || el.isContentEditable;
  }

  document.addEventListener('keydown', e => {
    if (e.code === 'Space' && !spaceHeld && !isTypingTarget(e.target)) {
      spaceHeld = true;
      container.classList.add('pan-ready');
      e.preventDefault();
    }
  });
  document.addEventListener('keyup', e => {
    if (e.code === 'Space') {
      spaceHeld = false;
      container.classList.remove('pan-ready', 'panning');
    }
  });

  container.addEventListener('mousedown', e => {
    if (e.button === 1 || (e.button === 0 && spaceHeld)) {
      e.preventDefault();
      panStart = {
        clientX: e.clientX,
        clientY: e.clientY,
        scrollLeft: container.scrollLeft,
        scrollTop: container.scrollTop
      };
      container.classList.add('panning');
    }
  }, true); // capture so node-drag mousedown doesn't fire first

  window.addEventListener('mousemove', e => {
    if (!panStart) return;
    container.scrollLeft = panStart.scrollLeft - (e.clientX - panStart.clientX);
    container.scrollTop = panStart.scrollTop - (e.clientY - panStart.clientY);
  });
  window.addEventListener('mouseup', () => {
    if (panStart) {
      panStart = null;
      container.classList.remove('panning');
      if (spaceHeld) container.classList.add('pan-ready');
    }
  });

  // Toolbar buttons
  document.getElementById('btn-zoom-in').addEventListener('click', () => setZoom(state.zoom * 1.2));
  document.getElementById('btn-zoom-out').addEventListener('click', () => setZoom(state.zoom / 1.2));
  document.getElementById('btn-zoom-fit').addEventListener('click', zoomFit);
  document.getElementById('btn-zoom-reset').addEventListener('click', zoomReset);
})();

// Note: applyZoom is invoked from inside renderDiagram so the zoom level
// persists across re-renders without monkey-patching.

// ─── HOVER TOOLTIP ────────────────────────────────────────────────
const tooltipEl = document.getElementById('canvas-tooltip');

function escHtml(s) {
  if (s == null) return '';
  return String(s)
    .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;').replace(/'/g, '&#39;');
}

function showTooltipFor(nodeEl, clientX, clientY) {
  if (interaction.dragging) return;
  if (!state.json || !state.json.devices) return;
  const id = nodeEl.dataset.id;
  const dev = state.json.devices.find(d => d.id === id);
  if (!dev || !tooltipEl) return;
  const kindLabel = dev.kind ? String(dev.kind).replace(/_/g, ' ') : '';
  const labelEn = dev.label || dev.id;
  const labelZh = dev.label_zh || '';
  const specsEn = (Array.isArray(dev.rating_items) ? dev.rating_items : []).join(' · ');
  const specsZh = (Array.isArray(dev.rating_items_zh) ? dev.rating_items_zh : []).join(' · ');
  const upstream = dev.upstream_parent || '';
  const downstream = Array.isArray(dev.downstream_children) ? dev.downstream_children.join(', ') : '';
  const notesEn = dev.notes || '';
  const notesZh = dev.notes_zh || '';

  // Show both languages stacked when a translation is available; the active
  // language comes first so it lines up with the on-canvas label.
  const labels = {
    Kind: kindLabel ? [kindLabel] : [],
    Specs:    [pickLang(specsEn, specsZh), isZh() ? specsEn : specsZh].filter(Boolean).filter((v, i, a) => a.indexOf(v) === i),
    From:     upstream ? [upstream] : [],
    To:       downstream ? [downstream] : [],
    Notes:    [pickLang(notesEn, notesZh), isZh() ? notesEn : notesZh].filter(Boolean).filter((v, i, a) => a.indexOf(v) === i),
  };
  const I18N_LABEL = isZh()
    ? { Kind: '类型', Specs: '规格', From: '上游', To: '下游', Notes: '备注' }
    : { Kind: 'Kind', Specs: 'Specs', From: 'From', To: 'To', Notes: 'Notes' };

  const rows = Object.keys(labels)
    .filter(k => labels[k].length > 0)
    .map(k => {
      const values = labels[k].map(v => `<div>${escHtml(v)}</div>`).join('');
      return `<div class="tt-row"><span class="tt-label">${escHtml(I18N_LABEL[k])}</span><span class="tt-value">${values}</span></div>`;
    });

  // Title shows active label up top, the other language underneath in dim text
  const titleMain = pickLang(labelEn, labelZh);
  const titleSub  = isZh() ? labelEn : labelZh;
  const titleHtml = `<div class="tt-title">${escHtml(titleMain)}</div>` +
                    (titleSub && titleSub !== titleMain ? `<div class="tt-id" style="opacity:0.85;color:#A1D5CC;font-family:inherit;font-size:11px;">${escHtml(titleSub)}</div>` : '');

  tooltipEl.innerHTML =
    titleHtml +
    `<div class="tt-id">${escHtml(dev.id)}</div>` +
    rows.join('');
  tooltipEl.style.display = 'block';
  positionTooltip(clientX, clientY);
  tooltipEl.setAttribute('aria-hidden', 'false');
}

function positionTooltip(clientX, clientY) {
  if (!tooltipEl || tooltipEl.style.display === 'none') return;
  const pad = 14;
  const rect = tooltipEl.getBoundingClientRect();
  let left = clientX + pad;
  let top = clientY + pad;
  if (left + rect.width > window.innerWidth - 8) left = clientX - rect.width - pad;
  if (top + rect.height > window.innerHeight - 8) top = clientY - rect.height - pad;
  tooltipEl.style.left = Math.max(8, left) + 'px';
  tooltipEl.style.top = Math.max(8, top) + 'px';
}

function hideTooltip() {
  if (!tooltipEl) return;
  tooltipEl.style.display = 'none';
  tooltipEl.setAttribute('aria-hidden', 'true');
}

(function initTooltip() {
  const container = document.getElementById('svg-container');
  if (!container) return;
  container.addEventListener('mouseover', e => {
    const nodeEl = e.target.closest && e.target.closest('.draggable-node');
    if (nodeEl) showTooltipFor(nodeEl, e.clientX, e.clientY);
  });
  container.addEventListener('mousemove', e => {
    if (tooltipEl.style.display === 'block') positionTooltip(e.clientX, e.clientY);
  });
  container.addEventListener('mouseout', e => {
    const to = e.relatedTarget;
    if (!to || !to.closest || !to.closest('.draggable-node')) hideTooltip();
  });
  // Hide while dragging or scrolling
  window.addEventListener('mousedown', hideTooltip);
  container.addEventListener('scroll', hideTooltip);
})();

// ─── TRACE MODE (downstream highlight) ────────────────────────────
interaction.traceMode = false;
interaction.traceSource = null;

function buildAdjacency() {
  const adj = {};
  if (!state.json || !Array.isArray(state.json.devices)) return adj;
  state.json.devices.forEach(d => { adj[d.id] = adj[d.id] || []; });
  state.json.devices.forEach(d => {
    if (d.upstream_parent && adj[d.upstream_parent] && !adj[d.upstream_parent].includes(d.id)) {
      adj[d.upstream_parent].push(d.id);
    }
    (d.downstream_children || []).forEach(cid => {
      if (adj[d.id] && !adj[d.id].includes(cid)) adj[d.id].push(cid);
    });
  });
  return adj;
}

function downstreamSet(sourceId) {
  const adj = buildAdjacency();
  const result = new Set();
  const queue = [sourceId];
  while (queue.length) {
    const cur = queue.shift();
    (adj[cur] || []).forEach(next => {
      if (!result.has(next) && next !== sourceId) {
        result.add(next);
        queue.push(next);
      }
    });
  }
  return result;
}

function clearTraceHighlight() {
  const container = document.getElementById('svg-container');
  if (!container) return;
  container.querySelectorAll('.trace-dim, .trace-hit, .trace-source').forEach(el => {
    el.classList.remove('trace-dim', 'trace-hit', 'trace-source');
  });
  interaction.traceSource = null;
}

function applyTraceHighlight(sourceId) {
  const container = document.getElementById('svg-container');
  if (!container) return;
  clearTraceHighlight();
  const included = downstreamSet(sourceId);
  included.add(sourceId);
  container.querySelectorAll('.draggable-node').forEach(n => {
    const id = n.dataset.id;
    if (id === sourceId) n.classList.add('trace-source', 'trace-hit');
    else if (included.has(id)) n.classList.add('trace-hit');
    else n.classList.add('trace-dim');
  });
  container.querySelectorAll('.sld-edge').forEach(p => {
    const s = p.dataset.source, t = p.dataset.target;
    if (included.has(s) && included.has(t)) p.classList.add('trace-hit');
    else p.classList.add('trace-dim');
  });
  interaction.traceSource = sourceId;
}

function setTraceMode(on) {
  if (on && interaction.connectMode) setConnectMode(false);
  interaction.traceMode = !!on;
  const container = document.getElementById('svg-container');
  const btn = document.getElementById('btn-trace-mode');
  const hint = document.getElementById('trace-hint');
  if (container) container.classList.toggle('trace-mode', interaction.traceMode);
  if (btn) btn.classList.toggle('active', interaction.traceMode);
  if (hint) hint.hidden = !interaction.traceMode;
  if (!interaction.traceMode) clearTraceHighlight();
}

(function initTraceMode() {
  const container = document.getElementById('svg-container');
  const btn = document.getElementById('btn-trace-mode');
  if (!btn || !container) return;
  btn.addEventListener('click', () => setTraceMode(!interaction.traceMode));
  // In trace mode, intercept clicks before connect/drag handlers
  container.addEventListener('click', e => {
    if (!interaction.traceMode) return;
    const nodeEl = e.target.closest && e.target.closest('.draggable-node');
    if (nodeEl) {
      e.preventDefault();
      e.stopPropagation();
      applyTraceHighlight(nodeEl.dataset.id);
    } else {
      // Background click clears the highlight but stays in trace mode
      clearTraceHighlight();
    }
  }, true);
})();

// Hook Esc to exit trace mode / clear highlight (chains with existing Esc handlers).
document.addEventListener('keydown', e => {
  if (e.key !== 'Escape') return;
  if (interaction.traceSource) { clearTraceHighlight(); return; }
  if (interaction.traceMode)   { setTraceMode(false); return; }
});

// ─── TOOLBAR TOGGLES (snap, legend, language) ─────────────────────
(function initToolbarToggles() {
  const snap = document.getElementById('toggle-snap');
  if (snap) {
    snap.checked = state.snapToGrid;
    snap.addEventListener('change', () => {
      state.snapToGrid = snap.checked;
    });
  }
  const legend = document.getElementById('toggle-legend');
  if (legend) {
    legend.checked = state.showLegend;
    legend.addEventListener('change', () => {
      state.showLegend = legend.checked;
      if (state.json) renderDiagram(state.json);
    });
  }

  // Language toggle: switch between EN and 中文.
  // Freeze current node positions first so the re-render preserves the
  // layout — the user's translation toggle should never reshuffle the SLD.
  const btnEn = document.getElementById('btn-lang-en');
  const btnZh = document.getElementById('btn-lang-zh');
  function setLanguage(lang) {
    if (lang !== 'en' && lang !== 'zh') return;
    if (state.language === lang) return;
    if (state.json && typeof freezeCurrentLayoutPositions === 'function') {
      freezeCurrentLayoutPositions();
    }
    state.language = lang;
    if (btnEn) {
      btnEn.classList.toggle('active', lang === 'en');
      btnEn.setAttribute('aria-pressed', lang === 'en' ? 'true' : 'false');
    }
    if (btnZh) {
      btnZh.classList.toggle('active', lang === 'zh');
      btnZh.setAttribute('aria-pressed', lang === 'zh' ? 'true' : 'false');
    }
    if (state.json) renderDiagram(state.json);
  }
  if (btnEn) btnEn.addEventListener('click', () => setLanguage('en'));
  if (btnZh) btnZh.addEventListener('click', () => setLanguage('zh'));
})();

// ─── TITLE BLOCK MODAL ────────────────────────────────────────────
(function initTitleBlock() {
  const modal = document.getElementById('title-modal');
  const openBtn = document.getElementById('btn-title-block');
  const closeBtn = document.getElementById('btn-close-title');
  const saveBtn = document.getElementById('btn-title-save');
  const clearBtn = document.getElementById('btn-title-clear');
  if (!modal || !openBtn) return;

  const fields = {
    project_name:   document.getElementById('tb-project'),
    drawing_no:     document.getElementById('tb-drawing-no'),
    revision:       document.getElementById('tb-revision'),
    date:           document.getElementById('tb-date'),
    drawn_by:       document.getElementById('tb-drawn-by'),
    classification: document.getElementById('tb-classification'),
  };

  function open() {
    const meta = (state.json && state.json.project_meta) || {};
    Object.keys(fields).forEach(k => {
      if (fields[k]) fields[k].value = meta[k] || '';
    });
    modal.hidden = false;
  }
  function close() { modal.hidden = true; }
  function save() {
    if (!state.json) { close(); return; }
    if (!state.json.project_meta) state.json.project_meta = {};
    Object.keys(fields).forEach(k => {
      const v = fields[k] ? fields[k].value.trim() : '';
      if (v) state.json.project_meta[k] = v;
      else delete state.json.project_meta[k];
    });
    close();
    renderDiagram(state.json);
  }
  function clearAll() {
    Object.keys(fields).forEach(k => { if (fields[k]) fields[k].value = ''; });
  }

  openBtn.addEventListener('click', () => {
    if (!state.json) {
      alert('Load a diagram first, then edit its title block.');
      return;
    }
    open();
  });
  closeBtn.addEventListener('click', close);
  saveBtn.addEventListener('click', save);
  clearBtn.addEventListener('click', clearAll);
  modal.addEventListener('click', e => { if (e.target === modal) close(); });
})();

// Hook Esc to close the title modal as well
document.addEventListener('keydown', e => {
  if (e.key !== 'Escape') return;
  const tm = document.getElementById('title-modal');
  if (tm && !tm.hidden) { tm.hidden = true; }
});

// ─── LANDING SPLASH + FILE-LOADER WIRING ──────────────────────────
// Reuse the embedded NGEN logo from the header for both the landing splash
// and the drag-drop spinner so the file stays fully self-contained.
(function initBrandedSplash() {
  const headerLogo = document.querySelector('.brand-logo');
  const logoSrc = headerLogo ? headerLogo.src : '';
  const landingLogo = document.getElementById('landing-logo');
  const flLogoImg = document.getElementById('fl-logo-img');
  if (logoSrc && landingLogo) landingLogo.src = logoSrc;
  if (logoSrc && flLogoImg) flLogoImg.src = logoSrc;

  const overlay = document.getElementById('landing-overlay');
  const startBtn = document.getElementById('btn-start');
  function dismissLanding() {
    if (!overlay) return;
    overlay.classList.add('hide');
    // Remove from the DOM after the fade so it can't trap focus or events.
    setTimeout(() => overlay && overlay.parentNode && overlay.parentNode.removeChild(overlay), 700);
  }
  if (startBtn) startBtn.addEventListener('click', dismissLanding);
})();

</script>

