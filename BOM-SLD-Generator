// â”€â”€â”€ LAYER ASSIGNMENT (topology-aware) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
// Each device is pinned to a layer (row) based on its role in the topology,
// not just its kind. The same `panel` kind can appear at the metering chain
// (between source and main breaker) or as a load (below feeder breakers) —
// graph position decides which.
//
// The renderer guarantees this row order, top to bottom:
//   0  source row              (utility / generator)
//   1  metering CT row
//   2  metering meter row
//   3  main incomer breaker row
//   4  main bus row
//   5  feeder breaker row      (drops off the main bus)
//   6  primary load row        (UPS, panel, CPT, mech load directly under a feeder)
//   7  ups output breaker / secondary feed row
//   8  secondary bus row       (UPS bus / critical bus)
//   9  secondary feeder breaker row
//  10  pdu row
//  11  busway row
//  12  rpp / final load row
//  13  ground bus row
//
// The function walks downstream from each main_bus and from sources to
// classify every device into one of these rows.
// â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

const ROW = {
  source:           0,
  metering_ct:      1,
  metering_meter:   2,
  main_incomer:     3,
  main_bus:         4,
  feeder_cb:        5,
  primary_load:     6,
  ups_out:          7,
  secondary_bus:    8,
  sec_feeder:       9,
  pdu:             10,
  busway:          11,
  rpp:             12,
  ground_bus:      13,
};

// Default row for each kind when topology doesn't override it.
const KIND_DEFAULT_ROW = {
  utility:          ROW.source,
  generator:        ROW.source,
  incomer_cb:       ROW.main_incomer,    // breakers feeding an ATS sit just above the bus
  ats:              ROW.main_incomer,
  main_incomer_cb:  ROW.main_incomer,
  main_bus:         ROW.main_bus,
  feeder_cb:        ROW.feeder_cb,
  ups_in_cb:        ROW.feeder_cb,
  ups:              ROW.primary_load,
  bypass:           ROW.primary_load,
  panel:            ROW.primary_load,
  mech_panel:       ROW.primary_load,
  battery:          ROW.ups_out,
  ups_out_cb:       ROW.ups_out,
  secondary_bus:    ROW.secondary_bus,
  sec_feeder_cb:    ROW.sec_feeder,
  pdu:              ROW.pdu,
  busway:           ROW.busway,
  rpp:              ROW.rpp,
  sts:              ROW.pdu,
  other:            ROW.primary_load,
  ground_bus:       ROW.ground_bus,
  // Bus separator is a bus-row ornament, not a graph node — never laid out by
  // ELK. This default row is cosmetic (used only if something iterates it).
  bus_separator:    ROW.main_bus,
  // Inline metering — topology walk will move these to wherever they fit
  // (top-level metering chain → metering_ct/metering_meter rows; inline on
  // a UPS output or feeder → wherever their parent puts them).
  ct:               ROW.metering_ct,
  meter:            ROW.metering_meter,
};

function computeLayers(model) {
  // Step 1: start with each device's default row from its kind.
  const layer = {};
  model.devices.forEach(d => {
    layer[d.id] = KIND_DEFAULT_ROW[d.kind] ?? ROW.primary_load;
  });
  // Couplers (right-segment breakers tying the section bus down to a lower bus)
  // sit on the feeder row beside their sibling feeders, not on the load row.
  model.devices.forEach(d => { if (d.isCoupler) layer[d.id] = ROW.feeder_cb; });

  // Step 2: detect the metering chain — any device on the path from a source
  // to a main_incomer_cb that isn't itself a source or breaker. Such devices
  // (CT, meter, etc.) sit on rows BETWEEN the source and the main incomer.
  const mainIncomers = model.devices.filter(d => d.kind === 'main_incomer_cb');
  mainIncomers.forEach(mainCB => {
    // Walk up from the main incomer through its ancestors until we hit a source.
    const chain = []; // ordered from main incomer (deep) to source (shallow)
    let cur = mainCB.id;
    const visited = new Set();
    while (cur && !visited.has(cur)) {
      visited.add(cur);
      const parents = model.parentsOf[cur] || [];
      if (parents.length === 0) break;
      const p = parents[0];
      const pDev = model.byId[p];
      if (!pDev) break;
      if (pDev.kind === 'utility' || pDev.kind === 'generator') break;
      chain.push(p);
      cur = p;
    }
    // chain is e.g. [MTR-MECH-MAIN, CT-MAIN], deepest-first.
    // Reverse it so it's top-to-bottom: [CT-MAIN, MTR-MECH-MAIN].
    chain.reverse();
    // Assign rows: first chain item → metering_ct row, second → metering_meter row,
    // any deeper → spread across rows between source and main incomer.
    if (chain.length === 1) {
      layer[chain[0]] = ROW.metering_meter;
    } else if (chain.length === 2) {
      layer[chain[0]] = ROW.metering_ct;
      layer[chain[1]] = ROW.metering_meter;
    } else if (chain.length >= 3) {
      // Spread evenly between source (row 0) and main incomer (row 3).
      // Rows 1 and 2 are metering CT and meter; deeper items collapse onto row 2.
      chain.forEach((id, i) => {
        if (i === 0) layer[id] = ROW.metering_ct;
        else layer[id] = ROW.metering_meter;
      });
    }
  });

  // Step 3: walk subtrees below the main bus to assign load-side rows.
  // Each child of a feeder_cb that doesn't have its own specific role
  // (UPS, PDU, etc.) sits at primary_load. Anything deeper goes on lower rows.
  function walkBelowBus(rootId, baseRow) {
    const seen = new Set();
    const queue = [{ id: rootId, depth: 0 }];
    while (queue.length > 0) {
      const { id, depth } = queue.shift();
      if (seen.has(id)) continue;
      seen.add(id);
      (model.childrenOf[id] || []).forEach(cid => {
        const c = model.byId[cid];
        if (!c) return;
        // Devices whose row is already pinned by kind keep it.
        // Generic panels/loads at depth N get baseRow + N - 1.
        if (c.kind === 'panel' || c.kind === 'mech_panel' || c.kind === 'other') {
          // If this panel sits directly under a feeder_cb, it's a primary_load.
          // If it's deeper, push it down to keep flow visible.
          const parentKind = c.kind;
          if (depth === 0) {
            // child of feeder breaker — leave at primary_load (already set)
          } else {
            layer[cid] = Math.max(layer[cid], ROW.primary_load + depth);
          }
        }
        queue.push({ id: cid, depth: depth + 1 });
      });
    }
  }
  model.devices.filter(d => d.kind === 'main_bus').forEach(mb => walkBelowBus(mb.id, ROW.feeder_cb));

  // Step 4: chains below a primary load (CPT → GW pattern). If a panel/other
  // device has a power-flow child (panel/other), the child must be on a row
  // BELOW its parent. We walk from each primary_load downward and push children
  // to lower rows as needed.
  function pushDescendantsDown(rootId) {
    const seen = new Set();
    function visit(id) {
      if (seen.has(id)) return;
      seen.add(id);
      const myRow = layer[id];
      (model.childrenOf[id] || []).forEach(cid => {
        const c = model.byId[cid];
        if (!c) return;
        // Children must be on a row strictly greater than the parent's row.
        if (layer[cid] <= myRow) {
          layer[cid] = myRow + 1;
        }
        visit(cid);
      });
    }
    visit(rootId);
  }
  // Run from every source so the whole tree is normalized.
  model.devices.filter(d => model.parentsOf[d.id].length === 0).forEach(d => pushDescendantsDown(d.id));

  // Step 5: compact layers — remove unused rows so there are no vertical
  // gaps. Preserves relative order (top-to-bottom) but renumbers contiguously.
  const usedLayers = [...new Set(Object.values(layer))].sort((a, b) => a - b);
  const compactMap = {};
  usedLayers.forEach((l, i) => { compactMap[l] = i; });
  Object.keys(layer).forEach(id => { layer[id] = compactMap[layer[id]]; });

  return layer;
}

// Maps device kind to box dimensions + which symbol to draw inside.
const DEVICE_GEOMETRY = {
  utility:        { w: 90,  h: 90, symbol: 'utility' },
  generator:      { w: 90,  h: 90, symbol: 'generator' },
  incomer_cb:     { w: 50,  h: 50, symbol: 'cb_closed' },
  main_incomer_cb:{ w: 50,  h: 50, symbol: 'cb_closed' },
  ats:            { w: 180, h: 50, symbol: 'ats' },
