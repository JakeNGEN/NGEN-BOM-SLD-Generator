  }
  .cat-item:last-child { border-bottom: none; }
  .cat-item.has-qty { background: #fbfaf6; }
  .cat-item .ci-main { flex: 1; min-width: 0; }
  .cat-item .ci-name { font-size: 14px; font-weight: 600; color: #1f2937; }
  .cat-item .ci-sub { font-size: 12px; color: #6b7280; margin-top: 2px; }
  .cat-item .ci-price { font-size: 13px; font-weight: 600; color: #1E6356; white-space: nowrap; width: 96px; text-align: right; }

  /* Quantity stepper */
  .stepper { display: flex; align-items: center; gap: 0; flex-shrink: 0; }
  .stepper button {
    width: 30px; height: 30px; padding: 0;
    background: #1E6356; color: #fff; border: none;
    font-size: 17px; line-height: 1; font-weight: 600;
    display: flex; align-items: center; justify-content: center;
  }
  .stepper button:first-child { border-radius: 7px 0 0 7px; background: #6B9E86; }
  .stepper button:last-child { border-radius: 0 7px 7px 0; }
  .stepper button:hover:not(:disabled) { background: #15514699; filter: brightness(1.08); }
  .stepper button:disabled { opacity: 0.35; cursor: not-allowed; }
  .stepper input {
    width: 44px; height: 30px; text-align: center;
    border: 1px solid #d1d5db; border-left: none; border-right: none;
    font-size: 14px; font-family: inherit; font-weight: 600; color: #1f2937;
    -moz-appearance: textfield;
  }
  .stepper input::-webkit-outer-spin-button,
  .stepper input::-webkit-inner-spin-button { -webkit-appearance: none; margin: 0; }

  /* ── Running quote summary ── */
  .quote-summary {
    position: sticky; top: 18px;
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
    box-shadow: 0 4px 16px rgba(0,0,0,0.07);
    overflow: hidden;
  }
  .quote-summary .qs-head {
    background: #1E6356; color: #fff;
    padding: 15px 18px;
    display: flex; align-items: center; justify-content: space-between;
  }
  .quote-summary .qs-head h3 { margin: 0; font-size: 16px; font-weight: 700; }
  .quote-summary .qs-head .qs-count { font-size: 12px; color: #A1D5CC; }
  .qs-lines { max-height: 46vh; overflow-y: auto; padding: 6px 0; }
  .qs-line { display: flex; align-items: baseline; gap: 8px; padding: 8px 18px; font-size: 13px; }
  .qs-line .qsl-name { flex: 1; color: #374151; }
  .qs-line .qsl-name .qsl-qty { color: #6B9E86; font-weight: 700; margin-right: 5px; }
  .qs-line .qsl-amt { font-weight: 600; color: #1f2937; white-space: nowrap; }
  .qs-empty { padding: 26px 18px; text-align: center; color: #9ca3af; font-size: 13px; }
  .qs-cat-label { padding: 10px 18px 3px; font-size: 10px; text-transform: uppercase; letter-spacing: 0.6px; color: #6B9E86; font-weight: 700; }
  .qs-total {
    border-top: 2px solid #f0f5f3;
    padding: 16px 18px;
    display: flex; align-items: baseline; justify-content: space-between;
  }
  .qs-total .qst-label { font-size: 13px; font-weight: 600; color: #374151; }
  .qs-total .qst-amt { font-size: 24px; font-weight: 700; color: #1E6356; }
  .qs-total .qst-amt small { font-size: 13px; color: #6b7280; font-weight: 500; margin-left: 4px; }
  .qs-actions { padding: 0 18px 18px; display: flex; flex-direction: column; gap: 9px; }
  .qs-actions .btn-build {
    background: #CA942B; color: #fff; border: none;
    border-radius: 9px; padding: 14px; font-size: 15px; font-weight: 700;
    display: flex; align-items: center; justify-content: center; gap: 9px;
    box-shadow: 0 3px 10px rgba(202,148,43,0.35);
  }
  .qs-actions .btn-build:hover:not(:disabled) { background: #b08023; }
  .qs-actions .btn-build:disabled { background: #d1d5db; box-shadow: none; cursor: not-allowed; }
  .qs-actions .btn-clear {
    background: transparent; color: #6b7280; border: 1px solid #e5e7eb;
    border-radius: 9px; padding: 9px; font-size: 13px; font-weight: 500;
  }
  .qs-actions .btn-clear:hover { color: #b91c1c; border-color: #fca5a5; background: #fef2f2; }
  .qs-actions .btn-export {
    background: #1E6356; color: #fff; border: none;
    border-radius: 9px; padding: 11px; font-size: 14px; font-weight: 600;
    display: flex; align-items: center; justify-content: center;
  }
  .qs-actions .btn-export:hover:not(:disabled) { background: #155146; }
  .qs-actions .btn-export:disabled { background: #d1d5db; cursor: not-allowed; }
  .qs-actions .btn-save {
    background: #CA942B; color: #fff; border: none;
    border-radius: 9px; padding: 11px; font-size: 14px; font-weight: 600;
    display: flex; align-items: center; justify-content: center; gap: 6px;
  }
  .qs-actions .btn-save:hover:not(:disabled) { background: #b08023; }
  .qs-actions .btn-save:disabled { background: #d1d5db; cursor: not-allowed; }

  /* Group header — group title + group-qty stepper */
  .cat-group > h3 .cat-title { flex: 1; }
  .cat-group > h3 .group-qty { display: flex; align-items: center; gap: 8px; font-weight: 500; font-size: 11px; color: #6B9E86; text-transform: uppercase; letter-spacing: 0.4px; }
  .gq-stepper button { width: 24px; height: 24px; font-size: 14px; }
  .gq-stepper input { width: 36px; height: 24px; font-size: 12px; }

  /* Subgroups within a category (LV Switchgear) */
  .cat-sub { border-top: 1px solid #f1f1ef; }
  .cat-sub:first-child { border-top: none; }
  .cat-sub-h {
    margin: 0;
    padding: 9px 18px 5px;
    font-size: 11px;
    font-weight: 700;
    color: #6B9E86;
    background: #fafaf7;
    letter-spacing: 0.5px;
    text-transform: uppercase;
  }

  /* Quote summary — group qty mult chip + per-line mult breakdown */
  .qs-cat-label .qs-gqty { color: #CA942B; font-weight: 700; }
  .qs-line .qsl-name .qsl-mult { color: #9ca3af; font-size: 11px; margin-left: 4px; }

  /* Topology mode selector */
  .qs-topo { padding: 12px 18px 0; }
  .qs-topo label { display: block; font-size: 11px; text-transform: uppercase; letter-spacing: 0.5px; color: #6B9E86; font-weight: 700; margin-bottom: 5px; }
  .qs-topo select {
    width: 100%;
    padding: 9px 10px;
    font-family: inherit;
    font-size: 13px;
    border: 1px solid #e5e7eb;
    border-radius: 7px;
    background: #fff;
    color: #1f2937;
  }
  .qs-topo select:focus { outline: 2px solid #CA942B; border-color: #CA942B; }
  .qs-topo-hint { font-size: 11px; color: #9ca3af; margin-top: 6px; line-height: 1.4; }
  .qs-topo-hint em { font-style: normal; color: #6B9E86; font-weight: 600; }

  /* Rating dropdown per section */
  .rating-select {
    font-family: inherit; font-size: 12px; font-weight: 500;
    border: 1px solid #d1d5db; border-radius: 6px;
    background: #fff; color: #1f2937;
    padding: 4px 8px; min-width: 86px; flex-shrink: 0;
    cursor: pointer;
  }
  .rating-select:hover { border-color: #6B9E86; }
  .rating-select:focus { outline: 2px solid #CA942B; border-color: #CA942B; }
  .rating-static {
    font-size: 11px; font-weight: 600; color: #6B9E86;
    padding: 4px 8px; background: #f0f5f3; border-radius: 6px;
    flex-shrink: 0;
  }
  .qs-line .qsl-name .qsl-rating { color: #1d4ed8; font-weight: 700; font-size: 10.5px; }

  /* Critical toggle on Mech / Therm / Gen-Aux sections */
  .crit-toggle {
    font-size: 11px; font-weight: 700; letter-spacing: 0.3px;
    padding: 4px 10px; border-radius: 999px;
    border: 1px solid #d1d5db; background: #fff; color: #9ca3af;
    cursor: pointer; flex-shrink: 0;
    transition: color 0.12s, border-color 0.12s, background 0.12s;
  }
  .crit-toggle:hover { color: #dc2626; border-color: #fca5a5; background: #fef2f2; }
  .crit-toggle.is-critical {
    color: #dc2626; border-color: #dc2626; background: #fef2f2;
    box-shadow: 0 0 0 1px rgba(220,38,38,0.15);
  }
  .crit-toggle.is-critical::before { content: '● '; }
  .cat-item.is-critical .ci-name { color: #dc2626; }

  .landing-overlay.hide {
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
  }
  .landing-content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 22px;
    padding: 40px;
    max-width: 720px;
    text-align: center;
  }

  .landing-anim-wrap {
    width: 480px;
    max-width: 90vw;
    aspect-ratio: 480 / 220;
    position: relative;
  }
  .landing-anim {
    width: 100%;
    height: 100%;
    overflow: visible;
  }

  /* line draw: pathLength=1 makes every path animate over the same duration */
  .la-stroke {
    fill: none;
    stroke: #A1D5CC;
    stroke-width: 2.5;
    stroke-linecap: round;
    stroke-dasharray: 1;
    stroke-dashoffset: 1;
    animation: laDraw 0.85s ease forwards;
    filter: drop-shadow(0 0 4px rgba(161,213,204,0.45));
  }
  .la-stroke.bus {
    stroke: #CA942B;
    stroke-width: 5;
    filter: drop-shadow(0 0 8px rgba(202,148,43,0.65));
  }
  .la-stroke.feed {
    stroke: #CA942B;
    stroke-width: 3;
    filter: drop-shadow(0 0 6px rgba(202,148,43,0.55));
  }
  @keyframes laDraw {
    to { stroke-dashoffset: 0; }
  }

  .la-node {
    opacity: 0;
    transform-box: fill-box;
    transform-origin: center;
    animation: laPop 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
  }
  @keyframes laPop {
    0%   { opacity: 0; transform: scale(0.4); }
    60%  { opacity: 1; transform: scale(1.12); }
    100% { opacity: 1; transform: scale(1); }
  }

  /* Energy pulse riding the busbar, kicks in after the SLD finishes drawing */
  .la-pulse {
    fill: #ffd574;
    filter: drop-shadow(0 0 6px #CA942B);
    opacity: 0;
    animation: laPulseRun 2.4s ease-in-out 2.6s infinite;
  }
  @keyframes laPulseRun {
    0%   { opacity: 0; transform: translateX(0); }
    10%  { opacity: 1; }
    90%  { opacity: 1; }
    100% { opacity: 0; transform: translateX(420px); }
  }

  .landing-logo {
    width: 240px;
    max-width: 70vw;
    height: auto;
    padding: 12px 22px;
    background: #faf8f2;
    border-radius: 12px;
    box-shadow: 0 14px 36px rgba(0,0,0,0.35);
    opacity: 0;
    transform: translateY(16px);
    animation: landingFadeUp 0.7s ease 2.2s forwards;
  }

  .landing-title {
    font-family: 'Poppins', sans-serif;
    font-size: 40px;
    font-weight: 700;
    letter-spacing: -0.5px;
    margin: 4px 0 0;
    opacity: 0;
    transform: translateY(16px);
    animation: landingFadeUp 0.7s ease 2.5s forwards;
  }
  .landing-title .accent { color: #CA942B; }

  .landing-subtitle {
    font-family: 'Poppins', sans-serif;
    font-size: 15px;
    color: #A1D5CC;
    font-weight: 300;
    letter-spacing: 0.4px;
    margin: 0 0 6px;
    max-width: 460px;
    opacity: 0;
    transform: translateY(16px);
    animation: landingFadeUp 0.7s ease 2.75s forwards;
  }
  @keyframes landingFadeUp {
    to { opacity: 1; transform: translateY(0); }
  }

  .start-btn {
    background: #CA942B;
    color: #ffffff;
    border: none;
    border-radius: 999px;
    padding: 16px 36px 16px 32px;
    font-size: 15px;
    font-family: 'Poppins', sans-serif;
    font-weight: 600;
    letter-spacing: 0.4px;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    box-shadow: 0 14px 30px rgba(202,148,43,0.45);
    opacity: 0;
    transform: translateY(16px);
    animation: landingFadeUp 0.7s ease 3.0s forwards, startGlow 2.6s ease-in-out 3.9s infinite;
    transition: transform 0.18s ease, background 0.18s ease, box-shadow 0.18s ease;
  }
  .start-btn:hover {
    background: #d8a23b;
    transform: translateY(-2px);
    box-shadow: 0 18px 38px rgba(202,148,43,0.55);
  }
  .start-btn:active { transform: translateY(0); }
  .start-btn .arrow {
    display: inline-block;
    transition: transform 0.2s ease;
  }
  .start-btn:hover .arrow { transform: translateX(4px); }
  @keyframes startGlow {
    0%, 100% { box-shadow: 0 14px 30px rgba(202,148,43,0.45), 0 0 0 0 rgba(202,148,43,0.55); }
    50%      { box-shadow: 0 14px 30px rgba(202,148,43,0.45), 0 0 0 18px rgba(202,148,43,0); }
  }

  /* ─── FILE-READ LOADER (drag/drop) ────────────────────────────── */
  .file-loader {
    position: fixed;
    inset: 0;
    z-index: 5000;
    background: rgba(14, 58, 49, 0.55);
    -webkit-backdrop-filter: blur(4px);
    backdrop-filter: blur(4px);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.22s ease, visibility 0.22s;
  }
  .file-loader.show { opacity: 1; visibility: visible; }
  .file-loader-card {
    background: #faf8f2;
    border-radius: 14px;
    padding: 22px 28px 20px;
    box-shadow: 0 22px 50px rgba(0,0,0,0.35);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    min-width: 240px;
    font-family: 'Poppins', sans-serif;
  }
  .fl-spinner {
    position: relative;
    width: 78px;
    height: 78px;
  }
  .fl-ring {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    border: 4px solid rgba(30,99,86,0.14);
    border-top-color: #CA942B;
    border-right-color: #CA942B;
    animation: flSpin 1.05s linear infinite;
  }
  @keyframes flSpin { to { transform: rotate(360deg); } }
  .fl-logo {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 50px;
    height: 50px;
    transform: translate(-50%, -50%);
    background: #ffffff;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 3px 8px rgba(0,0,0,0.15);
    padding: 6px;
    box-sizing: border-box;
    overflow: hidden;
  }
  .fl-logo img {
    width: 100%;
    height: auto;
    display: block;
  }
  .fl-text {
    font-size: 14px;
    font-weight: 600;
    color: #1E6356;
    letter-spacing: 0.3px;
    margin-top: 2px;
  }
  .fl-subtext {
    font-size: 12px;
    color: #6B9E86;
    font-weight: 400;
    margin-top: -6px;
    max-width: 240px;
    text-align: center;
    word-break: break-all;
  }

  /* ─── ZOOM / PAN / TOOLBAR EXTRAS ───────────────────────────── */
  .diagram-toolbar .tb-group {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    border: 1px solid #d1d5db;
    border-radius: 6px;
    padding: 2px;
    background: #f9fafb;
  }
  .diagram-toolbar .tb-group .btn-toolbar {
    padding: 4px 8px;
    border: none;
    background: transparent;
    color: #1E6356;
    border-radius: 4px;
    min-width: 28px;
    justify-content: center;
  }
  .diagram-toolbar .tb-group .btn-toolbar:hover { background: #e8f3f0; }
  .diagram-toolbar .zoom-indicator {
    font-size: 12px;
    font-weight: 600;
    color: #1E6356;
    min-width: 44px;
    text-align: center;
    user-select: none;
  }
  .diagram-toolbar .tb-divider {
    width: 1px;
    height: 22px;
    background: #d1d5db;
    margin: 0 4px;
  }

  /* Active state for the segmented language toggle */
  .diagram-toolbar .lang-toggle .btn-toolbar {
    min-width: 38px;
    font-weight: 600;
  }
  .diagram-toolbar .lang-toggle .btn-toolbar.active {
    background: #1E6356;
    color: #ffffff;
  }
  .diagram-toolbar .lang-toggle .btn-toolbar.active:hover {
    background: #185040;
  }

  /* Pan modes */
  #svg-container.pan-ready { cursor: grab; }
  #svg-container.panning { cursor: grabbing; }
  #svg-container.pan-ready svg .draggable-node { cursor: grab; }
  #svg-container.panning svg .draggable-node { cursor: grabbing; }

  /* SVG must hold its rendered width — let the container scroll */
  #svg-container { overflow: auto; }

  /* ─── HOVER TOOLTIP ──────────────────────────────────────────── */
  .canvas-tooltip {
    position: fixed;
    z-index: 4000;
    background: #1E6356;
    color: #ffffff;
    border-radius: 8px;
    padding: 10px 12px;
    box-shadow: 0 8px 20px rgba(0,0,0,0.25), 0 0 0 1px rgba(255,255,255,0.06);
    font-family: 'Poppins', sans-serif;
    font-size: 12px;
    line-height: 1.45;
    pointer-events: none;
    max-width: 320px;
    display: none;
    border-left: 3px solid #CA942B;
  }
  .canvas-tooltip .tt-title {
    font-size: 13px;
    font-weight: 700;
    color: #ffffff;
    margin-bottom: 2px;
  }
  .canvas-tooltip .tt-id {
    font-size: 11px;
    color: #A1D5CC;
    font-weight: 400;
    margin-bottom: 6px;
    font-family: 'SF Mono', Consolas, monospace;
  }
  .canvas-tooltip .tt-row {
    display: flex;
    gap: 8px;
    margin-top: 3px;
  }
  .canvas-tooltip .tt-row .tt-label {
    color: #CA942B;
    font-weight: 600;
    text-transform: uppercase;
    font-size: 10px;
    letter-spacing: 0.4px;
    flex-shrink: 0;
    width: 56px;
    padding-top: 1px;
  }
  .canvas-tooltip .tt-row .tt-value {
    color: #ffffff;
    flex: 1;
    word-break: break-word;
  }

  /* ─── TRACE / HIGHLIGHT MODE ─────────────────────────────────── */
  #svg-container.trace-mode svg { cursor: crosshair; }
  #svg-container .draggable-node.trace-dim,
  #svg-container .sld-edge.trace-dim {
    opacity: 0.15;
    transition: opacity 0.18s ease;
  }
  #svg-container .draggable-node.trace-hit .node-hit {
    fill: rgba(202,148,43,0.16);
    stroke: #CA942B;
    stroke-width: 1.5;
  }
  #svg-container .sld-edge.trace-hit {
    stroke: #CA942B !important;
    stroke-width: 3 !important;
    filter: drop-shadow(0 0 6px rgba(202,148,43,0.6));
  }
  #svg-container .draggable-node.trace-source .node-hit {
    fill: rgba(30,99,86,0.22);
    stroke: #1E6356;
    stroke-width: 2;
  }

  /* ─── TITLE BLOCK MODAL — re-uses .modal styles ─────────────── */
  .title-form {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
  }
  .title-form .add-field { margin: 0; }
  .title-form .add-field.full { grid-column: 1 / -1; }
  .title-form input, .title-form select {
    width: 100%;
    padding: 8px 10px;
    border: 1px solid #d1d5db;
    border-radius: 6px;
    font-family: inherit;
    font-size: 13px;
  }
  .title-form label {
    display: block;
    font-size: 11px;
    font-weight: 600;
    color: #1E6356;
    text-transform: uppercase;
    letter-spacing: 0.4px;
    margin-bottom: 4px;
  }

  /* Context menu (right-click on canvas) */
  .context-menu {
    position: fixed;
    background: white;
    border: 1px solid #d1d5db;
    border-radius: 8px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.18);
    padding: 4px;
    min-width: 200px;
    z-index: 1500;
    font-family: 'Poppins', 'Aptos', 'Calibri', sans-serif;
  }
  .context-menu[hidden] { display: none; }
  .context-menu button {
    display: flex;
    align-items: center;
    gap: 8px;
    width: 100%;
    background: transparent;
    border: none;
    color: #1f2937;
    padding: 8px 12px;
    font-size: 13px;
    font-family: inherit;
    text-align: left;
    cursor: pointer;
    border-radius: 5px;
  }
  .context-menu button:hover { background: #f3f4f6; }
  .context-menu button.danger { color: #b91c1c; }
  .context-menu button.danger:hover { background: #fef2f2; }
  .context-menu button svg { width: 14px; height: 14px; flex-shrink: 0; }
  .context-menu hr {
    border: none;
    border-top: 1px solid #e5e7eb;
    margin: 4px 0;
  }
  .context-menu .menu-coords {
    padding: 4px 12px;
    font-size: 11px;
    color: #9ca3af;
    font-family: 'SF Mono', Consolas, monospace;
  }
  .error {
    margin: 16px;
    padding: 12px;
    background: #fef2f2;
    border: 1px solid #fecaca;
    border-radius: 6px;
    color: #991b1b;
    font-size: 13px;
    font-family: 'SF Mono', Consolas, monospace;
    white-space: pre-wrap;
    word-break: break-word;
  }
</style>
</head>
