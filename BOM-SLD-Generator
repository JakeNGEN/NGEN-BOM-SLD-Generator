// â”€â”€â”€ SYMBOLS â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
// Each function takes (w, h) and returns an SVG string drawn relative to
// (0, 0) at top-left. The render code places them via a transform.
//
// Polish: every device shell is drawn with shell() which adds a top-down
// gradient fill, a soft drop shadow, and a subtle gloss highlight strip
// across the top. Internal symbols (contact lines, transformer circles,
// outlets) sit on top of the gloss so they remain crisp.
// â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

// Renders a polished rectangular body: gradient fill + drop shadow + gloss.
// fillId is the id of a linearGradient defined in <defs>.
function shell(w, h, fillId, opts = {}) {
  const x = opts.x ?? 0;
  const y = opts.y ?? 0;
  const rx = opts.rx ?? 4;
  const glossH = opts.glossH ?? h * 0.45;
  const filter = opts.filter || 'dropShadow';
  return `
    <rect x="${x}" y="${y}" width="${w}" height="${h}" rx="${rx}" fill="url(#${fillId})" stroke="${STYLE.deviceStroke}" stroke-width="${STYLE.deviceStrokeW}" filter="url(#${filter})"/>
    <rect x="${x+1}" y="${y+1}" width="${w-2}" height="${glossH}" rx="${Math.max(rx-1, 1)}" fill="url(#gloss)" pointer-events="none"/>
  `;
}

// Polished bus body (long thin bar, smaller gloss band, stronger shadow).
function busShell(w, h, fillId) {
  return `
    <rect width="${w}" height="${h}" fill="url(#${fillId})" stroke="${STYLE.deviceStroke}" stroke-width="${STYLE.busStrokeW}" filter="url(#busShadow)"/>
    <rect x="1" y="1" width="${w-2}" height="${h*0.4}" fill="url(#gloss)" pointer-events="none"/>
  `;
}

const SYMBOLS = {
  // Utility transformer — green circle with white "U"
  utility: (w, h) => {
    const r = Math.min(w, h) / 2 - 3;
    const cx = w / 2, cy = h / 2;
    return `
    <circle cx="${cx}" cy="${cy}" r="${r}" fill="url(#gradUtil)" stroke="#1a3a0a" stroke-width="2" filter="url(#dropShadow)"/>
    <ellipse cx="${cx}" cy="${cy - r*0.4}" rx="${r*0.72}" ry="${r*0.32}" fill="url(#gloss)" pointer-events="none"/>
    <text x="${cx}" y="${cy}" text-anchor="middle" dominant-baseline="central" font-family="${STYLE.fontFamily}" font-size="${Math.round(r*0.95)}" font-weight="700" fill="#ffffff">U</text>`;
  },

  // Generator — tan circle with white "G"
  generator: (w, h) => {
    const r = Math.min(w, h) / 2 - 3;
    const cx = w / 2, cy = h / 2;
    return `
