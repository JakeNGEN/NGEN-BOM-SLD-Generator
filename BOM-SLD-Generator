// Take the raw JSON from extraction and produce a clean device + connection
// list with canonical kinds. Same logic the in-skill renderer uses.
// â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

const DEVICE_TYPE_TO_KIND = {
  'Utility Transformer':            'utility',
  'Diesel Generator':               'generator',
  'Gas Generator':                  'generator',
  'Automatic Transfer Switch':      'ats',
  'Air Circuit Breaker':            'feeder_cb',
  'Molded Case Circuit Breaker':    'feeder_cb',
  'LV Switchgear Lineup':           'main_bus',
  'MV Switchgear':                  'main_bus',
  'Static UPS':                     'ups',
  'Rotary UPS':                     'ups',
  'Battery Cabinet':                'battery',
  'Bypass Switch':                  'bypass',
  'Step-Down Transformer / PDU':    'pdu',
  'Remote Power Panel':             'rpp',
  'Busway':                         'busway',
  'Static Transfer Switch':         'sts',
  'Current Transformer':            'ct',
  'Meter':                          'meter',
  'Revenue-grade Meter':            'meter',
  'Revenue-grade CT':               'ct',
};

const PREFIX_TO_KIND = {
  UTIL: 'utility', TX: 'utility', XFMR: 'utility',
  GEN: 'generator', DG: 'generator',
  ATS: 'ats',
  MSB: 'main_bus', MB: 'main_bus', SWBD: 'main_bus',
  CB: 'feeder_cb', FB: 'feeder_cb', MCB: 'feeder_cb', FDR: 'feeder_cb',
  UPS: 'ups',
  BAT: 'battery', BC: 'battery',
  BYP: 'bypass', BPS: 'bypass', MBP: 'bypass',
  MECH: 'panel', HVAC: 'panel', BMS: 'panel',
  PNL: 'panel', PANEL: 'panel', SWB: 'panel',
  PDU: 'pdu',
  BW: 'busway', BUS: 'busway',
  RPP: 'rpp',
  STS: 'sts',
  CRIT: 'rpp',
  CT: 'ct',
  MTR: 'meter', MET: 'meter', METER: 'meter',
};

function resolveKind(raw) {
  const dt = (raw.device_type || '').trim();
  if (DEVICE_TYPE_TO_KIND[dt]) return DEVICE_TYPE_TO_KIND[dt];
  if (dt.toLowerCase().startsWith('other')) return 'panel';
  const prefix = (raw.id || '').toUpperCase().split('-')[0];
  return PREFIX_TO_KIND[prefix] || 'panel';
}

function normalize(json) {
  const devices = (json.devices || []).map(rd => ({
    id: rd.id,
    kind: resolveKind(rd),
    label: rd.label || rd.id,
    label_zh: rd.label_zh || '',
    rating_items: rd.rating_items || [],
    rating_items_zh: Array.isArray(rd.rating_items_zh) ? rd.rating_items_zh : [],
    notes: rd.notes || '',
    notes_zh: rd.notes_zh || '',
    required_input: !!rd.required_input,
    state: detectState(rd),
    x: Number.isFinite(rd.x) ? rd.x : undefined,
    y: Number.isFinite(rd.y) ? rd.y : undefined,
    _raw: rd,
  }));

  const byId = {};
  devices.forEach(d => byId[d.id] = d);

  // Build edges from both upstream_parent and downstream_children
  const edgeSet = new Set();
  const edges = [];
  const childrenOf = {};
  const parentsOf = {};
  devices.forEach(d => { childrenOf[d.id] = []; parentsOf[d.id] = []; });

  (json.devices || []).forEach(rd => {
    if (rd.upstream_parent && byId[rd.upstream_parent]) {
      const key = `${rd.upstream_parent}|${rd.id}`;
      if (!edgeSet.has(key)) {
        edgeSet.add(key);
        edges.push({ source: rd.upstream_parent, target: rd.id, style: 'normal' });
        childrenOf[rd.upstream_parent].push(rd.id);
        parentsOf[rd.id].push(rd.upstream_parent);
      }
    }
    (rd.downstream_children || []).forEach(cid => {
      if (byId[cid]) {
        const key = `${rd.id}|${cid}`;
        if (!edgeSet.has(key)) {
          edgeSet.add(key);
          edges.push({ source: rd.id, target: cid, style: 'normal' });
          childrenOf[rd.id].push(cid);
          parentsOf[cid].push(rd.id);
        }
      }
    });
  });

  // Bus demotion: a main_bus with a main_bus ancestor becomes secondary_bus.
  function hasMainBusAncestor(devId, visited = new Set()) {
    if (visited.has(devId)) return false;
    visited.add(devId);
    for (const p of parentsOf[devId]) {
      const parent = byId[p];
      if (parent.kind === 'main_bus') return true;
      if (hasMainBusAncestor(p, visited)) return true;
    }
    return false;
  }
  devices.forEach(d => {
    if (d.kind === 'main_bus' && hasMainBusAncestor(d.id)) {
      d.kind = 'secondary_bus';
    }
  });

  // Tier-aware breaker reclassification
  const BREAKERS = new Set(['feeder_cb', 'incomer_cb', 'ups_in_cb', 'ups_out_cb', 'sec_feeder_cb', 'main_incomer_cb']);
  devices.forEach(d => {
    if (!BREAKERS.has(d.kind)) return;
    const childKinds = childrenOf[d.id].map(c => byId[c].kind);
    const parentKinds = parentsOf[d.id].map(p => byId[p].kind);
    // Main incomer: breaker that drops INTO the main bus from above.
    // The parent is NOT main_bus (since the bus is its child).
    if (childKinds.includes('main_bus') && !parentKinds.includes('main_bus')) {
      d.kind = 'main_incomer_cb';
    }
    else if (parentKinds.includes('ups')) d.kind = 'ups_out_cb';
    else if (childKinds.includes('ups')) d.kind = 'ups_in_cb';
    else if (childKinds.includes('ats')) d.kind = 'incomer_cb';
    else if (parentKinds.includes('secondary_bus')) d.kind = 'sec_feeder_cb';
    // else stays feeder_cb
  });

  // Bus segmentation (bus-section breaker model). A bus is "segmented" when a
  // real breaker sits inline on it as a bus-section / tie breaker — flagged by
  // `segments_bus: "<busId>"` on that breaker. The section breaker is drawn as
  // an inline ornament straddling the bar (see computeSegmentation /
  // renderSectionBreakers); it is kept out of the ELK power-flow graph and its
  // drop is suppressed, since it IS the bar boundary rather than a load on it.
  const segmentedBusIds = new Set();
  devices.forEach(d => {
    const busId = d._raw && d._raw.segments_bus;
    if (!busId) return;
    if (d.kind === 'main_bus' || d.kind === 'secondary_bus' || d.kind === 'ground_bus') return;
    if (!byId[busId]) { console.warn(`Section breaker "${d.id}" references unknown bus "${busId}" in segments_bus.`); return; }
    d.isBusSection = true;
    d.sectionBus = busId;
    segmentedBusIds.add(busId);
  });
  // Resolve which side of the section breaker each feeder sits on. `bus_segment`
  // ("left" | "right") bands the feeders for ELK ordering: UPS-backed feeders go
  // right of the section breaker, everything else left. The section breaker
  // itself is excluded. bus_segment on a child of a NON-segmented bus is ignored.
  devices.forEach(d => {
    if (d.isBusSection) { d.segment = undefined; d.segmentBus = undefined; return; }
    const parentBus = (parentsOf[d.id] || []).find(pid => segmentedBusIds.has(pid));
    if (!parentBus) { d.segment = undefined; d.segmentBus = undefined; return; }
    const seg = d._raw && d._raw.bus_segment;
    d.segment = (seg === 'left' || seg === 'right') ? seg : undefined;
    d.segmentBus = parentBus;
  });
  // Coupler detection: a right-segment breaker whose child is a (lower) bus ties
  // the segmented bus down to that bus — drawn as a vertical link on the right.
  // Pinned to the feeder row in computeLayers so it aligns with its sibling
  // feeders; its bus drops are drawn by the normal edge router.
  devices.forEach(d => {
    if (d.isBusSection || !d.segmentBus) return;
    const childBus = (childrenOf[d.id] || []).find(cid => {
      const c = byId[cid];
      return c && (c.kind === 'secondary_bus' || c.kind === 'main_bus');
    });
    if (childBus) { d.isCoupler = true; d.couplesBus = childBus; }
  });

  // Detect cycles
  const cycles = findCycles(devices, childrenOf);

  // Inject ground bus if missing
  if (!devices.some(d => d.kind === 'ground_bus')) {
    devices.push({
      id: 'GND-BUS',
      kind: 'ground_bus',
      label: 'GROUND BUS',
      rating_items: [],
      required_input: false,
      state: 'normal',
    });
    byId['GND-BUS'] = devices[devices.length - 1];
    childrenOf['GND-BUS'] = [];
    parentsOf['GND-BUS'] = [];
  }

  // Re-style edges based on endpoint kinds
  edges.forEach(e => {
    const s = byId[e.source], t = byId[e.target];
    if (!s || !t) { e.style = 'normal'; return; }
    if (s.state === 'standby' || t.state === 'standby') e.style = 'standby';
    else if (s.state === 'future' || t.state === 'future') e.style = 'standby';
    else if (s.kind === 'bypass' || t.kind === 'bypass') e.style = 'standby';
    else e.style = 'normal';
  });

  return {
    devices,
    edges,
    byId,
    childrenOf,
    parentsOf,
    cycles,
    packages: Array.isArray(json.packages) ? json.packages : [],
    interlocks: Array.isArray(json.interlocks) ? json.interlocks : [],
    segmentedBusIds,
    project_meta: json.project_meta || {},
    drawing_tag: json.drawing_tag || 'SLD',
    drawing_tag_zh: json.drawing_tag_zh || '',
    system_summary: json.system_summary || '',
    system_summary_zh: json.system_summary_zh || '',
    open_items: json.open_items || [],
  };
}

// ─── i18n HELPERS ─────────────────────────────────────────────────────────
// Single source of truth for "which language is active right now" plus a few
// helpers that pick the right field, with graceful fallback to English when
// a translation is missing.
function isZh() { return state && state.language === 'zh'; }

function pickLang(en, zh) {
  if (isZh() && zh != null && String(zh).length > 0) return zh;
  return en == null ? '' : en;
}

// rating_items / rating_items_zh — pick the array that has content for the
// active language, falling back to English if zh is empty or missing.
function pickRatingItems(d) {
  if (!d) return [];
  if (isZh() && Array.isArray(d.rating_items_zh) && d.rating_items_zh.length) {
    return d.rating_items_zh;
  }
  return Array.isArray(d.rating_items) ? d.rating_items : [];
}

function detectState(rd) {
  const n = (rd.notes || '').toLowerCase();
  if (n.includes('normally open') || n.includes('n.o.') || n.includes('standby')) return 'standby';
  if (n.includes('alternate path') || n.includes('alt path')) return 'alt_path';
  if (n.includes('future') || n.includes('provision') || n.includes('spare position')) return 'future';
  return 'normal';
}

function findCycles(devices, childrenOf) {
  const WHITE = 0, GRAY = 1, BLACK = 2;
  const color = {};
  devices.forEach(d => color[d.id] = WHITE);
  const cycles = [];
  function visit(node, path) {
    color[node] = GRAY;
    for (const c of childrenOf[node] || []) {
      if (color[c] === GRAY) {
        const i = path.indexOf(c);
        cycles.push(path.slice(i).concat(c));
        return;
      }
      if (color[c] === WHITE) visit(c, path.concat(c));
    }
    color[node] = BLACK;
  }
  devices.forEach(d => { if (color[d.id] === WHITE) visit(d.id, [d.id]); });
  return cycles;
}

// â”€â”€â”€ ELK GRAPH BUILDING â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
// Build the input graph ELK consumes. Each node carries its layer constraint
// (which row it lives on) and its geometry. Edges carry style metadata.
// â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

// Canvas-based text width measurement. We use this to size bus bars so their
// centered labels never overflow. The measurement uses the same font stack as
// the SVG; if Poppins hasn't loaded yet the fallback metrics are close enough
// for layout purposes (errs on the side of slightly-wider bars).
function measureText(text, fontSize, fontWeight) {
  if (!measureText._ctx) {
    measureText._ctx = document.createElement('canvas').getContext('2d');
  }
  measureText._ctx.font = `${fontWeight || 'normal'} ${fontSize}px ${STYLE.fontFamily}`;
  return measureText._ctx.measureText(text).width;
}

// Required width for a bus given its label, with horizontal padding so the
// text doesn't touch the bar ends.
function busRequiredWidth(device) {
  const displayLabel = pickLang(device.label, device.label_zh);
  const displaySpecs = pickRatingItems(device);
  let label;
  if (device.kind === 'ground_bus') {
    label = displayLabel;
  } else {
    label = `${displayLabel}${displaySpecs.length ? ' · ' + displaySpecs.join(' · ') : ''}`;
  }
  return Math.ceil(measureText(label, STYLE.busLabelSize, '600')) + 40;
}

function buildElkGraph(model) {
  // Compute per-device layer assignments from the topology.
  const layerOf = computeLayers(model);
  // Determine the max layer index actually used so we can size correctly.
  const maxLayer = Math.max(...Object.values(layerOf), ROW.ground_bus);

  // Ground bus is laid out manually after ELK (see buildSvg): it has no edges,
  // so ELK can't anchor it, and it must span the main bus width regardless of
  // where the rest of the diagram lands. Bus separators are likewise placed
  // manually (computeSegmentation) — they have no edges and are bus ornaments,
  // not power-flow nodes, so they must be kept out of the ELK graph entirely.
  const layoutDevices = model.devices.filter(d => d.kind !== 'ground_bus' && d.kind !== 'bus_separator' && !d.isBusSection);

  // Segment-band ordering for feeders on a SKRU-segmented bus: left-side feeders
  // get a low band, right-side feeders a high band, so ELK's semi-interactive
  // crossing-minimization keeps the whole left group left of the whole right
  // group. Within a band, bus_position (or insertion order) sets local order.
  const RIGHT_BAND = 1000;
  const segCounters = {};   // `${busId}|${seg}` -> running index for feeders without bus_position
  const segOrderKey = {};
  layoutDevices.forEach(d => {
    if (!d.segment || !d.segmentBus) return;
    const ck = `${d.segmentBus}|${d.segment}`;
    const bp = d._raw && d._raw.bus_position;
    const local = (typeof bp === 'number') ? bp : (segCounters[ck] = (segCounters[ck] || 0) + 1);
    segOrderKey[d.id] = (d.segment === 'right' ? RIGHT_BAND : 0) + local;
  });

  const nodes = layoutDevices.map(d => {
    const geom = DEVICE_GEOMETRY[d.kind] || DEVICE_GEOMETRY.other;
    // Bus bars grow to fit their label if the default width is too narrow.
    // ELK then accounts for the new width when packing children.
    let width = geom.w;
    if (d.kind === 'main_bus' || d.kind === 'secondary_bus') {
      width = Math.max(width, busRequiredWidth(d));
    } else {
      // Non-bus devices: grow the ELK *layout* width to clear the label and
      // rating text rendered below the symbol. The symbol itself stays at its
      // native geometry size (centered inside) — see renderNode.
      const displayLabel = pickLang(d.label, d.label_zh);
      const displaySpecs = pickRatingItems(d);
      const labelW = measureText(displayLabel, STYLE.labelSize, '600');
      let ratingW = 0;
      if (displaySpecs.length) {
        const rating = displaySpecs.join(' · ');
        const ratingTrimmed = rating.length > 30 ? rating.substring(0, 28) + '…' : rating;
        ratingW = measureText(ratingTrimmed, STYLE.ratingSize);
      }
      const textW = Math.ceil(Math.max(labelW, ratingW)) + 12;
      width = Math.max(width, textW);
    }
    const layoutOptions = {
      // Pin each node to its computed layer. layerChoiceConstraint is the
      // ELK option that lets us say "this node MUST live on layer N".
      'elk.layered.layering.layerChoiceConstraint': String(layerOf[d.id]),
    };
    // If the JSON specified a bus_position, hint ELK with an x-coordinate so
    // semi-interactive crossing-minimization preserves left-to-right order
    // among siblings on the same layer. Devices without bus_position are left
    // free for ELK to place.
    const busPos = d._raw && d._raw.bus_position;
    if (segOrderKey[d.id] !== undefined) {
      // Feeder on a segmented bus: band-ordered (left group then right group).
      layoutOptions['elk.position'] = `(${segOrderKey[d.id] * 100},0)`;
    } else if (typeof busPos === 'number') {
      layoutOptions['elk.position'] = `(${busPos * 100},0)`;
    }
    return {
      id: d.id,
      width,
      height: geom.h,
      labels: [{ text: d.label, width: 100, height: 14 }],
      layoutOptions,
    };
  });

  // Only edges whose BOTH endpoints are still laid out reach ELK. This drops the
  // section breaker's drop (it's an inline bar ornament, not a power-flow node).
  const layoutIds = new Set(layoutDevices.map(d => d.id));
  const edges = model.edges
    .filter(e => layoutIds.has(e.source) && layoutIds.has(e.target))
    .map((e, i) => ({
      id: `e${i}`,
      sources: [e.source],
      targets: [e.target],
    }));

  return {
    id: 'root',
    layoutOptions: {
      'elk.algorithm': 'layered',
      'elk.direction': 'DOWN',
      // With explicit per-node layer assignment, the layering strategy must
      // be INTERACTIVE so ELK respects our layer choices instead of recomputing.
      'elk.layered.layering.strategy': 'INTERACTIVE',
      'elk.layered.spacing.nodeNodeBetweenLayers': String(STYLE.elkLayerSpacing),
      'elk.spacing.nodeNode': String(STYLE.elkNodeSpacing),
      'elk.layered.spacing.edgeNodeBetweenLayers': String(STYLE.elkEdgeNodeSpacing),
      'elk.layered.spacing.edgeEdgeBetweenLayers': String(STYLE.elkEdgeSpacing),
      'elk.layered.nodePlacement.strategy': 'NETWORK_SIMPLEX',
      'elk.layered.crossingMinimization.strategy': 'LAYER_SWEEP',
      // Semi-interactive mode tells LAYER_SWEEP to honor elk.position as a
      // pre-ordering hint for any node that has one, and only re-order nodes
      // that don't. This is how we pin bus children to their JSON-specified
      // bus_position while letting ELK arrange the rest freely.
      'elk.layered.crossingMinimization.semiInteractive': 'true',
      'elk.edgeRouting': 'ORTHOGONAL',
    },
    children: nodes,
    edges,
  };
}

