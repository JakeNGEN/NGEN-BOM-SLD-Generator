        { key: 'std_sync',   name: 'Gen Synchronization Panel',     ladder: 'std_sync',   defaultRating: 'Auto',       critToggle: true },
        { key: 'std_phase',  name: 'Phase Sequence Monitor',        ladder: 'std_phase',  defaultRating: '3-phase',    critToggle: true },
        { key: 'std_annun',  name: 'Switchgear Annunciator',        ladder: 'std_annun',  defaultRating: 'LED Panel',  critToggle: true },
        { key: 'std_bms',    name: 'BMS Interface',                 ladder: 'std_bms',    defaultRating: 'BACnet',     critToggle: true },
        { key: 'std_gndbus', name: 'Insulated Ground Bus',          ladder: 'std_gndbus', defaultRating: 'Insulated',  critToggle: true },
      ]},
    ]},
    { id: 'pdu', name: '5. PDU', items: [
      { key: 'pdu_in',  name: 'PDU Input Breaker',                ladder: 'pdu_in',  defaultRating: '1200A' },
      { key: 'pdu_out', name: 'PDU Output Breaker (w/ integral tx)', ladder: 'pdu_out', defaultRating: '750kVA' },
    ]},
  ];

  // Walk every section (handles flat groups OR groups with subgroups).
  function eachSection(cat, cb) {
    if (cat.subgroups) cat.subgroups.forEach(sg => sg.items.forEach(it => cb(it, sg)));
    else cat.items.forEach(it => cb(it, null));
  }
  const ITEM = {};
  CATALOG.forEach(cat => eachSection(cat, (it, sg) => {
    it.cat = cat.name; it.catId = cat.id;
    if (sg) { it.sub = sg.name; it.subId = sg.id; }
    ITEM[it.key] = it;
  }));

  const quote     = {};           // section key -> qty
  const groupQty  = {};           // group id   -> qty (default 1)
  const critical  = {};           // section key -> bool (Mech/Therm/GenAux/std)
  const ratings   = {};           // section key -> selected rating label
  const qty       = k => quote[k] || 0;
  const gQty      = gid => (groupQty[gid] != null ? groupQty[gid] : 1);
  const effQty    = k => qty(k) * gQty(ITEM[k] && ITEM[k].catId);
  const isCrit    = k => !!critical[k];
  // Look up the ladder for a section. Returns an array of {label, price}.
  const ladderFor = k => { const it = ITEM[k]; return it && it.ladder ? (RATING_LADDERS[it.ladder] || []) : []; };
  // Current selected rating for a section (falls back to the catalog default).
  const ratingOf  = k => ratings[k] || (ITEM[k] && ITEM[k].defaultRating) || '';
  // Unit price for the current rating selection.
  const unitPrice = k => {
    const ladder = ladderFor(k);
    if (!ladder.length) return 0;
    const r = ratingOf(k);
    const entry = ladder.find(e => e.label === r) || ladder[0];
    return entry ? entry.price : 0;
  };
  const fmtUSD    = n => '$' + Math.round(n).toLocaleString('en-US');
  let topologyMode = '1msb';      // '1msb' | 'perups'

  // ── DOM refs ──
  const catalogEl  = document.getElementById('catalog');
  const linesEl    = document.getElementById('qs-lines');
  const countEl    = document.getElementById('qs-count');
  const buildBtn   = document.getElementById('btn-build-diagram');
  const exportBtn  = document.getElementById('btn-export-pdf');
  const saveBtn    = document.getElementById('btn-save-bom');
  const clearBtn   = document.getElementById('btn-clear-quote');
  const navQuote   = document.getElementById('nav-quote');
  const navDiagram = document.getElementById('nav-diagram');
  const startBtn   = document.getElementById('btn-start');

  // ── Render catalog ──
  // Each Group header carries a group-qty stepper (multiplier in the quote only).
  // Groups with `subgroups` render section rows under labelled subgroup headers.
  function renderCatalog() {
    const sectionRow = it => {
      const ladder = (it.ladder && RATING_LADDERS[it.ladder]) || [];
      const sel = ratingOf(it.key);
      const ratingHtml = ladder.length > 1
        ? `<select class="rating-select" data-rating-key="${it.key}" aria-label="${it.name} rating">${ladder.map(e => `<option value="${e.label}"${e.label === sel ? ' selected' : ''}>${e.label}</option>`).join('')}</select>`
        : ladder.length === 1
          ? `<span class="rating-static">${ladder[0].label}</span>`
          : '';
      return `
      <div class="cat-item" data-key="${it.key}">
        <div class="ci-main">
          <div class="ci-name">${it.name}</div>
        </div>
        ${ratingHtml}
        ${it.critToggle ? `<button type="button" class="crit-toggle" data-crit-key="${it.key}" aria-pressed="false" title="Mark as critical / UPS-backed (right side of MSB break)">Critical</button>` : ''}
        <div class="stepper" data-stepper="section" data-key="${it.key}">
          <button type="button" data-act="dec" aria-label="Remove one">−</button>
          <input type="number" min="0" step="1" value="0" data-key="${it.key}" aria-label="${it.name} quantity">
          <button type="button" data-act="inc" aria-label="Add one">+</button>
        </div>
      </div>`;
    };
    const groupBody = cat => cat.subgroups
      ? cat.subgroups.map(sg => `
          <div class="cat-sub" data-sub="${sg.id}">
            <h4 class="cat-sub-h">${sg.name}</h4>
            ${sg.items.map(sectionRow).join('')}
          </div>`).join('')
      : cat.items.map(sectionRow).join('');

    catalogEl.innerHTML = CATALOG.map(cat => `
      <section class="cat-group" data-cat="${cat.id}">
        <h3>
          <span class="cat-title">${cat.name}</span>
          <span class="group-qty">
            <span class="gq-label">Group qty</span>
            <span class="stepper gq-stepper" data-stepper="group" data-gid="${cat.id}">
              <button type="button" data-act="dec" aria-label="Decrease group quantity">−</button>
              <input type="number" min="1" step="1" value="1" data-gid="${cat.id}" aria-label="${cat.name} group quantity">
              <button type="button" data-act="inc" aria-label="Increase group quantity">+</button>
            </span>
          </span>
        </h3>
        ${groupBody(cat)}
      </section>`).join('');
  }

  // ── Summary / totals ──
  // Quote rolls up *effective* qty = section qty × its group qty. Diagram
  // generation uses raw section qty, not group qty (group qty is quote-only).
  function updateQuote() {
    const groups = {};   // catId -> [{ it, sq, gq, eq, up }]
    let total = 0, effCount = 0, sectionsSelected = 0;
    CATALOG.forEach(cat => {
      const gq = gQty(cat.id);
      eachSection(cat, it => {
        const sq = qty(it.key);
        if (sq > 0) {
          const eq = sq * gq;
          const up = unitPrice(it.key);
          (groups[cat.id] = groups[cat.id] || { name: cat.name, lines: [] }).lines.push({ it, sq, gq, eq, up, r: ratingOf(it.key) });
          total += eq * up;
          effCount += eq;
          sectionsSelected += 1;
        }
      });
    });

    if (sectionsSelected === 0) {
      linesEl.innerHTML = '<div class="qs-empty">No sections added yet.<br>Add sections on the left to start your BOM.</div>';
    } else {
      linesEl.innerHTML = Object.keys(groups).map(catId => `
        <div class="qs-cat-label">${groups[catId].name}${gQty(catId) > 1 ? ` <span class="qs-gqty">× ${gQty(catId)}</span>` : ''}</div>
        ${groups[catId].lines.map(({ it, sq, gq, eq, r }) => `
          <div class="qs-line">
            <span class="qsl-name"><span class="qsl-qty">${eq}×</span>${it.name}${r ? ` <span class="qsl-rating">[${r}]</span>` : ''}${gq > 1 ? `<span class="qsl-mult"> (${sq} × ${gq})</span>` : ''}</span>
          </div>`).join('')}`).join('');
    }

    countEl.textContent = effCount + (effCount === 1 ? ' item' : ' items');
    buildBtn.disabled = sectionsSelected === 0;
    if (exportBtn) exportBtn.disabled = sectionsSelected === 0;
    if (saveBtn)   saveBtn.disabled   = sectionsSelected === 0;

    // Reflect section qty + critical toggle + price/rating on catalog rows
    CATALOG.forEach(cat => eachSection(cat, it => {
      const q = qty(it.key);
      const row = catalogEl.querySelector(`.cat-item[data-key="${it.key}"]`);
      if (row) {
        row.classList.toggle('has-qty', q > 0);
        row.classList.toggle('is-critical', isCrit(it.key));
      }
      const inp = catalogEl.querySelector(`input[data-key="${it.key}"]`);
      if (inp && inp.value !== String(q)) inp.value = q;
      const dec = catalogEl.querySelector(`[data-stepper="section"][data-key="${it.key}"] button[data-act="dec"]`);
      if (dec) dec.disabled = q === 0;
      const ctBtn = catalogEl.querySelector(`.crit-toggle[data-crit-key="${it.key}"]`);
      if (ctBtn) {
        ctBtn.classList.toggle('is-critical', isCrit(it.key));
        ctBtn.setAttribute('aria-pressed', isCrit(it.key) ? 'true' : 'false');
      }
      // Keep the rating select's value in sync (when state changes via JSON import).
      const ratingSel = catalogEl.querySelector(`.rating-select[data-rating-key="${it.key}"]`);
      if (ratingSel && ratingSel.value !== ratingOf(it.key)) ratingSel.value = ratingOf(it.key);
    }));
    // Reflect group qty on group steppers
    CATALOG.forEach(cat => {
      const g = gQty(cat.id);
      const ginp = catalogEl.querySelector(`input[data-gid="${cat.id}"]`);
      if (ginp && ginp.value !== String(g)) ginp.value = g;
      const gdec = catalogEl.querySelector(`[data-stepper="group"][data-gid="${cat.id}"] button[data-act="dec"]`);
      if (gdec) gdec.disabled = g <= 1;
    });
  }

  function setQty(key, val) {
    const v = Math.max(0, Math.floor(Number(val) || 0));
    if (v === 0) delete quote[key]; else quote[key] = v;
    updateQuote();
  }
  function setGroupQty(gid, val) {
    const v = Math.max(1, Math.floor(Number(val) || 1));
    groupQty[gid] = v;
    updateQuote();
  }

  function toggleCritical(key) {
    if (critical[key]) delete critical[key]; else critical[key] = true;
    updateQuote();
  }

  // ── Catalog interactions (event delegation) ──
  catalogEl.addEventListener('click', e => {
    const critBtn = e.target.closest('.crit-toggle');
    if (critBtn) { toggleCritical(critBtn.dataset.critKey); return; }
    const btn = e.target.closest('button[data-act]');
    if (!btn) return;
    const stepper = btn.parentElement;
    const delta = btn.dataset.act === 'inc' ? 1 : -1;
    if (stepper.dataset.stepper === 'group') {
      const gid = stepper.dataset.gid;
      setGroupQty(gid, gQty(gid) + delta);
    } else {
      const key = stepper.dataset.key;
      setQty(key, qty(key) + delta);
    }
  });
  catalogEl.addEventListener('change', e => {
    const sel = e.target.closest('.rating-select');
    if (sel) {
      const key = sel.dataset.ratingKey;
      ratings[key] = sel.value;
      updateQuote();
    }
  });
  catalogEl.addEventListener('input', e => {
    const ginp = e.target.closest('input[data-gid]');
    if (ginp) { setGroupQty(ginp.dataset.gid, ginp.value); return; }
    const inp = e.target.closest('input[data-key]');
    if (inp) setQty(inp.dataset.key, inp.value);
  });

  clearBtn.addEventListener('click', () => {
    if (Object.keys(quote).length && !confirm('Clear all sections from the quote?')) return;
    Object.keys(quote).forEach(k => delete quote[k]);
    Object.keys(groupQty).forEach(k => delete groupQty[k]);
    Object.keys(critical).forEach(k => delete critical[k]);
    Object.keys(ratings).forEach(k => delete ratings[k]);
    updateQuote();
  });

  // Topology mode selector
  const topoModeEl = document.getElementById('topo-mode');
  if (topoModeEl) {
    topoModeEl.value = topologyMode;
    topoModeEl.addEventListener('change', () => { topologyMode = topoModeEl.value; });
  }

  // ── Screen switching ──
  function showScreen(name) {
    document.getElementById('screen-quote').hidden   = name !== 'quote';
    document.getElementById('screen-diagram').hidden = name !== 'diagram';
    document.body.dataset.screen = name;
    navQuote.classList.toggle('active', name === 'quote');
    navDiagram.classList.toggle('active', name === 'diagram');
  }
  navQuote.addEventListener('click', () => showScreen('quote'));
  navDiagram.addEventListener('click', () => { if (!navDiagram.disabled) showScreen('diagram'); });

  // ═══════════════════════════════════════════════════════════════════════
  //  QUOTE → SLD TOPOLOGY
  //  Emit a devices[] graph (connections via downstream_children only) and let
  //  the renderer's normalize()/computeLayers() classify breakers & lay it out.
  // ═══════════════════════════════════════════════════════════════════════
  function buildSldFromQuote() {
    const devices = [], byId = {};
    const add = d => { d.downstream_children = d.downstream_children || []; devices.push(d); byId[d.id] = d; return d.id; };
    const link = (p, c) => { if (byId[p] && c && !byId[p].downstream_children.includes(c)) byId[p].downstream_children.push(c); };
    // "Typical of N" goes FIRST in rating_items so the renderer's 30-char trim
    // doesn't eat it. Returns a new array with the typ chip prepended when n>1.
    const typOf = (n, prefix) => n > 1 ? `${prefix || ''}Typical of ${n}` : null;
    const withTyp = (ratings, typ) => typ ? [typ, ...ratings] : ratings;

    // ── Raw section quantities (diagram ignores group qty) ──
    const nHvMain = qty('hv_main'), nHvBkp = qty('hv_bkp');
    const nHvTx = qty('hv_tx');
    const nHvDisc = qty('hv_disc'), nHvSpd = qty('hv_spd'), nHvMtr = qty('hv_mtr');
    const nMvMain = qty('mv_main'), nMvBkp = qty('mv_backup');
    const nTxDc = qty('tx_dc'), nTxAux = qty('tx_aux');
    const nBypass = qty('lv_ups_bypass');
    const nUps = qty('lv_ups_io');
    const nMech = qty('lv_mech'), nAux = qty('lv_aux');
    const nChiller = qty('lv_chiller'), nCrah = qty('lv_crah');
    const nGenMain = qty('lv_gen_main'), nGenAux = qty('lv_gen_aux');
    const nUtilMain = qty('lv_util_main'), nAts = qty('lv_ats'), nMsbMain = qty('lv_msb_main');
    const nPduIn = qty('pdu_in'), nPduOut = qty('pdu_out');
    const nPdu = Math.max(nPduIn, nPduOut);

    const hasHV  = nHvMain + nHvBkp + nHvTx + nHvDisc + nHvSpd + nHvMtr > 0;
    const hasMV  = nMvMain + nMvBkp > 0;
    const hasTX  = nTxDc + nTxAux > 0;
    const hasLV  = nUps > 0 || nBypass > 0 || nMech > 0 || nAux > 0 || nChiller > 0 || nCrah > 0 || nGenMain > 0 || nGenAux > 0 || nUtilMain > 0 || nAts > 0 || nMsbMain > 0 || nPdu > 0;
    const hasGen = nGenMain > 0 || nAts > 0 || nGenAux > 0;
    if (!(hasLV || hasMV || hasTX || hasHV)) return null;

    // ── Sources ──
    const UTIL = add({ id: 'UTILITY', device_type: 'Utility Transformer', label: 'Utility Supply', rating_items: ['34.5kV', 'Incoming'] });
    let GEN = null;
    if (hasGen) GEN = add({ id: 'GEN-SRC', device_type: 'Diesel Generator', label: 'Standby Generator', rating_items: ['Standby'], notes: 'standby' });

    // ── HV equipment (upstream of MV) ──
    // Chain:  UTILITY → [HV Disconnect] → HV Switchgear → [HV Step-Down Tx]
    //         → MV Switchgear → ...
    // HV Surge Arrester + HV Meter hang off the HV Switchgear bus.
    let hvDisc = null, hvMain = null, hvBkp = null, hvTx = null;
    let utilDownstream = UTIL;
    if (nHvDisc > 0) {
      hvDisc = add({ id: 'HV-DISC', device_type: 'Air Circuit Breaker', label: 'HV Disconnect', rating_items: withTyp(['HV'], typOf(nHvDisc)) });
      link(UTIL, hvDisc);
      utilDownstream = hvDisc;
    }
    if (nHvMain > 0) {
      hvMain = add({ id: 'HVSWB-M', device_type: 'MV Switchgear', label: 'HV Switchgear (Main)', rating_items: withTyp(['HV'], typOf(nHvMain)) });
      link(utilDownstream, hvMain);
    }
    if (nHvBkp > 0) {
      hvBkp = add({ id: 'HVSWB-B', device_type: 'MV Switchgear', label: 'HV Switchgear (Backup)', rating_items: withTyp(['HV'], typOf(nHvBkp)) });
      link(utilDownstream, hvBkp);
    }
    const hvBus = hvMain || hvBkp;
    if (hvBus && nHvMtr > 0) {
      const id = add({ id: 'HV-MTR', device_type: 'Other', label: 'HV Meter', rating_items: withTyp([], typOf(nHvMtr)) });
      link(hvBus, id);
    }
    if (hvBus && nHvSpd > 0) {
      const id = add({ id: 'HV-SPD', device_type: 'Other', label: 'HV Surge', rating_items: withTyp([], typOf(nHvSpd)) });
      link(hvBus, id);
    }
    if (nHvTx > 0) {
      hvTx = add({ id: 'HV-TX', device_type: 'Utility Transformer', label: 'HV → MV Step-Down', rating_items: withTyp(['HV/MV'], typOf(nHvTx)) });
      link(hvBus || UTIL, hvTx);
    }
    // Whatever sits at the bottom of the HV stack feeds the MV bus(es).
    const mvFeedSource = hvTx || hvBus || UTIL;

    // ── MV switchgear: one instance per kind, "Typical of N" if qty>1.
    //    The user's selected rating from the dropdown is surfaced on the bus
    //    label so the SLD shows the actual chosen rating. ──
    let mvMainBus = null, mvBkpBus = null;
    if (nMvMain > 0) { mvMainBus = add({ id: 'MVSWB-M', device_type: 'MV Switchgear', label: 'MV Switchgear (Main)', rating_items: withTyp(['34.5kV', ratingOf('mv_main'), 'Floor-mounted'], typOf(nMvMain)) }); link(mvFeedSource, mvMainBus); }
    if (nMvBkp  > 0) { mvBkpBus  = add({ id: 'MVSWB-B', device_type: 'MV Switchgear', label: 'MV Switchgear (Backup)', rating_items: withTyp(['34.5kV', ratingOf('mv_backup'), 'Outdoor'], typOf(nMvBkp)) }); link(mvFeedSource, mvBkpBus); }
    const mvBus = mvMainBus || mvBkpBus;

    // ── Transformers: one per kind, "Typical of N" if qty>1 ──
    let txDc = null, txAux = null;
    if (nTxDc  > 0) { txDc  = add({ id: 'TX-DC',  device_type: 'Utility Transformer', label: 'Data Centre Tx',  rating_items: withTyp([ratingOf('tx_dc'), '34.5kV/LV'], typOf(nTxDc)) }); link(mvBus || mvFeedSource, txDc); }
    if (nTxAux > 0) { txAux = add({ id: 'TX-AUX', device_type: 'Utility Transformer', label: 'Auxiliary Tx',    rating_items: withTyp([ratingOf('tx_aux'), '34.5kV/LV'], typOf(nTxAux)) }); link(mvBus || mvFeedSource, txAux); }
    const utilFeed = txDc || txAux || mvBus || mvFeedSource;

    if (!hasLV) return wrap(devices);

    // ── LV MAIN BUS ──
    const MSB = add({ id: 'MAIN-BUS', device_type: 'LV Switchgear Lineup', label: 'Main LV Switchboard', rating_items: ['5000A', '480V', '3Ø'] });

    // Incomer chain:  utility[+util main]  ┐
    //                                       [ATS] → [MSB main] → MAIN-BUS
    //                 generator[+gen main]  ┘
    let utilSide = utilFeed;
    if (nUtilMain > 0) { const id = add({ id: 'CB-UTIL-MAIN', device_type: 'Air Circuit Breaker', label: 'Utility Main', rating_items: withTyp([ratingOf('lv_util_main')], typOf(nUtilMain)) }); link(utilFeed, id); utilSide = id; }
    let genSide = GEN;
    if (GEN && nGenMain > 0) { const id = add({ id: 'CB-GEN-MAIN', device_type: 'Air Circuit Breaker', label: 'Generator Main', rating_items: withTyp([ratingOf('lv_gen_main')], typOf(nGenMain)), notes: 'standby' }); link(GEN, id); genSide = id; }

    let transfer;
    if (nAts > 0) {
      transfer = add({ id: 'ATS-001', device_type: 'Automatic Transfer Switch', label: 'Integrated ATS', rating_items: withTyp([ratingOf('lv_ats'), 'open-transition'], typOf(nAts)) });
      link(utilSide, transfer);
      if (genSide) link(genSide, transfer);
    } else { transfer = utilSide; }

    let msbFeed = transfer;
    if (nMsbMain > 0) { const id = add({ id: 'CB-MSB-MAIN', device_type: 'Air Circuit Breaker', label: 'MSB Main', rating_items: withTyp([ratingOf('lv_msb_main')], typOf(nMsbMain)) }); link(transfer, id); msbFeed = id; }
    link(msbFeed, MSB);
    if (genSide && nAts === 0) link(genSide, MSB);

    // ── Bus segmentation requires UPS Input/Output qty≥1 AND UPS Maintenance
    //    Bypass qty≥1. (Otherwise the main bus is just a plain bar.)
    const segmented = nUps > 0 && nBypass > 0;
    const leftSeg = segmented ? 'left' : undefined;

    // ── Non-UPS feeders. One drawn per section type; "Typical of N" annotates
    //    the breaker when section qty > 1. When the bus is segmented AND the
    //    section's Critical toggle is on, the feeder is placed on the RIGHT
    //    segment (UPS-backed side) instead of the left. Critical feeders sit
    //    further right than the couplers (posCrit > posR). When the bus is NOT
    //    segmented (no UPS or no Bypass) the toggle is a no-op. ──
    let posL = 10;
    let posCrit = 70;
    function addFeeder(tag, label, n, key) {
      if (n <= 0) return;
      const wantsRight = segmented && isCrit(key);
      const segment = segmented ? (wantsRight ? 'right' : 'left') : undefined;
      const position = wantsRight ? posCrit++ : posL++;
      const r = ratingOf(key);
      const cb = add({ id: `CB-${tag}`, device_type: 'Air Circuit Breaker', label: `${label} Feeder`, rating_items: withTyp([r, 'Feeder'], typOf(n)), bus_segment: segment, bus_position: position });
      link(MSB, cb);
      // Loads downstream of mech / thermal / aux / gen-aux feeders are
      // Furnished by Other (chiller plant, mech equipment, CRAH, etc.) so we
      // tag them F.B.O — the renderer surfaces the chip below the graphic and
      // adds an F.B.O entry in the type legend.
      const load = add({ id: `LOAD-${tag}`, device_type: 'Other', label, rating_items: ['F.B.O'] });
      link(cb, load);
    }
    addFeeder('CHLR', 'Chiller Plant', nChiller, 'lv_chiller');
    addFeeder('MECH', 'Mechanical',    nMech,    'lv_mech');
    addFeeder('CRAH', 'CRAH Units',    nCrah,    'lv_crah');
    addFeeder('AUX',  'Auxiliary',     nAux,     'lv_aux');
    addFeeder('GAUX', 'Gen Auxiliary', nGenAux,  'lv_gen_aux');

    // ── Typical Inclusions — now drawn as proper feeders (small breaker →
    //    labelled device). They honor the Critical toggle (right segment when
    //    the bus is segmented) and carry the user's rating selection. ──
    function addStdFeeder(idSuffix, deviceLabel, key) {
      const n = qty(key);
      if (n <= 0) return;
      const wantsRight = segmented && isCrit(key);
      const segment = segmented ? (wantsRight ? 'right' : 'left') : undefined;
      const position = wantsRight ? posCrit++ : posL++;
      const r = ratingOf(key); // e.g. 'Type 2', '480/120V', etc.
      const cb = add({
        id: 'CB-STD-' + idSuffix,
        device_type: 'Air Circuit Breaker',
        label: `${deviceLabel} Feeder`,
        rating_items: withTyp(['Feeder'], typOf(n)),
        bus_segment: segment,
        bus_position: position,
      });
      link(MSB, cb);
      const load = add({
        id: 'STD-' + idSuffix,
        device_type: 'Other',
        label: deviceLabel,
        rating_items: r ? [r] : [],
      });
      link(cb, load);
    }
    addStdFeeder('SPD',    'SPD',           'std_spd');
    addStdFeeder('CPT',    'CPT',           'std_cpt');
    addStdFeeder('MTR',    'Revenue Mtr',   'std_meter');
    addStdFeeder('SYNC',   'Gen Sync',      'std_sync');
    addStdFeeder('PHASE',  'Phase Mon',     'std_phase');
    addStdFeeder('ANN',    'Annunciator',   'std_annun');
    addStdFeeder('BMS',    'BMS Interface', 'std_bms');
    addStdFeeder('GNDBUS', 'Ground Bus',    'std_gndbus');

    // ── UPS display rules ──
    //  · "1 MSB" mode:    up to 4 UPS drawn (A/B/C/D). If nUps>4, draw 1 + typical-of.
    //                     All drawn UPSs feed a single shared UPS-BUS; ONE coupler.
    //  · "MSB per UPS":   override — always draw 1 UPS, with typical-of when nUps>1.
    //                     One UPS bus, one coupler.
    let drawnUps, upsTypNote = null;
    if (nUps === 0) drawnUps = 0;
    else if (topologyMode === 'perups') { drawnUps = 1; upsTypNote = nUps > 1 ? `Typical of ${nUps}` : null; }
    else if (nUps > 4) { drawnUps = 1; upsTypNote = `Typical of ${nUps}`; }
    else { drawnUps = nUps; }
    const upsLetters = ['A', 'B', 'C', 'D'].slice(0, drawnUps);

    // ── UPS input feeders + UPS + UPS bus(es) ──
    let posUin = 30;
    const upsBuses = [];   // { busId, letter }
    if (drawnUps > 0) {
      if (topologyMode === '1msb') {
        const sharedBus = add({ id: 'UPS-BUS', device_type: 'LV Switchgear Lineup', label: 'UPS BUS', rating_items: ['3000A', '480V', '3Ø'] });
        upsLetters.forEach(letter => {
          const cbIn = add({ id: `FDR-UPS-${letter}-IN`, device_type: 'Air Circuit Breaker', label: `FDR-UPS-${letter}-IN`, rating_items: withTyp([ratingOf('lv_ups_io'), 'UPS input'], upsTypNote), bus_segment: leftSeg, bus_position: posUin++ });
          link(MSB, cbIn);
          const ups = add({ id: `UPS-${letter}`, device_type: 'Static UPS', label: `UPS-${letter}`, rating_items: withTyp(['Double-conversion'], upsTypNote) });
          link(cbIn, ups);
          const cbOut = add({ id: `UPS-${letter}-OUT`, device_type: 'Air Circuit Breaker', label: `UPS-${letter}-OUT`, rating_items: [ratingOf('lv_ups_io'), 'UPS output'] });
          link(ups, cbOut);
          link(cbOut, sharedBus);
        });
        upsBuses.push({ busId: sharedBus, letter: '' });
      } else {
        // MSB-per-UPS mode: always exactly one UPS drawn (with typical-of note).
        upsLetters.forEach(letter => {
          const cbIn = add({ id: `FDR-UPS-${letter}-IN`, device_type: 'Air Circuit Breaker', label: `FDR-UPS-${letter}-IN`, rating_items: withTyp([ratingOf('lv_ups_io'), 'UPS input'], upsTypNote), bus_segment: leftSeg, bus_position: posUin++ });
          link(MSB, cbIn);
          const ups = add({ id: `UPS-${letter}`, device_type: 'Static UPS', label: `UPS-${letter}`, rating_items: withTyp(['Double-conversion'], upsTypNote) });
          link(cbIn, ups);
          const cbOut = add({ id: `UPS-${letter}-OUT`, device_type: 'Air Circuit Breaker', label: `UPS-${letter}-OUT`, rating_items: [ratingOf('lv_ups_io'), 'UPS output'] });
          link(ups, cbOut);
          const busId = add({ id: `UPS-BUS-${letter}`, device_type: 'LV Switchgear Lineup', label: 'UPS BUS', rating_items: withTyp(['3000A', '480V', '3Ø'], upsTypNote) });
          link(cbOut, busId);
          upsBuses.push({ busId, letter });
        });
      }
    }

    // ── MSB break + right-segment couplers + SKRU interlocks (only when segmented) ──
    const interlocks = [];
    if (segmented && upsBuses.length > 0) {
      add({ id: 'MBP-B', device_type: 'Bypass Switch', label: 'MBP-B — N/O', rating_items: withTyp([ratingOf('lv_ups_bypass'), 'SKRU', 'N/O'], typOf(nBypass)), segments_bus: 'MAIN-BUS', bus_position: 50, notes: 'standby' });
      link(MSB, 'MBP-B');
      let posR = 60;
      upsBuses.forEach(({ busId, letter }, idx) => {
        const coupId = upsBuses.length > 1 ? `MBP-A-${letter}` : 'MBP-A';
        const coupLabel = upsBuses.length > 1 ? `MBP-A (${letter}) — N/O` : 'MBP-A — N/O';
        add({ id: coupId, device_type: 'Bypass Switch', label: coupLabel, rating_items: ['3000A', 'SKRU', 'N/O'], bus_segment: 'right', bus_position: posR++, notes: 'standby' });
        link(MSB, coupId);
        link(coupId, busId);
        const sk = `SKRU-${String(idx + 1).padStart(2, '0')}`;
        interlocks.push({ id: sk, label: sk, members: ['MBP-B', coupId] });
      });
    }

    // ── PDU — always one drawn on the RIGHT segment of MAIN-BUS (UPS-backed
    //    side). Never hangs off the UPS bus. "Typical of N" annotates when
    //    multiple are quoted. The input breaker carries the right-segment
    //    placement; if it's omitted, the PDU itself becomes the right-segment
    //    child of MAIN-BUS. ──
    if (nPdu > 0) {
      const pduTypNote = nPdu > 1 ? `Typical of ${nPdu}` : null;
      const onRight = segmented;
      let pduParent;
      if (nPduIn > 0) {
        const cbIn = add({ id: 'CB-PDU-IN', device_type: 'Air Circuit Breaker', label: 'PDU Input', rating_items: withTyp([ratingOf('pdu_in')], pduTypNote), bus_segment: onRight ? 'right' : undefined, bus_position: onRight ? posCrit++ : posL++ });
        link(MSB, cbIn);
        pduParent = cbIn;
      } else {
        // No input breaker quoted — anchor the PDU itself to MAIN-BUS so the
        // right-segment classification still applies.
        pduParent = null; // set after we add the PDU below
      }
      const pdu = add({ id: 'PDU', device_type: 'Step-Down Transformer / PDU', label: 'PDU', rating_items: withTyp([ratingOf('pdu_out')], pduTypNote), bus_segment: (pduParent ? undefined : (onRight ? 'right' : undefined)), bus_position: (pduParent ? undefined : (onRight ? posCrit++ : posL++)) });
      link(pduParent || MSB, pdu);
      let rppParent = pdu;
      if (nPduOut > 0) {
        const cbOut = add({ id: 'CB-PDU-OUT', device_type: 'Air Circuit Breaker', label: 'PDU Output', rating_items: ['Output'] });
        link(pdu, cbOut);
        rppParent = cbOut;
      }
      const rpp = add({ id: 'RPP', device_type: 'Remote Power Panel', label: 'IT Load', rating_items: ['F.B.O'] });
      link(rppParent, rpp);
    }

    return wrap(devices, interlocks);
  }

  function wrap(devices, interlocks) {
    let total = 0, count = 0;
    CATALOG.forEach(cat => eachSection(cat, it => {
      const eq = effQty(it.key);
      if (eq > 0) { total += eq * unitPrice(it.key); count += eq; }
    }));
    const project = (document.getElementById('q-project').value || '').trim();
    const client  = (document.getElementById('q-client').value || '').trim();
    const today   = new Date().toISOString().slice(0, 10);
    const summary = `Auto-generated from quote — ${count} section${count !== 1 ? 's' : ''}, ${fmtUSD(total)}${client ? ' · ' + client : ''}`;
    return {
      drawing_tag: 'SLD',
      system_summary: summary,
      project_meta: {
        project_name: project || 'Untitled Quote',
        drawing_no: 'NGEN-QB-001',
        revision: 'A',
        date: today,
        drawn_by: 'NGEN BOM Builder',
        classification: 'Confidential',
      },
      devices,
      interlocks: interlocks || [],
    };
  }

  // ── Build Diagram ──
  buildBtn.addEventListener('click', async () => {
    const json = buildSldFromQuote();
    if (!json) return;
    navDiagram.disabled = false;
    showScreen('diagram');
    // The screen un-hides synchronously, so the container has layout dimensions
    // by the time ELK's async layout resolves (don't use rAF — it's throttled
    // when the page is backgrounded).
    renderDiagram(json);
  });

  // ── PDF Export (quote on p.1 + SLD on p.2, opens browser print dialog) ──
  function escapeHtml(s) {
    return String(s == null ? '' : s)
      .replace(/&/g, '&amp;').replace(/</g, '&lt;')
      .replace(/>/g, '&gt;').replace(/"/g, '&quot;');
  }
  function buildQuoteTableRows() {
    let count = 0;
    let html = '';
    CATALOG.forEach(cat => {
      const gq = gQty(cat.id);
      let groupHasAny = false;
      eachSection(cat, it => { if (qty(it.key) > 0) groupHasAny = true; });
      if (!groupHasAny) return;
      html += `<tr class="group"><td colspan="3">${escapeHtml(cat.name)}${gq > 1 ? ` <span class="mult">× ${gq}</span>` : ''}</td></tr>`;
      const renderItem = it => {
        const sq = qty(it.key); if (sq === 0) return;
        const eq = sq * gq;
        count += eq;
        const r = ratingOf(it.key);
        const isCritical = isCrit(it.key);
        const nameCell = `${escapeHtml(it.name)}${isCritical ? ` <span class="crit-pill">CRITICAL</span>` : ''}`;
        const ratingCell = r ? escapeHtml(r) : '';
        const qtyDisplay = gq > 1 ? `${eq} <span class="mult">(${sq} × ${gq})</span>` : `${sq}`;
        html += `<tr><td>${nameCell}</td><td>${ratingCell}</td><td class="num">${qtyDisplay}</td></tr>`;
      };
      if (cat.subgroups) {
        cat.subgroups.forEach(sg => {
          if (!sg.items.some(it => qty(it.key) > 0)) return;
          html += `<tr class="sub"><td colspan="3">${escapeHtml(sg.name)}</td></tr>`;
          sg.items.forEach(renderItem);
        });
      } else {
        cat.items.forEach(renderItem);
      }
    });
    return { html, count };
  }
  exportBtn.addEventListener('click', () => {
    const { html: tableRows } = buildQuoteTableRows();
    if (!tableRows) { alert('Add sections to the BOM first.'); return; }
    const svgEl = document.querySelector('#svg-container svg');
    let svgStr = '', sldOrientation = 'landscape';
    if (svgEl) {
      const cloned = svgEl.cloneNode(true);
      // Ensure a viewBox is set (the renderer normally sets one already).
      if (!cloned.getAttribute('viewBox')) {
        const w = cloned.getAttribute('width') || svgEl.viewBox.baseVal.width || svgEl.getBoundingClientRect().width;
        const h = cloned.getAttribute('height') || svgEl.viewBox.baseVal.height || svgEl.getBoundingClientRect().height;
        if (w && h) cloned.setAttribute('viewBox', `0 0 ${w} ${h}`);
      }
      // Pin the SVG element's intrinsic size to its viewBox so the CSS scale-
      // to-fit ("max-width/max-height: 100% with width/height: auto") preserves
      // aspect ratio. Without this the SVG would fill 100% × 100% of the page
      // frame and squish if the frame's aspect ratio doesn't match.
      const vb = cloned.viewBox && cloned.viewBox.baseVal;
      if (vb && vb.width && vb.height) {
        cloned.setAttribute('width', vb.width);
        cloned.setAttribute('height', vb.height);
        // Pick the SLD page orientation based on the diagram's own aspect
        // ratio, so a tall diagram gets a portrait page and a wide one gets
        // landscape — that way the diagram fills the page instead of being
        // letterboxed into a sliver.
        sldOrientation = vb.width >= vb.height ? 'landscape' : 'portrait';
      } else {
        cloned.removeAttribute('width');
        cloned.removeAttribute('height');
      }
      cloned.setAttribute('preserveAspectRatio', 'xMidYMid meet');
      svgStr = new XMLSerializer().serializeToString(cloned);
    }
    const projectName = (document.getElementById('q-project').value || '').trim() || 'Untitled Quote';
    const clientName  = (document.getElementById('q-client').value || '').trim();
    const today = new Date().toISOString().slice(0, 10);
    const logoSrc = (document.querySelector('.brand-logo') || {}).src || '';

    const styles = `
      @page { size: letter; margin: 0.5in; }
      @page sld { size: letter ${sldOrientation}; margin: 0.35in; }
      body { font-family: 'Poppins', 'Helvetica Neue', Arial, sans-serif; margin: 0; color: #1f2937; -webkit-print-color-adjust: exact; print-color-adjust: exact; }
      .quote-page { padding: 0; }
      .sld-page { page: sld; page-break-before: always; height: 100vh; display: flex; flex-direction: column; }
      .sld-frame {
        flex: 1 1 auto;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        min-height: 0;
      }
      /* Intrinsic SVG size (width/height = viewBox) + max-width/max-height
         caps to the frame. With width:auto height:auto the SVG scales DOWN
         uniformly to fit, preserving its aspect ratio. */
      .sld-frame svg {
        max-width: 100%;
        max-height: 100%;
        width: auto;
        height: auto;
        display: block;
      }
      header.qhead { display: flex; align-items: center; justify-content: space-between; border-bottom: 3px solid #1E6356; padding-bottom: 14px; margin-bottom: 22px; }
      header.qhead h1 { margin: 0; font-size: 30px; font-weight: 700; color: #1E6356; letter-spacing: 0.5px; }
      header.qhead .meta { margin-top: 6px; font-size: 13px; color: #6b7280; }
      header.qhead .meta strong { color: #1f2937; font-weight: 600; }
      header.qhead .logo img { height: 56px; padding: 6px 14px; background: #faf8f2; border-radius: 6px; }
      table.quote { width: 100%; border-collapse: collapse; font-size: 11px; }
      table.quote thead th { background: #1E6356; color: #fff; padding: 8px 10px; text-align: left; font-weight: 700; letter-spacing: 0.3px; font-size: 10px; text-transform: uppercase; }
      table.quote thead th.num { text-align: right; }
      table.quote td { padding: 7px 10px; border-bottom: 1px solid #f1f1ef; vertical-align: top; }
      table.quote td.num { text-align: right; font-variant-numeric: tabular-nums; white-space: nowrap; }
      table.quote tr.group td { background: #f0f5f3; color: #1E6356; font-weight: 700; padding: 9px 10px; font-size: 12px; }
      table.quote tr.group .mult { color: #CA942B; }
      table.quote tr.sub td { background: #fafaf7; color: #6B9E86; font-weight: 700; padding: 5px 14px; font-size: 10px; text-transform: uppercase; letter-spacing: 0.4px; }
      table.quote .mult { color: #9ca3af; font-size: 10px; }
      table.quote .rating-pill { display: inline-block; margin-left: 4px; padding: 1px 6px; border-radius: 999px; font-size: 9.5px; font-weight: 700; color: #1d4ed8; background: #dbeafe; }
      table.quote .crit-pill { display: inline-block; margin-left: 4px; padding: 1px 6px; border-radius: 999px; font-size: 9px; font-weight: 700; color: #dc2626; background: #fee2e2; letter-spacing: 0.4px; }
      table.quote tfoot th { background: #fff; color: #1f2937; border-top: 2.5px solid #1E6356; padding: 12px 10px; font-size: 13px; }
      table.quote tfoot th.total-label { text-align: right; text-transform: uppercase; letter-spacing: 0.5px; font-weight: 600; }
      table.quote tfoot th.total { font-size: 20px; color: #1E6356; text-align: right; font-variant-numeric: tabular-nums; }
      footer.qfoot { margin-top: 22px; padding-top: 12px; border-top: 1px solid #e5e7eb; font-size: 10px; color: #9ca3af; display: flex; justify-content: space-between; }
      .sldhead { display: flex; justify-content: space-between; align-items: baseline; padding-bottom: 6px; border-bottom: 1px solid #e5e7eb; margin-bottom: 4px; font-size: 10px; color: #6b7280; }
      .sldhead .title { font-weight: 700; font-size: 13px; color: #1E6356; }
    `;
    const quoteHtml = `
      <div class="quote-page">
        <header class="qhead">
          <div>
            <h1>BILL OF MATERIALS</h1>
            <div class="meta"><strong>${escapeHtml(projectName)}</strong>${clientName ? ' &middot; ' + escapeHtml(clientName) : ''}</div>
            <div class="meta">${today}</div>
          </div>
          ${logoSrc ? `<div class="logo"><img src="${logoSrc}" alt="NGEN"/></div>` : ''}
        </header>
        <table class="quote">
          <thead><tr><th>Item</th><th>Rating</th><th class="num">Qty</th></tr></thead>
          <tbody>${tableRows}</tbody>
        </table>
        <footer class="qfoot">
          <span>NGEN Mission Critical &mdash; Confidential</span>
          <span>Page 1 of ${svgStr ? 2 : 1}</span>
        </footer>
      </div>`;
    const sldHtml = svgStr ? `
      <div class="sld-page">
        <div class="sldhead">
          <span class="title">Single-Line Diagram &mdash; ${escapeHtml(projectName)}</span>
          <span>Page 2 of 2 &middot; ${today}</span>
        </div>
        <div class="sld-frame">${svgStr}</div>
      </div>` : '';
    const html = `<!DOCTYPE html><html><head><meta charset="UTF-8"><title>BOM — ${escapeHtml(projectName)}</title><link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet"><style>${styles}</style></head><body>${quoteHtml}${sldHtml}<script>window.onload = () => setTimeout(() => window.print(), 350);<\/script></body></html>`;
    const w = window.open('', '_blank');
    if (!w) { alert('Pop-up blocked — allow pop-ups for this page to export the PDF.'); return; }
    w.document.open(); w.document.write(html); w.document.close();
  });

  // ── JSON template + import ──
  // The template lists every section key with its default values so users can
  // edit it externally and re-import. Importing replaces the current quote
  // state (qty / rating / critical) and re-renders.
  function generateTemplateJson() {
    const sections = {};
    CATALOG.forEach(cat => eachSection(cat, it => {
      const entry = { qty: 0, rating: it.defaultRating || '' };
      if (it.critToggle) entry.critical = false;
      sections[it.key] = entry;
    }));
    return {
      _doc: 'NGEN BOM Builder import template. Set qty>0 to include a section; choose any rating from the equipment ladder; flag critical:true on mech/thermal/aux/gen-aux/std items to route them to the right segment of the MSB break.',
      _generated: new Date().toISOString().slice(0, 10),
      project: { name: '', client: '' },
      topologyMode: '1msb',
      groupQty: { hv: 1, mv: 1, tx: 1, lv: 1, pdu: 1 },
      sections,
    };
  }
  document.getElementById('btn-template').addEventListener('click', () => {
    const json = generateTemplateJson();
    const blob = new Blob([JSON.stringify(json, null, 2)], { type: 'application/json' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url; a.download = 'ngen-bom-template.json';
    document.body.appendChild(a); a.click(); document.body.removeChild(a);
    setTimeout(() => URL.revokeObjectURL(url), 1000);
  });

  // Snapshot the current BOM state as JSON (same shape as the template — so
  // it round-trips through Import). Only sections with qty>0 are included so
  // the file is compact; readers should treat missing sections as qty 0.
  function buildBomJson() {
    const sections = {};
    let totalCount = 0;
    CATALOG.forEach(cat => eachSection(cat, it => {
      const q = qty(it.key);
      if (q <= 0) return;
      const eq = q * gQty(cat.id);
      totalCount += eq;
      const entry = { qty: q, rating: ratingOf(it.key) };
      if (it.critToggle && isCrit(it.key)) entry.critical = true;
      sections[it.key] = entry;
    }));
    const projectName = (document.getElementById('q-project').value || '').trim();
    const clientName  = (document.getElementById('q-client').value || '').trim();
    const groupQtyOut = {};
    Object.keys(groupQty).forEach(gid => { if (groupQty[gid] !== 1) groupQtyOut[gid] = groupQty[gid]; });
    return {
      _doc: 'NGEN BOM export. Re-import via the Import JSON button to reload this BOM.',
      _generated: new Date().toISOString().slice(0, 10),
      _summary: { sections: Object.keys(sections).length, item_count: totalCount, topology_mode: topologyMode },
      project: { name: projectName, client: clientName },
      topologyMode,
      groupQty: groupQtyOut,
      sections,
    };
  }
  saveBtn.addEventListener('click', () => {
    const json = buildBomJson();
    if (!Object.keys(json.sections).length) { alert('Add sections to the BOM first.'); return; }
    const blob = new Blob([JSON.stringify(json, null, 2)], { type: 'application/json' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    const safeName = (json.project.name || 'untitled').replace(/[^a-z0-9-_]+/gi, '-').toLowerCase();
    a.href = url; a.download = `bom-${safeName}.json`;
    document.body.appendChild(a); a.click(); document.body.removeChild(a);
    setTimeout(() => URL.revokeObjectURL(url), 1000);
  });
  function applyImportedJson(data) {
    if (!data || typeof data !== 'object') { alert('Invalid JSON — top level must be an object.'); return; }
    // Wipe current state.
    Object.keys(quote).forEach(k => delete quote[k]);
    Object.keys(groupQty).forEach(k => delete groupQty[k]);
    Object.keys(critical).forEach(k => delete critical[k]);
    Object.keys(ratings).forEach(k => delete ratings[k]);
    // Project meta.
    if (data.project) {
      const pn = document.getElementById('q-project');
      const cn = document.getElementById('q-client');
      if (pn) pn.value = data.project.name || '';
      if (cn) cn.value = data.project.client || '';
    }
    // Topology mode.
    if (data.topologyMode === '1msb' || data.topologyMode === 'perups') {
      topologyMode = data.topologyMode;
      const sel = document.getElementById('topo-mode');
      if (sel) sel.value = topologyMode;
    }
    // Group qty.
    if (data.groupQty && typeof data.groupQty === 'object') {
      Object.entries(data.groupQty).forEach(([gid, v]) => {
        const n = Math.max(1, Math.floor(Number(v) || 1));
        groupQty[gid] = n;
      });
    }
    // Sections.
    let warnings = 0;
    if (data.sections && typeof data.sections === 'object') {
      Object.entries(data.sections).forEach(([key, entry]) => {
        if (!ITEM[key]) { warnings++; return; }
        if (!entry || typeof entry !== 'object') return;
        const q = Math.max(0, Math.floor(Number(entry.qty) || 0));
        if (q > 0) quote[key] = q;
        if (entry.rating != null && entry.rating !== '') {
          const ladder = ladderFor(key);
          if (ladder.some(e => e.label === String(entry.rating))) ratings[key] = String(entry.rating);
        }
        if (entry.critical === true && ITEM[key].critToggle) critical[key] = true;
      });
    }
    updateQuote();
    if (warnings) console.warn(`${warnings} unknown section key(s) in imported JSON were ignored.`);
  }
  document.getElementById('json-file').addEventListener('change', e => {
    const file = e.target.files && e.target.files[0];
    if (!file) return;
    const reader = new FileReader();
    reader.onload = ev => {
      try { applyImportedJson(JSON.parse(ev.target.result)); }
      catch (err) { alert('Could not parse JSON: ' + err.message); }
    };
    reader.readAsText(file);
    e.target.value = ''; // allow re-importing the same file
  });

  // ── Init ──
  renderCatalog();
  updateQuote();
  document.body.dataset.screen = 'quote';
  // Ensure the Start-your-Quote splash button lands on the quote screen.
  if (startBtn) startBtn.addEventListener('click', () => showScreen('quote'));
})();
</script>

</body>
</html>
