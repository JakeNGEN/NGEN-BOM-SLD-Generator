  panel:          { w: 110, h: 55, symbol: 'panel' },
  mech_panel:     { w: 110, h: 55, symbol: 'panel' },
  pdu:            { w: 110, h: 60, symbol: 'pdu' },
  busway:         { w: 130, h: 36, symbol: 'busway' },
  rpp:            { w: 120, h: 55, symbol: 'rpp' },
  sts:            { w: 60,  h: 60, symbol: 'sts' },
