function updateSummary(model) {
  const el = document.getElementById('summary');
  el.style.display = 'block';

  const kindCounts = {};
  model.devices.forEach(d => kindCounts[d.kind] = (kindCounts[d.kind] || 0) + 1);
  const flagged = model.devices.filter(d => d.required_input);
  const hasCycles = model.cycles.length > 0;

  let html = `<h3>${escapeXml(model.drawing_tag)}</h3>`;
  html += `<div class="stat"><span>Devices</span><span>${model.devices.length}</span></div>`;
  html += `<div class="stat"><span>Connections</span><span>${model.edges.length}</span></div>`;
  const upsCount = kindCounts.ups || 0;
  if (upsCount > 0) html += `<div class="stat"><span>UPS modules</span><span>${upsCount}</span></div>`;
  const busCount = (kindCounts.main_bus || 0) + (kindCounts.secondary_bus || 0);
  if (busCount > 0) html += `<div class="stat"><span>Buses</span><span>${busCount}</span></div>`;

  if (flagged.length > 0 || hasCycles) {
    html += '<div class="flag-list"><strong>Issues:</strong><ul>';
    if (hasCycles) {
      model.cycles.forEach(c => {
        html += `<li>Cycle: ${c.join(' → ')}</li>`;
      });
    }
    flagged.forEach(d => {
      const reason = d.notes || 'required input';
      html += `<li>${escapeXml(d.id)}: ${escapeXml(reason.substring(0, 60))}${reason.length > 60 ? '…' : ''}</li>`;
    });
    html += '</ul></div>';
  }

  el.innerHTML = html;
}

