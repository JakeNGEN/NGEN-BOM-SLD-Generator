  .cat-group > h3 {
    margin: 0;
    background: #f0f5f3;
    color: #1E6356;
    padding: 13px 18px;
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 0.3px;
    border-bottom: 1px solid #e5e7eb;
