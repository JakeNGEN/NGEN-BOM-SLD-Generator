function loadFile(file) {
  showFileLoader(file && file.name);
  const reader = new FileReader();
  const startedAt = Date.now();
  const finish = () => {
    // Keep the loader on screen for a minimum so small files don't just flash.
    const elapsed = Date.now() - startedAt;
    const MIN_VISIBLE_MS = 550;
    setTimeout(hideFileLoader, Math.max(0, MIN_VISIBLE_MS - elapsed));
  };
  reader.onload = e => {
    try {
      const json = JSON.parse(e.target.result);
      renderDiagram(json);
    } catch (err) {
      showError(err);
    }
    finish();
  };
  reader.onerror = () => {
    showError(new Error('Could not read file'));
    finish();
  };
  reader.readAsText(file);
}

function showFileLoader(filename) {
  const loader = document.getElementById('file-loader');
  const sub = document.getElementById('fl-subtext');
  if (sub) sub.textContent = filename ? filename : 'Parsing SLD';
  if (loader) {
    loader.classList.add('show');
    loader.setAttribute('aria-hidden', 'false');
  }
}
