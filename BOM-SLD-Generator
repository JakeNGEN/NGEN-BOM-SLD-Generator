    font-size: 11px; font-weight: 700;
  }
  .top-nav .nav-btn:hover:not(:disabled) { color: #fff; background: rgba(255,255,255,0.10); }
  .top-nav .nav-btn.active { color: #1E6356; background: #faf8f2; border-color: #faf8f2; }
  .top-nav .nav-btn.active .step-num { background: #CA942B; color: #fff; }
  .top-nav .nav-btn:disabled { opacity: 0.4; cursor: not-allowed; }

  /* Export buttons only relevant on the diagram screen */
  body[data-screen="quote"] .actions #btn-svg,
  body[data-screen="quote"] .actions #btn-png,
  body[data-screen="quote"] .actions #btn-print { display: none; }

  /* ── Quote screen ── */
  #screen-quote { padding: 0; }
  .quote-hero {
    background: linear-gradient(135deg, #1E6356 0%, #2c7d6c 100%);
    color: #fff;
    padding: 30px 40px 26px;
  }
  .quote-hero h2 { margin: 0; font-size: 26px; font-weight: 700; letter-spacing: 0.2px; }
  .quote-hero h2 .accent { color: #CA942B; }
  .quote-hero p { margin: 8px 0 0; font-size: 14px; color: #A1D5CC; max-width: 720px; font-weight: 300; line-height: 1.5; }
  .quote-hero .project-row { margin-top: 18px; display: flex; gap: 14px; flex-wrap: wrap; align-items: flex-end; }
  .quote-hero .project-row .fld { display: flex; flex-direction: column; gap: 5px; }
  .quote-hero .project-row label { font-size: 11px; text-transform: uppercase; letter-spacing: 0.6px; color: #A1D5CC; font-weight: 600; }
  .quote-hero .project-row input {
    background: rgba(255,255,255,0.92);
    border: 1px solid rgba(255,255,255,0.4);
    border-radius: 7px; padding: 9px 12px; font-size: 13px; font-family: inherit;
    color: #1f2937; min-width: 240px;
  }
  .quote-hero .project-row input:focus { outline: 2px solid #CA942B; background: #fff; }
  .json-tools { min-width: 250px; }
  .json-tool-row { display: flex; gap: 8px; }
  .btn-import, .btn-template {
    flex: 1; font-family: inherit; font-size: 13px; font-weight: 600;
    padding: 9px 12px; border-radius: 7px; cursor: pointer;
    display: inline-flex; align-items: center; justify-content: center; gap: 6px;
    background: rgba(255,255,255,0.92); color: #1E6356;
    border: 1px solid rgba(255,255,255,0.4);
  }
  .btn-import:hover, .btn-template:hover { background: #ffffff; border-color: #CA942B; color: #155146; }

  .quote-body {
    display: grid;
