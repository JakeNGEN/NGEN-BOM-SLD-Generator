// Renders an editable table of every device in the loaded JSON. The user
// can edit the display name, the rating items (specs), and the bus_position
// ordering hint. Clicking "Save & Update SLD" writes the edits back into
// state.json and re-renders the diagram.

const ICON_EDIT = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4Z"/></svg>';
const ICON_DELETE = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/></svg>';

function buildComponentsEditor(rawJson, model) {
  const root = document.getElementById('components-editor');
  if (!rawJson) {
    root.innerHTML = '<div class="empty">Load a JSON file to edit components.</div>';
    return;
  }
  if (!rawJson.devices || rawJson.devices.length === 0) {
    root.innerHTML = `
      <div class="editor-wrap">
        <div class="editor-header">
          <div>
            <h2>Components &amp; Specs</h2>
            <div class="hint">No components yet. Add one to get started.</div>
          </div>
          <div class="editor-header-right">
            <button class="btn-add-comp" id="btn-add-comp">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
              Add component
            </button>
          </div>
        </div>
      </div>
    `;
    document.getElementById('btn-add-comp').addEventListener('click', openAddComponentModal);
    return;
  }
  const cards = rawJson.devices.map(d => {
    const kindRaw = (model.byId[d.id] && model.byId[d.id].kind) || '';
    const kindLabel = kindRaw.replace(/_/g, ' ');
    const specsEn = Array.isArray(d.rating_items) ? d.rating_items : [];
    const specsZh = Array.isArray(d.rating_items_zh) ? d.rating_items_zh : [];
    // The edit form always writes to rating_items (English); the chips/name
    // displayed in the card respect the active language.
    const specsRaw = specsEn.join(', ');
    const displaySpecs = (isZh() && specsZh.length) ? specsZh : specsEn;
    const displayLabel = pickLang(d.label || d.id || '', d.label_zh);
    const pos = (typeof d.bus_position === 'number') ? d.bus_position : '';
    const idAttr = escapeAttr(d.id || '');
    const chips = displaySpecs.length
      ? displaySpecs.map(s => `<span class="spec-chip">${escapeXml(s)}</span>`).join('')
      : `<span class="comp-specs-empty">${isZh() ? '无规格' : 'No specs'}</span>`;
    const hasX = Number.isFinite(d.x);
    const hasY = Number.isFinite(d.y);
    const xVal = hasX ? d.x : '';
    const yVal = hasY ? d.y : '';
    const metaLines = [];
    if (pos !== '') metaLines.push(`<div class="comp-meta"><strong>Bus position:</strong> ${escapeXml(String(pos))}</div>`);
    if (hasX || hasY) {
      const xs = hasX ? d.x : 'auto';
      const ys = hasY ? d.y : 'auto';
      metaLines.push(`<div class="comp-meta"><strong>Position:</strong> (${escapeXml(String(xs))}, ${escapeXml(String(ys))})</div>`);
    }

    return `<div class="comp-card" data-id="${idAttr}">
      <div class="comp-card-head">
        <span class="comp-badge">${escapeXml(d.id || '')}</span>
        ${kindRaw ? `<span class="comp-kind">${escapeXml(kindLabel)}</span>` : ''}
        <div class="comp-card-actions">
          <button class="icon-btn" data-action="edit" title="Edit" aria-label="Edit ${idAttr}">${ICON_EDIT}</button>
          <button class="icon-btn danger" data-action="delete" title="Delete" aria-label="Delete ${idAttr}">${ICON_DELETE}</button>
        </div>
      </div>
      <div class="comp-view">
        <div class="comp-name">${escapeXml(displayLabel)}</div>
        <div class="comp-specs">${chips}</div>
        ${metaLines.join('')}
      </div>
      <div class="comp-edit">
        <div class="comp-edit-field">
          <label>Name</label>
          <input type="text" class="f-label" value="${escapeAttr(d.label || '')}" placeholder="Display name">
        </div>
        <div class="comp-edit-field">
          <label>Specs (comma-separated)</label>
          <input type="text" class="f-specs" value="${escapeAttr(specsRaw)}" placeholder="e.g. 2000A, 480V">
        </div>
        <div class="comp-edit-field row-pos">
          <label>Bus position</label>
          <input type="number" class="f-pos" value="${pos}" step="1" placeholder="auto">
        </div>
        <div class="comp-edit-field">
          <label>Position on canvas (X, Y)</label>
          <div class="xy-row">
            <input type="number" class="f-x" value="${xVal}" step="1" placeholder="X (auto)">
            <input type="number" class="f-y" value="${yVal}" step="1" placeholder="Y (auto)">
          </div>
        </div>
        <div class="comp-edit-actions">
          <button class="secondary" data-action="cancel">Cancel</button>
          <button data-action="save">Save</button>
        </div>
      </div>
    </div>`;
  }).join('');

  const count = rawJson.devices.length;
  root.innerHTML = `
    <div class="editor-wrap">
      <div class="editor-header">
        <div>
          <h2>Components &amp; Specs</h2>
          <div class="hint">Click the pencil to edit a card, the trash to remove it, or <strong>Add component</strong> to insert a new one. Changes update the SLD immediately.</div>
        </div>
        <div class="editor-header-right">
          <div class="editor-summary">${count} component${count === 1 ? '' : 's'}</div>
          <button class="btn-add-comp" id="btn-add-comp">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            Add component
          </button>
        </div>
      </div>
      <div class="comp-cards">${cards}</div>
    </div>
  `;
  document.getElementById('btn-add-comp').addEventListener('click', openAddComponentModal);

  if (!root._compHandlerBound) {
    root.addEventListener('click', handleComponentAction);
    root._compHandlerBound = true;
  }
}

function handleComponentAction(e) {
  const btn = e.target.closest('button[data-action]');
  if (!btn) return;
  const card = btn.closest('.comp-card');
  if (!card) return;
  const id = card.dataset.id;
  const action = btn.dataset.action;

  if (action === 'edit') {
    card.classList.add('editing');
    const first = card.querySelector('.f-label');
    if (first) { first.focus(); first.select(); }
  } else if (action === 'cancel') {
    resetCardInputs(card, id);
    card.classList.remove('editing');
  } else if (action === 'save') {
    saveCardEdits(card, id);
  } else if (action === 'delete') {
    deleteComponent(id);
  }
}

function resetCardInputs(card, id) {
  if (!state.json) return;
  const dev = state.json.devices.find(d => d.id === id);
  if (!dev) return;
  const labelEl = card.querySelector('.f-label');
  const specsEl = card.querySelector('.f-specs');
  const posEl = card.querySelector('.f-pos');
  const xEl = card.querySelector('.f-x');
  const yEl = card.querySelector('.f-y');
  if (labelEl) labelEl.value = dev.label || '';
  if (specsEl) specsEl.value = Array.isArray(dev.rating_items) ? dev.rating_items.join(', ') : '';
  if (posEl) posEl.value = (typeof dev.bus_position === 'number') ? dev.bus_position : '';
  if (xEl) xEl.value = Number.isFinite(dev.x) ? dev.x : '';
  if (yEl) yEl.value = Number.isFinite(dev.y) ? dev.y : '';
}

function saveCardEdits(card, id) {
  if (!state.json) return;
  const dev = state.json.devices.find(d => d.id === id);
  if (!dev) return;

  const label = card.querySelector('.f-label').value.trim();
  const specsRaw = card.querySelector('.f-specs').value;
  const posRaw = card.querySelector('.f-pos').value.trim();
  const xRaw = card.querySelector('.f-x').value.trim();
  const yRaw = card.querySelector('.f-y').value.trim();

  dev.label = label;
  dev.rating_items = specsRaw.split(',').map(s => s.trim()).filter(Boolean);
  if (posRaw === '') {
    delete dev.bus_position;
  } else {
    const n = Number(posRaw);
    if (Number.isFinite(n)) dev.bus_position = n;
  }
  if (xRaw === '') {
    delete dev.x;
  } else {
    const n = Number(xRaw);
    if (Number.isFinite(n)) dev.x = n;
  }
  if (yRaw === '') {
    delete dev.y;
  } else {
    const n = Number(yRaw);
    if (Number.isFinite(n)) dev.y = n;
  }
  renderDiagram(state.json);
}

// Sensible default ID prefix per device_type, used to auto-suggest a unique
// ID in the "Add component" modal. Falls back to "DEV-" if a type isn't here.
const PREFIX_FROM_TYPE = {
  'Utility Transformer':         'UTIL',
  'Diesel Generator':            'GEN',
  'Gas Generator':               'GEN',
  'Automatic Transfer Switch':   'ATS',
  'Air Circuit Breaker':         'CB',
  'Molded Case Circuit Breaker': 'CB',
  'LV Switchgear Lineup':        'SWBD',
  'MV Switchgear':               'SWBD',
  'Static UPS':                  'UPS',
  'Rotary UPS':                  'UPS',
  'Battery Cabinet':             'BAT',
  'Bypass Switch':               'BYP',
  'Step-Down Transformer / PDU': 'PDU',
  'Remote Power Panel':          'RPP',
  'Busway':                      'BW',
  'Static Transfer Switch':      'STS',
  'Current Transformer':         'CT',
  'Meter':                       'MTR',
  'Revenue-grade Meter':         'MTR',
  'Revenue-grade CT':            'CT',
};

function buildConnectOptionsHtml() {
  const opts = ['<option value="">(none &mdash; standalone)</option>'];
  (state.json.devices || []).forEach(d => {
    const labelTxt = d.label && d.label !== d.id ? ` — ${d.label}` : '';
    opts.push(`<option value="${escapeAttr(d.id)}">${escapeXml(d.id)}${escapeXml(labelTxt)}</option>`);
  });
  return opts.join('');
}

function makeConnRowHtml(presetTarget) {
  const targetOpts = buildConnectOptionsHtml();
  return `<div class="conn-row">
    <select class="conn-target">${targetOpts}</select>
    <select class="conn-dir">
      <option value="downstream">Downstream of (child)</option>
      <option value="upstream">Upstream of (parent)</option>
    </select>
    <button type="button" class="conn-remove" data-action="remove-conn" aria-label="Remove connection" title="Remove">&times;</button>
  </div>`;
}

function openAddComponentModal(prefillCoords) {
  if (!state.json) return;
  if (!Array.isArray(state.json.devices)) state.json.devices = [];

  const typeSelect = document.getElementById('add-type');
  typeSelect.innerHTML = Object.keys(DEVICE_TYPE_TO_KIND)
    .map(t => `<option value="${escapeAttr(t)}">${escapeXml(t)}</option>`).join('');

  // Seed the connection list with a single row.
  const list = document.getElementById('conn-list');
  list.innerHTML = makeConnRowHtml();

  document.getElementById('add-name').value = '';
  document.getElementById('add-specs').value = '';
  document.getElementById('add-x').value = (prefillCoords && Number.isFinite(prefillCoords.x)) ? prefillCoords.x : '';
  document.getElementById('add-y').value = (prefillCoords && Number.isFinite(prefillCoords.y)) ? prefillCoords.y : '';
  document.getElementById('add-error').textContent = '';

  updateAddIdFromType();
  document.getElementById('add-modal').hidden = false;
  setTimeout(() => document.getElementById('add-id').focus(), 0);
}

function addConnRow() {
  const list = document.getElementById('conn-list');
  list.insertAdjacentHTML('beforeend', makeConnRowHtml());
}

function handleConnListClick(e) {
  const btn = e.target.closest('button[data-action="remove-conn"]');
  if (!btn) return;
  const row = btn.closest('.conn-row');
  if (row) row.remove();
}

function updateAddIdFromType() {
  const type = document.getElementById('add-type').value;
  const prefix = PREFIX_FROM_TYPE[type] || 'DEV';
  document.getElementById('add-id').value = nextIdForPrefix(prefix);
}

function nextIdForPrefix(prefix) {
  const existing = new Set((state.json.devices || []).map(d => d.id));
  for (let n = 1; n <= 999; n++) {
    const padded = String(n).padStart(3, '0');
    const candidate = `${prefix}-${padded}`;
    if (!existing.has(candidate)) return candidate;
  }
  return `${prefix}-NEW`;
}

function closeAddModal() {
  document.getElementById('add-modal').hidden = true;
}

function submitAddComponent() {
  if (!state.json) return;
  if (!Array.isArray(state.json.devices)) state.json.devices = [];

  const type = document.getElementById('add-type').value;
  const id = document.getElementById('add-id').value.trim();
  const name = document.getElementById('add-name').value.trim();
  const specsRaw = document.getElementById('add-specs').value;
  const xRaw = document.getElementById('add-x').value.trim();
  const yRaw = document.getElementById('add-y').value.trim();
  const errEl = document.getElementById('add-error');
  errEl.textContent = '';

  if (!id) { errEl.textContent = 'ID is required.'; return; }
  if (state.json.devices.some(d => d.id === id)) {
    errEl.textContent = `ID "${id}" is already in use. Pick another.`;
    return;
  }

  // Collect connections from all rows. Empty target = ignored.
  const conns = [];
  document.querySelectorAll('#conn-list .conn-row').forEach(row => {
    const target = row.querySelector('.conn-target').value;
    const dir = row.querySelector('.conn-dir').value;
    if (target) conns.push({ target, dir });
  });

  const newDevice = {
    id,
    device_type: type,
    label: name || id,
    rating_items: specsRaw.split(',').map(s => s.trim()).filter(Boolean),
  };

  if (xRaw !== '') {
    const n = Number(xRaw);
    if (Number.isFinite(n)) newDevice.x = n;
  }
  if (yRaw !== '') {
    const n = Number(yRaw);
    if (Number.isFinite(n)) newDevice.y = n;
  }

  // Apply each connection. First "downstream of" sets upstream_parent on the
  // new device; additional parents are recorded as downstream_children on the
  // parent itself (the model supports multiple parents this way). "Upstream of"
  // means the new device is the parent — record the target as a child.
  conns.forEach(c => {
    if (c.dir === 'downstream') {
      if (!newDevice.upstream_parent) {
        newDevice.upstream_parent = c.target;
      } else {
        const parent = state.json.devices.find(d => d.id === c.target);
        if (parent) {
          if (!Array.isArray(parent.downstream_children)) parent.downstream_children = [];
          if (!parent.downstream_children.includes(id)) parent.downstream_children.push(id);
        }
      }
    } else {
      if (!Array.isArray(newDevice.downstream_children)) newDevice.downstream_children = [];
      if (!newDevice.downstream_children.includes(c.target)) newDevice.downstream_children.push(c.target);
    }
  });

  state.json.devices.push(newDevice);
  closeAddModal();
  renderDiagram(state.json);
}

function deleteComponent(id) {
  if (!state.json) return;
  const dev = state.json.devices.find(d => d.id === id);
  const display = dev && dev.label ? `${dev.label} (${id})` : id;
  if (!confirm(`Delete ${display}?\n\nThis removes it from the SLD and unlinks any references.`)) return;

  state.json.devices = state.json.devices.filter(d => d.id !== id);
  state.json.devices.forEach(d => {
    if (d.upstream_parent === id) delete d.upstream_parent;
    if (Array.isArray(d.downstream_children)) {
      d.downstream_children = d.downstream_children.filter(c => c !== id);
    }
  });
  renderDiagram(state.json);
}

function escapeAttr(s) {
  return String(s)
    .replace(/&/g, '&amp;')
    .replace(/"/g, '&quot;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;');
}

function showError(err) {
  const container = document.getElementById('svg-container');
  container.innerHTML = `<div class="error">Render error:\n${err.message || err}\n\n${err.stack || ''}</div>`;
  document.getElementById('summary').style.display = 'none';
  disableExportButtons();
}

// Render a coordinate grid covering (0,0) to (w,h) in node-space. Minor lines
// every 50 units; major lines + labels every 200. Labels live on the top and
// left edges so the user can read off coordinates to type into a card.
function renderGrid(w, h) {
  const MINOR = 50;
  const MAJOR = 200;
  const minorColor = '#eef0f2';
  const majorColor = '#d4dadf';
  const labelColor = '#9aa3ad';
  const axisColor = '#c5ccd2';
  // Round the extent up to the nearest major step + a buffer so the grid
  // covers the whole content area even if a node was pinned past the edge.
  const W = Math.ceil((w + MAJOR) / MAJOR) * MAJOR;
  const H = Math.ceil((h + MAJOR) / MAJOR) * MAJOR;
  let g = '';
  // Minor lines
  for (let x = 0; x <= W; x += MINOR) {
    if (x % MAJOR === 0) continue;
    g += `<line x1="${x}" y1="0" x2="${x}" y2="${H}" stroke="${minorColor}" stroke-width="0.5"/>`;
  }
  for (let y = 0; y <= H; y += MINOR) {
    if (y % MAJOR === 0) continue;
    g += `<line x1="0" y1="${y}" x2="${W}" y2="${y}" stroke="${minorColor}" stroke-width="0.5"/>`;
  }
  // Major lines + labels
  for (let x = 0; x <= W; x += MAJOR) {
    g += `<line x1="${x}" y1="0" x2="${x}" y2="${H}" stroke="${majorColor}" stroke-width="0.75"/>`;
    g += `<text x="${x + 3}" y="-6" font-family="${STYLE.fontFamily}" font-size="10" fill="${labelColor}">${x}</text>`;
  }
  for (let y = 0; y <= H; y += MAJOR) {
    g += `<line x1="0" y1="${y}" x2="${W}" y2="${y}" stroke="${majorColor}" stroke-width="0.75"/>`;
    g += `<text x="-6" y="${y + 3}" text-anchor="end" font-family="${STYLE.fontFamily}" font-size="10" fill="${labelColor}">${y}</text>`;
  }
  // Axes (0,0 origin emphasized)
  g += `<line x1="0" y1="0" x2="${W}" y2="0" stroke="${axisColor}" stroke-width="1"/>`;
  g += `<line x1="0" y1="0" x2="0" y2="${H}" stroke="${axisColor}" stroke-width="1"/>`;
  g += `<text x="-6" y="-6" text-anchor="end" font-family="${STYLE.fontFamily}" font-size="9" font-weight="600" fill="${labelColor}">0,0</text>`;
  return g;
}

function buildSvg(model, layout) {
  // Place the ground bus manually — same x/width as the main bus, just below
  // the lowest device. ELK doesn't see it (filtered out in buildElkGraph) so
  // we compute its geometry from the laid-out main bus.
  const groundBusDev = model.devices.find(d => d.kind === 'ground_bus');
  const mainBusNode = layout.children.find(n => model.byId[n.id] && model.byId[n.id].kind === 'main_bus');
  // Bus-section breakers: shift each segmented bus's right half to open a gap,
  // re-route the affected conductors, widen the bar to span its feeders, and
  // compute the on-bar boundary. Done before the ground-bus geometry below so a
  // widened/shifted main bus carries through to the ground bus.
  const sections = computeSegmentation(model, layout);
  // After all routing (ELK + segmentation reroutes) is done, detour any wire
  // segments that pass through non-endpoint node bounding boxes so paths
  // navigate around product graphics instead of crossing them.
  routeAvoidObstacles(layout, model);
  let groundBus = null;
  if (groundBusDev) {
    const lastBottom = layout.children.length
      ? Math.max(...layout.children.map(n => n.y + n.height))
      : 0;
    // Width: match the main bus, but grow if the ground-bus label needs more room.
    const baseW = mainBusNode ? mainBusNode.width : layout.width;
    const width = Math.max(baseW, busRequiredWidth(groundBusDev));
    groundBus = {
      id: groundBusDev.id,
      x: mainBusNode ? mainBusNode.x : 0,
      y: lastBottom + 60,
      width,
      height: STYLE.groundBusH,
    };
  }
  const contentH = groundBus ? (groundBus.y + groundBus.height) : layout.height;
  const contentW = groundBus
    ? Math.max(layout.width, groundBus.x + groundBus.width)
    : layout.width;

  const W = contentW + STYLE.pageMargin * 2;
  const H = contentH + STYLE.headerHeight + STYLE.pageMargin * 2 + 120; // extra for legend
  const svg = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
  svg.setAttribute('xmlns', 'http://www.w3.org/2000/svg');
  svg.setAttribute('viewBox', `0 0 ${W} ${H}`);
  svg.setAttribute('width', W);
  svg.setAttribute('height', H);

  let inner = '';

  // Reusable filters + gradients used by every device symbol.
  inner += `<defs>
    <filter id="dropShadow" x="-20%" y="-20%" width="140%" height="150%">
      <feGaussianBlur in="SourceAlpha" stdDeviation="1"/>
      <feOffset dx="0.6" dy="1.3"/>
      <feComponentTransfer><feFuncA type="linear" slope="0.32"/></feComponentTransfer>
      <feMerge><feMergeNode/><feMergeNode in="SourceGraphic"/></feMerge>
    </filter>
    <filter id="busShadow" x="-3%" y="-80%" width="106%" height="260%">
      <feGaussianBlur in="SourceAlpha" stdDeviation="1.4"/>
      <feOffset dx="0" dy="1.8"/>
      <feComponentTransfer><feFuncA type="linear" slope="0.4"/></feComponentTransfer>
      <feMerge><feMergeNode/><feMergeNode in="SourceGraphic"/></feMerge>
    </filter>
    <!-- Generic light device body (battery, STS, fallback) -->
    <linearGradient id="gradDevice" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#ffffff"/>
      <stop offset="55%" stop-color="#f6f7f9"/>
      <stop offset="100%" stop-color="#e3e6eb"/>
    </linearGradient>
    <!-- Utility transformer (warm green) — radial for a "dome" feel -->
    <radialGradient id="gradUtil" cx="0.35" cy="0.32" r="0.78">
      <stop offset="0%"   stop-color="#9bd087"/>
      <stop offset="55%"  stop-color="#5a9a3e"/>
      <stop offset="100%" stop-color="#2e6e1a"/>
    </radialGradient>
    <!-- Generator (warm tan/orange) -->
    <radialGradient id="gradGen" cx="0.35" cy="0.32" r="0.78">
      <stop offset="0%"   stop-color="#f0c87a"/>
      <stop offset="55%"  stop-color="#c98e2e"/>
      <stop offset="100%" stop-color="#8a5e16"/>
    </radialGradient>
    <!-- Circuit breaker body (black) -->
    <linearGradient id="gradCb" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%"   stop-color="#3a3a3a"/>
      <stop offset="100%" stop-color="#080808"/>
    </linearGradient>
    <!-- ATS (blue) -->
    <linearGradient id="gradAts" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%"   stop-color="#6ba4d8"/>
      <stop offset="55%"  stop-color="#3674b3"/>
      <stop offset="100%" stop-color="#1d4f88"/>
    </linearGradient>
    <!-- UPS (lavender) -->
    <linearGradient id="gradUps" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%"   stop-color="#efe7fa"/>
      <stop offset="55%"  stop-color="#d3c0eb"/>
      <stop offset="100%" stop-color="#a98ec8"/>
    </linearGradient>
    <!-- PDU (steel blue) -->
    <linearGradient id="gradPdu" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%"   stop-color="#bcd3e7"/>
      <stop offset="55%"  stop-color="#7ea5c7"/>
      <stop offset="100%" stop-color="#5982b2"/>
    </linearGradient>
    <!-- Busway (gray-green) -->
    <linearGradient id="gradBusway" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%"   stop-color="#b3cfb3"/>
      <stop offset="55%"  stop-color="#82ab82"/>
      <stop offset="100%" stop-color="#5a8a5a"/>
    </linearGradient>
    <!-- RPP (light gray — paired with dashed border) -->
    <linearGradient id="gradRpp" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%"   stop-color="#eef1f5"/>
      <stop offset="55%"  stop-color="#cdd3dc"/>
      <stop offset="100%" stop-color="#a5acb6"/>
    </linearGradient>
    <!-- Mech / HVAC / BMS / generic panel (dark slate) -->
    <linearGradient id="gradMech" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%"   stop-color="#52606e"/>
      <stop offset="55%"  stop-color="#2f3a47"/>
      <stop offset="100%" stop-color="#1d262f"/>
    </linearGradient>
    <!-- Main bus & secondary (UPS-output) bus — lime green family -->
    <linearGradient id="gradMainBus" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%"   stop-color="#c5dc46"/>
      <stop offset="50%"  stop-color="#7fa423"/>
      <stop offset="100%" stop-color="#4f6f10"/>
    </linearGradient>
    <linearGradient id="gradSecBus" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%"   stop-color="#d8e87a"/>
      <stop offset="50%"  stop-color="#9ec23a"/>
      <stop offset="100%" stop-color="#6c8e1c"/>
    </linearGradient>
    <!-- Ground bus (forest green) -->
    <linearGradient id="gradGroundBus" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%"   stop-color="#7fb87a"/>
      <stop offset="55%"  stop-color="#4a8245"/>
      <stop offset="100%" stop-color="#2e5a2b"/>
    </linearGradient>
    <!-- Shared top-down gloss overlay -->
    <linearGradient id="gloss" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#ffffff" stop-opacity="0.55"/>
      <stop offset="55%" stop-color="#ffffff" stop-opacity="0.06"/>
      <stop offset="100%" stop-color="#ffffff" stop-opacity="0"/>
    </linearGradient>
  </defs>`;

  // Background
  inner += `<rect width="${W}" height="${H}" fill="${STYLE.canvasBg}"/>`;

  // Header banner (NGEN brand)
  inner += `<rect x="0" y="0" width="${W}" height="${STYLE.headerHeight}" fill="${STYLE.headerBg}"/>`;

  // NGEN logo — top-left (native aspect ratio 1500:455 ≈ 3.30:1)
  const brandX = STYLE.pageMargin;
  const logoH = 56;
  const logoW = Math.round(logoH * 1500 / 455);
  const logoY = (STYLE.headerHeight - logoH) / 2;
  // Cream "card" behind the logo so the dark wordmark reads on the green header
  const padX = 14, padY = 6;
  inner += `<rect x="${brandX - padX}" y="${logoY - padY}" width="${logoW + padX*2}" height="${logoH + padY*2}" rx="8" fill="#faf8f2" filter="url(#dropShadow)"/>`;
  inner += `<image x="${brandX}" y="${logoY}" width="${logoW}" height="${logoH}" href="data:image/webp;base64," preserveAspectRatio="xMidYMid meet"/>`;
  // Vertical divider between logo and drawing title
  inner += `<line x1="${brandX + logoW + 22}" y1="22" x2="${brandX + logoW + 22}" y2="${STYLE.headerHeight - 22}" stroke="#ffffff" stroke-opacity="0.22" stroke-width="1"/>`;

  // Drawing title — centered
  const hdrTitle = pickLang(model.drawing_tag, model.drawing_tag_zh);
  const hdrSummary = pickLang(model.system_summary, model.system_summary_zh);
  inner += `<text x="${W/2}" y="40" text-anchor="middle" font-family="${STYLE.fontFamily}" font-size="${STYLE.titleSize}" font-weight="700" fill="${STYLE.headerTitleColor}">${escapeXml(hdrTitle)}</text>`;
  if (hdrSummary) {
    inner += `<text x="${W/2}" y="62" text-anchor="middle" font-family="${STYLE.fontFamily}" font-size="${STYLE.subtitleSize}" font-weight="400" fill="${STYLE.headerSubColor}">${escapeXml(hdrSummary)}</text>`;
  }
  const pm = model.project_meta || {};
  const site = pickLang(pm.site || pm.project_name || '', pm.site_zh || pm.project_name_zh || '');
  if (site) {
    inner += `<text x="${W/2}" y="80" text-anchor="middle" font-family="${STYLE.fontFamily}" font-size="${STYLE.subtitleSize}" font-weight="300" fill="${STYLE.headerSubColor}">${escapeXml(site)}</text>`;
  }

  // Thin gold accent line at bottom of header
  inner += `<rect x="0" y="${STYLE.headerHeight - 3}" width="${W}" height="3" fill="#CA942B"/>`;

  // Offset everything below the header
  const yOff = STYLE.headerHeight + STYLE.pageMargin;
  const xOff = STYLE.pageMargin;

  // Grid + coordinate ruler (behind everything else, inside the same translated
  // group so its labels match the X/Y values used by the manual placement UI).
  if (state.showGrid) {
    inner += `<g transform="translate(${xOff},${yOff})" class="grid-layer">`;
    inner += renderGrid(contentW, contentH);
    inner += `</g>`;
  }

  // Edges first (so devices render on top), all inside an addressable group
  // so the interactive layer can convert client coords into node-space.
  inner += `<g id="sld-content" data-xoff="${xOff}" data-yoff="${yOff}" transform="translate(${xOff},${yOff})">`;
  layout.edges.forEach(edge => {
    inner += renderEdge(edge, model);
  });

  // Nodes
  layout.children.forEach(node => {
    inner += renderNode(node, model);
  });
  // Manually-placed ground bus, after every other node
  if (groundBus) {
    inner += renderNode(groundBus, model);
  }
  // Inline bus-section breakers and mechanical-interlock callouts — drawn on top
  // of the nodes. The interlock dashed line is an annotation, not a conductor.
  inner += renderSectionBreakers(sections, model);
  inner += renderInterlocks(model, layout, sections);
  // Rubber-band line target (used while drawing a new connection)
  inner += `<line id="sld-rubber" x1="0" y1="0" x2="0" y2="0" stroke="#CA942B" stroke-width="2" stroke-dasharray="6,4" stroke-linecap="round" visibility="hidden" pointer-events="none"/>`;
  inner += `</g>`;

  // Required-input legend below the ground bus
  const flagged = model.devices.filter(d => d.required_input || model.cycles.some(c => c.includes(d.id)));
  if (flagged.length > 0) {
    inner += renderLegend(flagged, model, xOff, yOff + contentH + 24);
  }

  // Auto-generated component-types legend (bottom-left panel)
  let bottomStripY = yOff + contentH + 60;
  if (flagged.length > 0) bottomStripY += 20 + flagged.length * 16;
  let extraBottom = 0;
  if (state.showLegend) {
    const tl = renderTypeLegend(model, xOff, bottomStripY);
    if (tl) {
      inner += tl.svg;
      extraBottom = Math.max(extraBottom, tl.height);
    }
  }
  // Editable title block (bottom-right panel) — pulls from state.json.project_meta
  const tbMeta = (state.json && state.json.project_meta) || {};
  const tb = renderTitleBlock(tbMeta, W - STYLE.pageMargin, bottomStripY);
  if (tb) {
    inner += tb.svg;
    extraBottom = Math.max(extraBottom, tb.height);
  }

  // Grow the SVG height if our bottom-strip panels overflow the reserved 120px
  if (extraBottom > 0) {
    const newH = bottomStripY + extraBottom + STYLE.pageMargin;
    if (newH > H) {
      svg.setAttribute('viewBox', `0 0 ${W} ${newH}`);
      svg.setAttribute('height', newH);
    }
  }

  svg.innerHTML = inner;
  return svg;
}

// ── COMPONENT-TYPES LEGEND ──────────────────────────────────────────
// Auto-builds a small legend showing one row per device kind currently in
// the diagram. Returns { svg, height } so buildSvg can grow the canvas.
function renderTypeLegend(model, x, y) {
  const KIND_LABELS = {
    utility: 'Utility', generator: 'Generator', ats: 'ATS', sts: 'STS',
    breaker: 'Circuit Breaker', main_bus: 'Main Bus', secondary_bus: 'Secondary Bus',
    ground_bus: 'Ground Bus', ups: 'UPS', pdu: 'PDU', rpp: 'RPP',
    panel: 'Panel', mech_load: 'Mechanical Load', meter: 'Meter', ct: 'CT',
    battery: 'Battery', busway: 'Busway', cpt: 'CPT', other: 'Other',
    bypass: 'Bypass / Tie Breaker', __interlock__: 'Mechanical Interlock',
    __fbo__: 'F.B.O (Furnished by Other)'
  };
  const KIND_LABELS_ZH = {
    utility: '市电', generator: '发电机', ats: '自动转换开关', sts: '静态转换开关',
    breaker: '断路器', main_bus: '主母线', secondary_bus: '次级母线',
    ground_bus: '接地母线', ups: '不间断电源', pdu: '配电单元', rpp: '远程配电柜',
    panel: '配电盘', mech_load: '机械负载', meter: '电表', ct: '电流互感器',
    battery: '电池', busway: '母线槽', cpt: '控制电源变压器', other: '其他',
    bypass: '旁路 / 母联断路器', __interlock__: '机械联锁',
    __fbo__: 'F.B.O (由他方提供)'
  };
  const present = Array.from(new Set((model.devices || []).map(d => d.kind))).sort();
  if (model.interlocks && model.interlocks.length) present.push('__interlock__');
  if ((model.devices || []).some(d => (d.rating_items || []).some(s => s === 'F.B.O'))) present.push('__fbo__');
  if (present.length === 0) return null;

  const rowH = 22;
  const w = 220;
  const headerH = 24;
  const h = headerH + present.length * rowH + 10;
  let out = `<g class="type-legend" transform="translate(${x},${y})">`;
  out += `<rect x="0" y="0" width="${w}" height="${h}" rx="4" fill="#ffffff" stroke="#1E6356" stroke-width="1.2" filter="url(#dropShadow)"/>`;
  out += `<rect x="0" y="0" width="${w}" height="${headerH}" rx="4" fill="#1E6356"/>`;
  out += `<rect x="0" y="${headerH - 4}" width="${w}" height="4" fill="#1E6356"/>`;
  out += `<text x="10" y="16" font-family="${STYLE.fontFamily}" font-size="11" font-weight="700" fill="#ffffff" letter-spacing="0.5">${isZh() ? '元件类型' : 'COMPONENT TYPES'}</text>`;
  present.forEach((k, i) => {
    const fy = headerH + 6 + i * rowH;
    out += renderMiniSymbol(k, 10, fy + 2);
    const label = pickLang(KIND_LABELS[k] || k, KIND_LABELS_ZH[k]);
    out += `<text x="50" y="${fy + 14}" font-family="${STYLE.fontFamily}" font-size="11" fill="#111827">${escapeXml(label)}</text>`;
  });
  out += `</g>`;
  return { svg: out, height: h };
}

function renderMiniSymbol(kind, x, y) {
  const sw = 32, sh = 14;
  if (kind === 'main_bus' || kind === 'secondary_bus' || kind === 'ground_bus') {
    const fill = kind === 'main_bus' ? STYLE.mainBusFill
               : kind === 'secondary_bus' ? STYLE.secBusFill
               : STYLE.groundBusFill;
    return `<rect x="${x}" y="${y + 4}" width="${sw}" height="6" fill="${fill}" stroke="#111827" stroke-width="0.8"/>`;
  }
  if (kind === 'utility') {
    return `<circle cx="${x + 16}" cy="${y + 7}" r="7" fill="url(#gradUtil)" stroke="#1a3a0a" stroke-width="0.8"/>
            <text x="${x + 16}" y="${y + 10.5}" text-anchor="middle" font-family="${STYLE.fontFamily}" font-size="8" font-weight="700" fill="#ffffff">U</text>`;
  }
  if (kind === 'generator') {
    return `<circle cx="${x + 16}" cy="${y + 7}" r="7" fill="url(#gradGen)" stroke="#5a3a08" stroke-width="0.8"/>
            <text x="${x + 16}" y="${y + 10.5}" text-anchor="middle" font-family="${STYLE.fontFamily}" font-size="8" font-weight="700" fill="#ffffff">G</text>`;
  }
  if (kind === 'breaker' || kind === 'bypass') {
    return `<rect x="${x + 6}" y="${y}" width="${sw - 12}" height="${sh}" rx="1.5" fill="url(#gradCb)" stroke="#000" stroke-width="0.8"/>`;
  }
  if (kind === 'bus_separator') {
    return `<rect x="${x + 4}" y="${y + 4}" width="${sw - 8}" height="6" fill="${STYLE.mainBusFill}" stroke="#111827" stroke-width="0.6"/>
            <rect x="${x + sw/2 - 4}" y="${y + 1}" width="8" height="12" rx="1.5" fill="${STYLE.busSeparatorFill}" stroke="${STYLE.busSeparatorBorder}" stroke-width="1.2"/>`;
  }
  if (kind === '__interlock__') {
    return `<line x1="${x}" y1="${y + 7}" x2="${x + sw}" y2="${y + 7}" stroke="${STYLE.interlockColor}" stroke-width="1.6" stroke-dasharray="4,3"/>`;
  }
  if (kind === '__fbo__') {
    return `<rect x="${x + 4}" y="${y + 1}" width="${sw - 8}" height="12" rx="2" fill="#fef9c3" stroke="#a16207" stroke-width="0.8"/>
            <text x="${x + 16}" y="${y + 10}" text-anchor="middle" font-family="${STYLE.fontFamily}" font-size="7" font-weight="700" fill="#854d0e">F.B.O</text>`;
  }
  if (kind === 'ats' || kind === 'sts') {
    return `<rect x="${x}" y="${y}" width="${sw}" height="${sh}" rx="2" fill="url(#gradAts)" stroke="#111827" stroke-width="0.8"/>
            <text x="${x + 16}" y="${y + 10}" text-anchor="middle" font-family="${STYLE.fontFamily}" font-size="7" font-weight="700" fill="#ffffff">${kind.toUpperCase()}</text>`;
  }
  if (kind === 'ups') {
    return `<rect x="${x}" y="${y}" width="${sw}" height="${sh}" rx="2" fill="${STYLE.upsFill}" stroke="#111827" stroke-width="0.8"/>
            <text x="${x + 16}" y="${y + 10}" text-anchor="middle" font-family="${STYLE.fontFamily}" font-size="7" font-weight="700" fill="#111827">UPS</text>`;
  }
  if (kind === 'mech_load') {
    return `<rect x="${x}" y="${y}" width="${sw}" height="${sh}" rx="1.5" fill="${STYLE.deviceFill}" stroke="#111827" stroke-width="0.8"/>
            <circle cx="${x + 16}" cy="${y + 7}" r="4" fill="none" stroke="#CA942B" stroke-width="1.2"/>
            <text x="${x + 16}" y="${y + 9.5}" text-anchor="middle" font-family="${STYLE.fontFamily}" font-size="5.5" font-weight="700" fill="#1E6356">M</text>`;
  }
  // generic block
  return `<rect x="${x}" y="${y}" width="${sw}" height="${sh}" rx="1.5" fill="${STYLE.deviceFill}" stroke="#111827" stroke-width="0.8"/>`;
}

// ── TITLE BLOCK ─────────────────────────────────────────────────────
// Engineering-drawing title block in the bottom-right. Pulls from
// state.json.project_meta. Returns null when no metadata is set.
function renderTitleBlock(meta, rightX, y) {
  if (!meta) return null;
  const fields = [
    ['PROJECT',        pickLang(meta.project_name || meta.project || meta.site || '', meta.project_name_zh || meta.site_zh || '')],
    ['DRAWING NO.',    pickLang(meta.drawing_no || meta.drawing_number || '',          meta.drawing_no_zh || '')],
    ['REVISION',       meta.revision || meta.rev || ''],
    ['DATE',           meta.date || ''],
    ['DRAWN BY',       pickLang(meta.drawn_by || meta.author || '',                    meta.drawn_by_zh || '')],
    ['CLASSIFICATION', meta.classification || '']
  ];
  if (!fields.some(f => f[1])) return null;

  const w = 380;
  const headerH = 24;
  const rowH = 36;
  const h = headerH + Math.ceil(fields.length / 2) * rowH + 8;
  const x = rightX - w;
  const colW = w / 2;
  const classification = (meta.classification || '').toUpperCase();
  const classColor =
    classification === 'STRICTLY CONFIDENTIAL' ? '#dc2626' :
    classification === 'CONFIDENTIAL'          ? '#CA942B' :
    classification === 'INTERNAL'              ? '#1E6356' :
    classification === 'PUBLIC'                ? '#6B9E86' : '#6b7280';

  let out = `<g class="title-block" transform="translate(${x},${y})">`;
  out += `<rect x="0" y="0" width="${w}" height="${h}" rx="4" fill="#ffffff" stroke="#1E6356" stroke-width="1.5" filter="url(#dropShadow)"/>`;
  out += `<rect x="0" y="0" width="${w}" height="${headerH}" rx="4" fill="#1E6356"/>`;
  out += `<rect x="0" y="${headerH - 4}" width="${w}" height="4" fill="#1E6356"/>`;
  out += `<text x="10" y="16" font-family="${STYLE.fontFamily}" font-size="11" font-weight="700" fill="#ffffff" letter-spacing="0.5">DRAWING TITLE BLOCK</text>`;
  out += `<rect x="${w - 86}" y="4" width="80" height="16" rx="3" fill="#CA942B"/>`;
  out += `<text x="${w - 46}" y="15" text-anchor="middle" font-family="${STYLE.fontFamily}" font-size="9" font-weight="700" fill="#ffffff" letter-spacing="0.4">NGEN</text>`;
  fields.forEach((field, i) => {
    const col = i % 2;
    const row = Math.floor(i / 2);
    const fx = col * colW + 12;
    const fy = headerH + 14 + row * rowH;
    const valColor = field[0] === 'CLASSIFICATION' && field[1] ? classColor : '#111827';
    out += `<text x="${fx}" y="${fy}" font-family="${STYLE.fontFamily}" font-size="8" font-weight="700" fill="#6b7280" letter-spacing="0.5">${field[0]}</text>`;
    out += `<text x="${fx}" y="${fy + 16}" font-family="${STYLE.fontFamily}" font-size="12" font-weight="600" fill="${valColor}">${escapeXml(truncate(field[1] || '—', 32))}</text>`;
    if (col === 0 && i + 1 < fields.length) {
      out += `<line x1="${colW}" y1="${headerH + 2 + row * rowH}" x2="${colW}" y2="${headerH + 2 + (row + 1) * rowH - 4}" stroke="#e5e7eb" stroke-width="0.8"/>`;
    }
    if (row < Math.ceil(fields.length / 2) - 1) {
      out += `<line x1="6" y1="${headerH + 4 + (row + 1) * rowH - 4}" x2="${w - 6}" y2="${headerH + 4 + (row + 1) * rowH - 4}" stroke="#e5e7eb" stroke-width="0.6"/>`;
    }
  });
  out += `</g>`;
  return { svg: out, height: h };
}

function truncate(s, n) {
  if (!s) return '';
  const str = String(s);
  return str.length > n ? str.substring(0, n - 1) + '…' : str;
}

// Package grouping outlines removed per request — the renderer no longer draws
// dashed section outlines or pill labels around package members.

function renderNode(node, model) {
  const d = model.byId[node.id];
  if (!d) return '';
  const geom = DEVICE_GEOMETRY[d.kind] || DEVICE_GEOMETRY.other;
  const isBus = d.kind === 'main_bus' || d.kind === 'secondary_bus' || d.kind === 'ground_bus';
  const x = node.x;
  const y = node.y;
  // Buses scale to their full ELK width. Every other symbol stays at its
  // native geometry size and is centered horizontally inside the ELK node
  // area (which may have been grown wider to clear label/rating text).
  const drawW = isBus ? node.width : geom.w;
  const drawH = node.height;
  const offsetX = (node.width - drawW) / 2;
  const symFn = SYMBOLS[geom.symbol];
  // A segmented bus (one carrying an inline section breaker) draws as two bars
  // with a gap between them; renderSectionBreakers fills the gap with the
  // breaker symbol and stubs. _split.x is in node-space; convert to bar-local.
  const split = (isBus && node._split && (d.kind === 'main_bus' || d.kind === 'secondary_bus')) ? node._split : null;
  let sym;
  if (split) {
    const busGrad = d.kind === 'secondary_bus' ? 'gradSecBus' : 'gradMainBus';
    const localB = split.x - node.x;
    const leftW = localB - split.gap / 2;
    const rightStart = localB + split.gap / 2;
    const rightW = drawW - rightStart;
    const piece = (xL, w) => w > 0
      ? `<rect x="${xL}" y="0" width="${w}" height="${drawH}" fill="url(#${busGrad})" stroke="${STYLE.deviceStroke}" stroke-width="${STYLE.busStrokeW}" filter="url(#busShadow)"/>`
        + `<rect x="${xL + 1}" y="1" width="${w - 2}" height="${drawH * 0.4}" fill="url(#gloss)" pointer-events="none"/>`
      : '';
    sym = piece(0, leftW) + piece(rightStart, rightW);
  } else {
    sym = symFn ? symFn(drawW, drawH) : '';
  }
  const isFlagged = d.required_input || model.cycles.some(c => c.includes(d.id));

  // Wrap the node in a draggable group. The invisible hit-rect catches mouse
  // events that fall inside the bounding box but outside the visible symbol
  // (e.g. transparent corners of a transformer circle).
  let out = `<g class="draggable-node" data-id="${escapeAttr(d.id)}" data-w="${drawW}" data-h="${drawH}" data-offx="${offsetX}" data-bus="${isBus ? 1 : 0}" transform="translate(${x + offsetX},${y})">`;
  out += `<rect class="node-hit" x="0" y="0" width="${drawW}" height="${drawH}" fill="transparent" stroke="transparent" pointer-events="all"/>`;
  out += sym;

  // Bus labels are placed differently (on the bus itself)
  const displayLabel = pickLang(d.label, d.label_zh);
  const displaySpecs = pickRatingItems(d);
  if (d.kind === 'main_bus' || d.kind === 'secondary_bus') {
    // On a split bus, centre the label in the (wider) left segment so it clears
    // the section breaker straddling the gap.
    const lblX = split ? Math.max(20, (split.x - node.x - split.gap / 2) / 2) : drawW / 2;
    out += `<text x="${lblX}" y="${drawH/2}" text-anchor="middle" dominant-baseline="central" font-family="${STYLE.fontFamily}" font-size="${STYLE.busLabelSize}" font-weight="600" fill="${STYLE.labelColor}">${busLabelContent(displayLabel, displaySpecs)}</text>`;
  } else if (d.kind === 'ground_bus') {
    out += `<text x="${drawW/2}" y="${drawH/2}" text-anchor="middle" dominant-baseline="central" font-family="${STYLE.fontFamily}" font-size="${STYLE.busLabelSize}" font-weight="600" fill="#ffffff">${escapeXml(displayLabel)}</text>`;
  } else {
    // Regular device: label below + rating below that. The text carries a
    // white stroke ("halo") rendered BEHIND the fill via paint-order so lines
    // that happen to pass under the labels stay readable.
    const labelY = drawH + 12;
    out += `<text x="${drawW/2}" y="${labelY}" text-anchor="middle" font-family="${STYLE.fontFamily}" font-size="${STYLE.labelSize}" font-weight="600" fill="${STYLE.labelColor}" stroke="#ffffff" stroke-width="3" stroke-linejoin="round" paint-order="stroke">${escapeXml(displayLabel)}</text>`;
    if (displaySpecs.length > 0) {
      out += `<text x="${drawW/2}" y="${labelY + 12}" text-anchor="middle" font-family="${STYLE.fontFamily}" font-size="${STYLE.ratingSize}" fill="${STYLE.ratingColor}" stroke="#ffffff" stroke-width="2.5" stroke-linejoin="round" paint-order="stroke">${ratingTextContent(displaySpecs, 30)}</text>`;
    }
    // Flag star on top-right of the visible symbol
    if (isFlagged) {
      out += `<text x="${drawW - 4}" y="12" text-anchor="end" font-family="${STYLE.fontFamily}" font-size="14" font-weight="700" fill="${STYLE.flagColor}">★</text>`;
    }
  }

  out += `</g>`;
  return out;
}

function renderEdge(edge, model) {
  const e = model.edges.find(x => x.source === edge.sources[0] && x.target === edge.targets[0]);
  const style = e ? e.style : 'normal';
  const dash = style === 'standby' || style === 'alt_path' ? ` stroke-dasharray="${STYLE.dashedDash}"` : '';
  const color = style === 'standby' ? STYLE.wireStandby :
                style === 'alt_path' ? STYLE.wireAlt :
                STYLE.wire;

  // Check if either endpoint is a bus — use thicker wire for bus drops
  const sourceDev = model.byId[edge.sources[0]];
  const targetDev = model.byId[edge.targets[0]];
  const isBusDrop = (sourceDev && (sourceDev.kind === 'main_bus' || sourceDev.kind === 'secondary_bus')) ||
                    (targetDev && (targetDev.kind === 'main_bus' || targetDev.kind === 'secondary_bus'));
  const strokeW = isBusDrop ? STYLE.busDropStrokeW : STYLE.wireStrokeW;

  let path = '';
  (edge.sections || []).forEach(section => {
    path += `M${section.startPoint.x},${section.startPoint.y}`;
    (section.bendPoints || []).forEach(bp => {
      path += `L${bp.x},${bp.y}`;
    });
    path += `L${section.endPoint.x},${section.endPoint.y}`;
  });

  return `<path class="sld-edge" data-source="${escapeAttr(edge.sources[0])}" data-target="${escapeAttr(edge.targets[0])}" d="${path}" fill="none" stroke="${color}" stroke-width="${strokeW}"${dash} stroke-linecap="square" stroke-linejoin="miter"/>`;
}

// ─── BUS SEGMENTATION (SKRU) ───────────────────────────────────────────────
// A bus_separator is NOT a node in the power-flow graph — it's an ornament that
// sits inline on a bus bar at the boundary between the bus's two segments. This
// runs AFTER ELK: it widens each segmented bus so its bar spans every feeder,
// then computes the boundary x where the separator should sit. Returns one
// entry per placeable separator: { id, dev, busId, x, centerY, busBottom }.
function computeSegmentation(model, layout) {
  const out = [];
  if (!model.segmentedBusIds || model.segmentedBusIds.size === 0) return out;
  const nodeById = {};
  (layout.children || []).forEach(n => nodeById[n.id] = n);
  const SECTION_GAP = 64;   // clear span (bar units) the breaker straddles

  model.devices.filter(d => d.isBusSection).forEach(sec => {
    const busId = sec.sectionBus;
    const busNode = busId && nodeById[busId];
    if (!busNode) return; // unknown segments_bus — already warned in normalize()

    const childIds = model.childrenOf[busId] || [];
    const childNodes = childIds.map(cid => nodeById[cid]).filter(Boolean);
    const rightChildren = childNodes.filter(n => (model.byId[n.id] || {}).segment === 'right');
    const leftChildren  = childNodes.filter(n => (model.byId[n.id] || {}).segment !== 'right');

    // 1+2: open a gap for the breaker by shifting the entire right-segment
    // subtree (right feeders + their descendants + the bus they couple down to)
    // rightward, then re-route every edge that touches a shifted node so the
    // conductors follow. Left-segment feeders and the source chain stay put.
    if (rightChildren.length && leftChildren.length) {
      const rightSet = collectRightSegmentSet(model, rightChildren.map(n => n.id), nodeById);
      const leftMaxRight = Math.max(...leftChildren.map(n => n.x + n.width));
      const rightMinLeft = Math.min(...rightChildren.map(n => n.x));
      const currentGap = rightMinLeft - leftMaxRight;
      const shift = Math.max(0, (SECTION_GAP + 24) - currentGap);
      if (shift > 0) {
        rightSet.forEach(id => { const n = nodeById[id]; if (n) n.x += shift; });
        reRouteTouching(model, layout, rightSet);
        layout.width = Math.max(layout.width || 0, ...layout.children.map(n => n.x + n.width));
      }
    }

    // 3: widen the bar so it spans all feeders (visual only; never shrinks).
    if (childNodes.length) {
      const minX = Math.min(...childNodes.map(n => n.x));
      const maxX = Math.max(...childNodes.map(n => n.x + n.width));
      const newX = Math.max(0, Math.min(busNode.x, minX - 12));
      const newRight = Math.max(busNode.x + busNode.width, maxX + 12);
      busNode.x = newX;
      busNode.width = newRight - newX;
      layout.width = Math.max(layout.width || 0, newRight);
    }

    // 4: boundary = midpoint between the (post-shift) left and right groups.
    let boundaryX;
    if (leftChildren.length && rightChildren.length) {
      const leftMaxRight = Math.max(...leftChildren.map(n => n.x + n.width));
      const rightMinLeft = Math.min(...rightChildren.map(n => n.x));
      boundaryX = (leftMaxRight + rightMinLeft) / 2;
    } else if (rightChildren.length) {
      boundaryX = Math.min(...rightChildren.map(n => n.x)) - SECTION_GAP / 2 - 12;
    } else if (leftChildren.length) {
      boundaryX = Math.max(...leftChildren.map(n => n.x + n.width)) + SECTION_GAP / 2 + 12;
    } else {
      boundaryX = busNode.x + busNode.width / 2;
    }
    const minB = busNode.x + SECTION_GAP / 2 + 4;
    const maxB = busNode.x + busNode.width - SECTION_GAP / 2 - 4;
    boundaryX = Math.max(minB, Math.min(maxB, boundaryX));

    // Record the split so renderNode draws the bar as two pieces with a gap.
    busNode._split = { x: boundaryX, gap: SECTION_GAP };

    out.push({
      id: sec.id,
      dev: sec,
      busId,
      x: boundaryX,
      centerY: busNode.y + busNode.height / 2,
      busBottom: busNode.y + busNode.height,
      gap: SECTION_GAP,
      leftEnd: boundaryX - SECTION_GAP / 2,
      rightEnd: boundaryX + SECTION_GAP / 2,
    });
  });
  return out;
}

// Closure of the right-segment feeders under childrenOf, intersected with laid-
// out nodes. The lower bus a coupler ties to (and its loads) are reached this
// way, so the whole right half shifts together. Never walks up into the section
// bus, so left-segment feeders are untouched.
function collectRightSegmentSet(model, seedIds, nodeById) {
  const set = new Set();
  const stack = [...seedIds];
  while (stack.length) {
    const id = stack.pop();
    if (set.has(id) || !nodeById[id]) continue;
    set.add(id);
    (model.childrenOf[id] || []).forEach(c => { if (!set.has(c)) stack.push(c); });
  }
  return set;
}

// After moving nodes, recompute orthogonal routes for every edge touching a
// moved node (intra-set edges plus boundary-crossing bus drops). Edges away from
// the move keep ELK's original routing.
function reRouteTouching(model, layout, movedSet) {
  const visualById = {};
  (layout.children || []).forEach(n => {
    const dev = model.byId[n.id];
    if (!dev) return;
    const geom = DEVICE_GEOMETRY[dev.kind] || DEVICE_GEOMETRY.other;
    const isBus = dev.kind === 'main_bus' || dev.kind === 'secondary_bus' || dev.kind === 'ground_bus';
    const drawW = isBus ? n.width : geom.w;
    const offsetX = (n.width - drawW) / 2;
    visualById[n.id] = { x: n.x + offsetX, y: n.y, width: drawW, height: n.height };
  });
  const affected = (layout.edges || []).filter(e => {
    const s = e.sources && e.sources[0], t = e.targets && e.targets[0];
    return movedSet.has(s) || movedSet.has(t);
  });
  routeOrthogonalEdges(affected, visualById);
}

// Draws each inline bus-section breaker: a normally-open breaker symbol
// straddling the gap in the bar, short stubs tying it to each bar end on the bus
// centre line, and the device label + rating below the bar. It IS the bar
// boundary — no separate power-flow drop is routed to it.
function renderSectionBreakers(sections, model) {
  if (!sections || !sections.length) return '';
  let out = '';
  sections.forEach(s => {
    const bw = 40, bh = 44;
    const cx = s.x, cy = s.centerY;
    const bx = cx - bw / 2, by = cy - bh / 2;
    const symFn = SYMBOLS.cb_open || SYMBOLS.cb_closed;
    const sym = symFn ? symFn(bw, bh) : '';
    out += `<g class="bus-section" data-id="${escapeAttr(s.id)}" pointer-events="none">`;
    out += `<line x1="${s.leftEnd}" y1="${cy}" x2="${bx}" y2="${cy}" stroke="${STYLE.wire}" stroke-width="${STYLE.busDropStrokeW}" stroke-linecap="square"/>`;
    out += `<line x1="${bx + bw}" y1="${cy}" x2="${s.rightEnd}" y2="${cy}" stroke="${STYLE.wire}" stroke-width="${STYLE.busDropStrokeW}" stroke-linecap="square"/>`;
    out += `<g transform="translate(${bx},${by})">${sym}</g>`;
    const label = pickLang(s.dev.label, s.dev.label_zh) || s.dev.id;
    out += `<text x="${cx}" y="${s.busBottom + 14}" text-anchor="middle" font-family="${STYLE.fontFamily}" font-size="${STYLE.labelSize}" font-weight="600" fill="${STYLE.labelColor}" stroke="#ffffff" stroke-width="3" stroke-linejoin="round" paint-order="stroke">${escapeXml(label)}</text>`;
    const specs = pickRatingItems(s.dev);
    if (specs.length) {
      out += `<text x="${cx}" y="${s.busBottom + 26}" text-anchor="middle" font-family="${STYLE.fontFamily}" font-size="${STYLE.ratingSize}" fill="${STYLE.ratingColor}" stroke="#ffffff" stroke-width="2.5" stroke-linejoin="round" paint-order="stroke">${ratingTextContent(specs, 30)}</text>`;
    }
    out += `</g>`;
  });
  return out;
}

// ─── MECHANICAL INTERLOCKS ─────────────────────────────────────────────────
// A post-layout visual overlay only — a dashed orange callout pairing two
// member devices (e.g. a Kirk-style mechanical interlock between two breakers).
// It is NOT an ELK edge and NOT an electrical conductor: it never affects
// topology, state detection, or edge styling. Each member resolves to an ELK
// node or an inline section-breaker placement; the callout routes orthogonally
// from the upper member down into the lower one with the label at the midpoint.
function renderInterlocks(model, layout, sections) {
  const list = model.interlocks || [];
  if (!list.length) return '';
  const nodeById = {};
  (layout.children || []).forEach(n => nodeById[n.id] = n);
  const sectionById = {};
  (sections || []).forEach(s => { sectionById[s.dev.id] = s; sectionById[s.id] = s; });

  // A member resolves to either an ELK node (centre + top/bottom edges) or an
  // inline section-breaker placement (on the bar). Returns null if unplaced.
  function anchor(id) {
    const n = nodeById[id];
    if (n) return { cx: n.x + n.width / 2, cy: n.y + n.height / 2, top: n.y, bottom: n.y + n.height };
    const s = sectionById[id];
    if (s) return { cx: s.x, cy: s.centerY, top: s.centerY - 22, bottom: s.busBottom };
    return null;
  }

  let out = '';
  list.forEach((il, idx) => {
    const tag = il.id || ('IL-' + idx);
    const ids = (Array.isArray(il.members) ? il.members : []).filter(m => anchor(m));
    if (ids.length < 2) {
      console.warn(`Interlock "${tag}" needs 2 resolvable members; skipped.`);
      return;
    }
    const A = anchor(ids[0]), B = anchor(ids[1]);
    // Clean orthogonal callout: leave the bottom edge of the upper anchor, run to
    // a mid line, across, then into the top of the lower anchor. The dashed line
    // is a Kirk-style mechanical interlock annotation — not a conductor.
    const upper = A.cy <= B.cy ? A : B;
    const lower = A.cy <= B.cy ? B : A;
    const start = { x: upper.cx, y: upper.bottom };
    const end   = { x: lower.cx, y: lower.top };
    const midY = (start.y + end.y) / 2;
    const d = `M${start.x},${start.y} L${start.x},${midY} L${end.x},${midY} L${end.x},${end.y}`;
    const midX = (start.x + end.x) / 2;
    out += `<g class="interlock" data-id="${escapeAttr(tag)}" pointer-events="none">`;
    out += `<path d="${d}" fill="none" stroke="${STYLE.interlockColor}" stroke-width="${STYLE.interlockStrokeW}" stroke-dasharray="5,4" stroke-linecap="round" stroke-linejoin="round"/>`;
    out += `<circle cx="${start.x}" cy="${start.y}" r="2.4" fill="${STYLE.interlockColor}"/>`;
    out += `<circle cx="${end.x}" cy="${end.y}" r="2.4" fill="${STYLE.interlockColor}"/>`;
    const labelText = il.label || tag;
    if (labelText) {
      const tw = Math.max(36, measureText(labelText, STYLE.ratingSize, '600') + 10);
      out += `<rect x="${midX - tw / 2}" y="${midY - 8}" width="${tw}" height="14" rx="3" fill="#ffffff" stroke="${STYLE.interlockColor}" stroke-width="0.8" opacity="0.96"/>`;
      out += `<text x="${midX}" y="${midY}" text-anchor="middle" dominant-baseline="central" font-family="${STYLE.fontFamily}" font-size="${STYLE.ratingSize}" font-weight="600" fill="${STYLE.interlockColor}">${escapeXml(labelText)}</text>`;
    }
    out += `</g>`;
  });
  return out;
}

function renderLegend(flagged, model, xOff, yOff) {
  let out = `<g transform="translate(${xOff},${yOff})">`;
  out += `<text x="0" y="0" font-family="${STYLE.fontFamily}" font-size="${STYLE.legendTitleSize}" font-weight="700" fill="${STYLE.flagColor}">★ ${isZh() ? '必需输入' : 'REQUIRED INPUT'}</text>`;
  flagged.forEach((d, i) => {
    let reason = pickLang(d.notes, d.notes_zh) || '';
    if (model.cycles.some(c => c.includes(d.id))) {
      const cycleNote = isZh() ? '拓扑回路的一部分' : 'part of topology cycle';
      reason = reason ? `${reason}; ${cycleNote}` : cycleNote;
    }
    if (reason.length > 100) reason = reason.substring(0, 98) + '…';
    const displayLabel = pickLang(d.label, d.label_zh);
    const line = reason ? `${d.id} (${displayLabel}): ${reason}` : `${d.id} (${displayLabel})`;
    out += `<text x="0" y="${20 + i * 16}" font-family="${STYLE.fontFamily}" font-size="${STYLE.legendSize}" fill="${STYLE.flagColor}">${escapeXml(line)}</text>`;
  });
  out += `</g>`;
  return out;
}

function escapeXml(s) {
  if (s == null) return '';
  return String(s)
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;');
}

// Render a comma-joined ratings string as SVG <text> content. Any chip matching
// /^Typical of / is wrapped in a bold blue <tspan> so the call-out reads at a
// glance. Other chips render plain. With a budget the OTHER chips truncate from
// the end to fit; the Typical-of chip is never truncated.
function ratingTextContent(specs, budget) {
  const isTyp = s => /^Typical of /.test(s);
  const typicals = specs.filter(isTyp);
  const others   = specs.filter(s => !isTyp(s));
  const typText = typicals.join(' · ');
  let othText   = others.join(' · ');
  const sep = (typText && othText) ? ' · ' : '';
  if (budget != null) {
    const overflow = typText.length + sep.length + othText.length - budget;
    if (overflow > 0 && othText) {
      const remain = othText.length - overflow - 1;
      othText = remain > 1 ? othText.substring(0, remain) + '…' : '…';
    }
  }
  let out = '';
  if (typText) out += `<tspan font-weight="700" fill="#1d4ed8">${escapeXml(typText)}</tspan>`;
  if (typText && othText) out += escapeXml(' · ');
  if (othText) out += escapeXml(othText);
  return out;
}

// For bus labels: "<label> · spec1 · spec2 · …", with Typical-of styled as
// bold blue tspans. Bus labels are not truncated.
function busLabelContent(label, specs) {
  const isTyp = s => /^Typical of /.test(s);
  let out = escapeXml(label);
  specs.forEach(s => {
    out += escapeXml(' · ');
    if (isTyp(s)) out += `<tspan font-weight="700" fill="#1d4ed8">${escapeXml(s)}</tspan>`;
    else out += escapeXml(s);
  });
  return out;
}

