// Holds the most recently loaded JSON so the Components tab can edit it
// in place and re-render the diagram from the same source of truth.
// showGrid controls the coordinate grid overlay on the SVG.
const state = {
  json: null,
  showGrid: true,
  showLegend: true,
  snapToGrid: false,
  snapStep: 50,
  zoom: 1,
  language: 'en',   // 'en' | 'zh' — picks the active label / specs / notes language
};

async function renderDiagram(rawJson) {
  const errorEl = document.querySelector('.error');
  if (errorEl) errorEl.remove();

  try {
    state.json = rawJson;
    const model = normalize(rawJson);
    const elkGraph = buildElkGraph(model);

    const elk = new ELK();
    const layout = await elk.layout(elkGraph);

    applyManualPositions(layout, model);

    const svg = buildSvg(model, layout);
    const container = document.getElementById('svg-container');
    container.innerHTML = '';
    container.appendChild(svg);
    attachCanvasInteraction();
    if (typeof applyZoom === 'function') applyZoom();

    updateSummary(model);
    buildComponentsEditor(rawJson, model);
    enableExportButtons();
  } catch (err) {
    showError(err);
  }
}

// ─── INTERACTIVE CANVAS ────────────────────────────────────────────────────
// Drag-to-move, click-to-connect, right-click-to-add. All handlers live on
// the persistent #svg-container and use event delegation so they survive
// re-renders. The SVG content sits inside #sld-content which is translated
// by (xOff, yOff); we convert browser client coords into that node-space
// using the SVG's CTM.

const interaction = {
  dragging: null,        // { id, nodeEl, startNodeX, startNodeY, startMouseX, startMouseY, incidentEdges, busFlag }
  connectMode: false,
  connectSource: null,   // id of first-clicked node while in connect mode
  pendingAddCoords: null // { x, y } captured from a right-click; pre-fills the Add modal
};

function clientToNodeSpace(svg, clientX, clientY) {
  const content = svg.querySelector('#sld-content');
  if (!content) return { x: 0, y: 0 };
  const pt = svg.createSVGPoint();
  pt.x = clientX; pt.y = clientY;
  const ctm = content.getScreenCTM();
  if (!ctm) return { x: 0, y: 0 };
  const local = pt.matrixTransform(ctm.inverse());
  return { x: local.x, y: local.y };
}

function getNodeAnchor(nodeEl, side) {
  // Returns the (cx, cy) anchor on a rendered node in node-space.
  // side: 'top' = top-center; 'bottom' = bottom-center; 'center' = middle.
  const w = parseFloat(nodeEl.dataset.w) || 0;
  const h = parseFloat(nodeEl.dataset.h) || 0;
  const offx = parseFloat(nodeEl.dataset.offx) || 0;
  const tx = nodeEl.transform.baseVal.consolidate ? nodeEl.transform.baseVal.consolidate().matrix : null;
  const x = tx ? tx.e : 0;
  const y = tx ? tx.f : 0;
  const cx = x - offx + (nodeEl.dataset.bus === '1' ? w / 2 : (w + offx * 2) / 2);
  // For non-bus nodes, the wrapper is offset by offx; account for that when
  // computing the visual center.
  const baseX = x + w / 2;
  if (side === 'top') return { x: baseX, y };
  if (side === 'bottom') return { x: baseX, y: y + h };
  return { x: baseX, y: y + h / 2 };
}

function setNodeTransform(nodeEl, x, y) {
  nodeEl.setAttribute('transform', `translate(${x},${y})`);
}

function startDrag(nodeEl, clientX, clientY) {
  const svg = nodeEl.ownerSVGElement;
  if (!svg) return;
  const start = clientToNodeSpace(svg, clientX, clientY);
  const m = nodeEl.transform.baseVal.consolidate().matrix;
  const w = parseFloat(nodeEl.dataset.w) || 0;
  const h = parseFloat(nodeEl.dataset.h) || 0;
  const id = nodeEl.dataset.id;

  // Find incident edges by data-source / data-target.
  const incident = [];
  svg.querySelectorAll(`path.sld-edge[data-source="${cssAttrEsc(id)}"], path.sld-edge[data-target="${cssAttrEsc(id)}"]`).forEach(p => {
    const otherId = p.dataset.source === id ? p.dataset.target : p.dataset.source;
    const otherEl = svg.querySelector(`g.draggable-node[data-id="${cssAttrEsc(otherId)}"]`);
    if (!otherEl) return;
    incident.push({
      path: p,
      role: p.dataset.source === id ? 'source' : 'target',
      other: otherEl
    });
  });

  interaction.dragging = {
    id,
    nodeEl,
    w, h,
    nodeStartX: m.e,
    nodeStartY: m.f,
    mouseStartX: start.x,
    mouseStartY: start.y,
    incident
  };
  nodeEl.classList.add('dragging');
}

function moveDrag(clientX, clientY) {
  const drag = interaction.dragging;
  if (!drag) return;
  const svg = drag.nodeEl.ownerSVGElement;
  const cur = clientToNodeSpace(svg, clientX, clientY);
  const dx = cur.x - drag.mouseStartX;
  const dy = cur.y - drag.mouseStartY;
  let newX = drag.nodeStartX + dx;
  let newY = drag.nodeStartY + dy;
  // Snap to grid (in device-space, then translate back to wrapper-space)
  if (state.snapToGrid) {
    const step = state.snapStep || 50;
    const offx = parseFloat(drag.nodeEl.dataset.offx) || 0;
    newX = Math.round((newX - offx) / step) * step + offx;
    newY = Math.round(newY / step) * step;
  }
  setNodeTransform(drag.nodeEl, newX, newY);

  // Live-redraw incident edges with orthogonal routing AND wire-spreading,
  // so multiple wires hitting the same side of the dragged node fan out
  // instead of stacking. Mirrors the same logic applyManualPositions uses
  // on drop, so the visual stays consistent through the release.
  const nodesById = {};
  nodesById[drag.id] = { x: newX, y: newY, width: drag.w, height: drag.h };
  const pseudoEdges = [];
  drag.incident.forEach(inc => {
    const otherId = inc.other.dataset.id;
    if (!nodesById[otherId]) {
      const ow = parseFloat(inc.other.dataset.w) || 0;
      const oh = parseFloat(inc.other.dataset.h) || 0;
      const om = inc.other.transform.baseVal.consolidate().matrix;
      nodesById[otherId] = { x: om.e, y: om.f, width: ow, height: oh };
    }
    pseudoEdges.push({
      sources: [inc.role === 'source' ? drag.id : otherId],
      targets: [inc.role === 'source' ? otherId : drag.id],
      _pathEl: inc.path
    });
  });
  routeOrthogonalEdges(pseudoEdges, nodesById);
  pseudoEdges.forEach(pe => {
    pe._pathEl.setAttribute('d', sectionToPath(pe.sections[0]));
  });
}

function endDrag() {
  const drag = interaction.dragging;
  if (!drag) return;
  drag.nodeEl.classList.remove('dragging');

  // Read the final translate from the DOM and persist to state.json.
  const m = drag.nodeEl.transform.baseVal.consolidate().matrix;
  const offx = parseFloat(drag.nodeEl.dataset.offx) || 0;
  const finalX = m.e - offx;
  const finalY = m.f;

  interaction.dragging = null;

  if (!state.json) return;
  const dev = state.json.devices.find(d => d.id === drag.id);
  if (!dev) return;
  let saveX = Math.round(finalX);
  let saveY = Math.round(finalY);
  if (state.snapToGrid) {
    const step = state.snapStep || 50;
    saveX = Math.round(saveX / step) * step;
    saveY = Math.round(saveY / step) * step;
  }
  dev.x = saveX;
  dev.y = saveY;
  renderDiagram(state.json);
}

function cssAttrEsc(s) {
  return String(s).replace(/(["\\])/g, '\\$1');
}

// ─── Connect mode ─────────────────────────────────────────────────────────

function setConnectMode(on) {
  if (on && interaction.traceMode && typeof setTraceMode === 'function') setTraceMode(false);
  interaction.connectMode = !!on;
  interaction.connectSource = null;
  const container = document.getElementById('svg-container');
  const btn = document.getElementById('btn-connect-mode');
  const hint = document.getElementById('connect-hint');
  container.classList.toggle('connect-mode', interaction.connectMode);
  btn.classList.toggle('active', interaction.connectMode);
  hint.hidden = !interaction.connectMode;
  // Clear any source highlight
  container.querySelectorAll('.draggable-node.connect-source').forEach(el => el.classList.remove('connect-source'));
  hideRubberBand();
}

function handleConnectClick(nodeEl) {
  if (!interaction.connectMode) return;
  const id = nodeEl.dataset.id;
  if (!interaction.connectSource) {
    interaction.connectSource = id;
    nodeEl.classList.add('connect-source');
    return;
  }
  if (interaction.connectSource === id) {
    // Clicked the same node again — deselect.
    nodeEl.classList.remove('connect-source');
    interaction.connectSource = null;
    return;
  }
  createConnection(interaction.connectSource, id);
  setConnectMode(false);
}

function createConnection(sourceId, targetId) {
  if (!state.json || !Array.isArray(state.json.devices)) return;
  const target = state.json.devices.find(d => d.id === targetId);
  const source = state.json.devices.find(d => d.id === sourceId);
  if (!target || !source) return;

  // Freeze current node positions so any *future* re-render (from another
  // action) won't shuffle the layout. This call has no visible effect now
  // because we don't re-render below.
  freezeCurrentLayoutPositions();

  // Mutate topology — first "downstream of" wire uses upstream_parent on the
  // target; any additional upstream is appended to source.downstream_children.
  if (!target.upstream_parent) {
    target.upstream_parent = sourceId;
  } else if (target.upstream_parent !== sourceId) {
    if (!Array.isArray(source.downstream_children)) source.downstream_children = [];
    if (!source.downstream_children.includes(targetId)) source.downstream_children.push(targetId);
  }

  // Inject the new wire straight into the existing SVG. No re-render →
  // existing wires + components stay exactly where they are.
  injectEdgeIntoCurrentSvg(sourceId, targetId);

  // Refresh the side panels (summary counts, components/specs tab) from the
  // updated JSON, without touching the canvas.
  try {
    const model = normalize(state.json);
    if (typeof updateSummary === 'function') updateSummary(model);
    if (typeof buildComponentsEditor === 'function') buildComponentsEditor(state.json, model);
  } catch (e) { /* non-fatal: side panels can stay stale until next full render */ }
}

// Build a single new <path class="sld-edge"> using the same orthogonal
// routing as a full render, and insert it under the existing nodes in
// #sld-content. The path's endpoints come from the LIVE DOM transforms,
// so dragged nodes are honored automatically.
function injectEdgeIntoCurrentSvg(sourceId, targetId) {
  const svg = document.querySelector('#svg-container svg');
  if (!svg) return;
  const content = svg.querySelector('#sld-content');
  if (!content) return;
  const sourceEl = content.querySelector(`g.draggable-node[data-id="${cssAttrEsc(sourceId)}"]`);
  const targetEl = content.querySelector(`g.draggable-node[data-id="${cssAttrEsc(targetId)}"]`);
  if (!sourceEl || !targetEl) return;

  const sM = sourceEl.transform.baseVal.consolidate().matrix;
  const tM = targetEl.transform.baseVal.consolidate().matrix;
  const nodesById = {};
  nodesById[sourceId] = {
    x: sM.e, y: sM.f,
    width: parseFloat(sourceEl.dataset.w) || 0,
    height: parseFloat(sourceEl.dataset.h) || 0,
  };
  nodesById[targetId] = {
    x: tM.e, y: tM.f,
    width: parseFloat(targetEl.dataset.w) || 0,
    height: parseFloat(targetEl.dataset.h) || 0,
  };

  const pseudo = { sources: [sourceId], targets: [targetId] };
  routeOrthogonalEdges([pseudo], nodesById);
  if (!pseudo.sections || !pseudo.sections.length) return;

  // Bus drops use a slightly thicker stroke. Resolve kind via normalize().
  let isBusDrop = false;
  try {
    const m = normalize(state.json);
    const sk = m.byId[sourceId] && m.byId[sourceId].kind;
    const tk = m.byId[targetId] && m.byId[targetId].kind;
    const isBus = k => k === 'main_bus' || k === 'secondary_bus';
    isBusDrop = isBus(sk) || isBus(tk);
  } catch (e) { /* default to non-bus stroke */ }

  const path = document.createElementNS('http://www.w3.org/2000/svg', 'path');
  path.setAttribute('class', 'sld-edge');
  path.setAttribute('data-source', sourceId);
  path.setAttribute('data-target', targetId);
  path.setAttribute('d', sectionToPath(pseudo.sections[0]));
  path.setAttribute('fill', 'none');
  path.setAttribute('stroke', STYLE.wire);
  path.setAttribute('stroke-width', isBusDrop ? STYLE.busDropStrokeW : STYLE.wireStrokeW);
  path.setAttribute('stroke-linecap', 'square');
  path.setAttribute('stroke-linejoin', 'miter');

  // Insert before the first .draggable-node so edges render UNDER nodes
  // (matches the order produced by buildSvg).
  const firstNode = content.querySelector('g.draggable-node');
  if (firstNode) content.insertBefore(path, firstNode);
  else content.appendChild(path);
}

// Walk every laid-out node in the current SVG and persist its position
// (in device-coords) onto state.json. After this, applyManualPositions
// will override ELK for those nodes, so a re-render leaves the layout in
// place. Used after edge-only mutations (connect, delete connection) to
// avoid disturbing the diagram.
function freezeCurrentLayoutPositions() {
  if (!state.json || !Array.isArray(state.json.devices)) return;
  const svg = document.querySelector('#svg-container svg');
  if (!svg) return;
  const byId = {};
  state.json.devices.forEach(d => { byId[d.id] = d; });
  svg.querySelectorAll('g.draggable-node').forEach(el => {
    const dev = byId[el.dataset.id];
    if (!dev) return;
    const m = el.transform && el.transform.baseVal && el.transform.baseVal.consolidate
      ? el.transform.baseVal.consolidate().matrix
      : null;
    if (!m) return;
    const offx = parseFloat(el.dataset.offx) || 0;
    dev.x = Math.round(m.e - offx);
    dev.y = Math.round(m.f);
  });
}

function showRubberBand(from, to) {
  const svg = document.querySelector('#svg-container svg');
  if (!svg) return;
  const line = svg.querySelector('#sld-rubber');
  if (!line) return;
  line.setAttribute('x1', from.x);
  line.setAttribute('y1', from.y);
  line.setAttribute('x2', to.x);
  line.setAttribute('y2', to.y);
  line.setAttribute('visibility', 'visible');
}
function hideRubberBand() {
  const line = document.querySelector('#sld-rubber');
  if (line) line.setAttribute('visibility', 'hidden');
}

// ─── Context menu (right-click) ───────────────────────────────────────────

function showContextMenu(clientX, clientY, items) {
  const menu = document.getElementById('canvas-menu');
  menu.innerHTML = items.map(item => {
    if (item.divider) return '<hr>';
    if (item.label) return `<div class="menu-coords">${escapeXml(item.label)}</div>`;
    return `<button class="${item.danger ? 'danger' : ''}" data-menu-id="${escapeAttr(item.id)}">${item.icon || ''}${escapeXml(item.text)}</button>`;
  }).join('');
  menu.style.left = `${clientX}px`;
  menu.style.top = `${clientY}px`;
  menu.hidden = false;
  // Keep within viewport
  const rect = menu.getBoundingClientRect();
  if (rect.right > window.innerWidth) menu.style.left = `${window.innerWidth - rect.width - 8}px`;
  if (rect.bottom > window.innerHeight) menu.style.top = `${window.innerHeight - rect.height - 8}px`;
}
function hideContextMenu() {
  const menu = document.getElementById('canvas-menu');
  if (menu) menu.hidden = true;
}

function handleCanvasContextMenu(e) {
  if (!state.json) return;
  e.preventDefault();
  const svg = document.querySelector('#svg-container svg');
  if (!svg) return;
  const nodeEl = e.target.closest('.draggable-node');
  if (nodeEl) {
    // Right-clicked on a node → edit / delete shortcuts
    const id = nodeEl.dataset.id;
    showContextMenu(e.clientX, e.clientY, [
      { label: id },
      { id: `edit:${id}`, text: 'Edit on Components tab', icon: '' },
      { divider: true },
      { id: `delete:${id}`, text: 'Delete component', danger: true }
    ]);
  } else {
    // Right-clicked on empty canvas → add component here
    const pt = clientToNodeSpace(svg, e.clientX, e.clientY);
    interaction.pendingAddCoords = { x: Math.round(pt.x), y: Math.round(pt.y) };
    showContextMenu(e.clientX, e.clientY, [
      { label: `at (${interaction.pendingAddCoords.x}, ${interaction.pendingAddCoords.y})` },
      { id: 'add-here', text: 'Add component here' }
    ]);
  }
}

function handleMenuClick(e) {
  const btn = e.target.closest('button[data-menu-id]');
  if (!btn) return;
  const id = btn.dataset.menuId;
  hideContextMenu();
  if (id === 'add-here') {
    openAddComponentModal(interaction.pendingAddCoords);
  } else if (id.startsWith('delete:')) {
    deleteComponent(id.slice('delete:'.length));
  } else if (id.startsWith('edit:')) {
    const devId = id.slice('edit:'.length);
    document.querySelector('.tab[data-tab="components"]').click();
    setTimeout(() => {
      const card = document.querySelector(`.comp-card[data-id="${cssAttrEsc(devId)}"]`);
      if (card) {
        card.scrollIntoView({ behavior: 'smooth', block: 'center' });
        card.classList.add('editing');
        const first = card.querySelector('.f-label');
        if (first) first.focus();
      }
    }, 50);
  }
}

// Single delegated handler attached once to #svg-container.
function attachCanvasInteraction() {
  const container = document.getElementById('svg-container');
  if (!container || container._interactiveBound) return;
  container._interactiveBound = true;

  container.addEventListener('mousedown', e => {
    if (e.button !== 0) return; // left-button only
    const nodeEl = e.target.closest('.draggable-node');
    if (!nodeEl) return;
    if (interaction.connectMode) {
      // In connect mode, mousedown doesn't drag — it picks. We'll handle on click.
      return;
    }
    e.preventDefault();
    startDrag(nodeEl, e.clientX, e.clientY);
  });

  container.addEventListener('click', e => {
    if (!interaction.connectMode) return;
    const nodeEl = e.target.closest('.draggable-node');
    if (!nodeEl) return;
    e.preventDefault();
    handleConnectClick(nodeEl);
  });

  container.addEventListener('mousemove', e => {
    if (!interaction.connectMode || !interaction.connectSource) return;
    const svg = container.querySelector('svg');
    if (!svg) return;
    const sourceEl = svg.querySelector(`g.draggable-node[data-id="${cssAttrEsc(interaction.connectSource)}"]`);
    if (!sourceEl) return;
    const from = getNodeAnchor(sourceEl, 'center');
    const to = clientToNodeSpace(svg, e.clientX, e.clientY);
    showRubberBand(from, to);
  });

  container.addEventListener('contextmenu', handleCanvasContextMenu);

  // Mouse move / up while dragging is tracked on the window so the user can
  // drag past the edge of the SVG without losing the node.
  window.addEventListener('mousemove', e => {
    if (interaction.dragging) moveDrag(e.clientX, e.clientY);
  });
  window.addEventListener('mouseup', () => {
    if (interaction.dragging) endDrag();
  });
}

// Anchor a wire on a specific side of a node at a fractional offset (0..1)
// along that side. frac=0.5 = center, 0.25 = first quarter, etc.
function anchorPoint(node, side, frac) {
  if (typeof frac !== 'number') frac = 0.5;
  if (side === 'top')    return { x: node.x + node.width * frac, y: node.y };
  if (side === 'bottom') return { x: node.x + node.width * frac, y: node.y + node.height };
  if (side === 'left')   return { x: node.x, y: node.y + node.height * frac };
  /* right */              return { x: node.x + node.width, y: node.y + node.height * frac };
}

// Decide which side of a node a wire should exit on, based on the direction
// to its other endpoint. Picks the dominant axis.
function pickSide(self, other) {
  const scx = self.x + self.width / 2;
  const scy = self.y + self.height / 2;
  const ocx = other.x + other.width / 2;
  const ocy = other.y + other.height / 2;
  const dx = ocx - scx;
  const dy = ocy - scy;
  if (Math.abs(dy) >= Math.abs(dx)) return dy >= 0 ? 'bottom' : 'top';
  return dx >= 0 ? 'right' : 'left';
}

// Re-route a set of edges with orthogonal (Manhattan) paths AND distribute
// the wires that share a side of any one node so they don't overlap.
// Mutates each edge's `sections` field with ELK-shaped section data.
//
//  - Phase 1: pick source/target sides for each edge based on relative geometry.
//  - Phase 2: group edges by (nodeId, side). Within each group, sort by the
//    other endpoint's perpendicular-axis position (so wires don't cross),
//    then assign each member a fractional slot 1/(N+1), 2/(N+1), …
//  - Phase 3: build the elbow path (3-segment with horizontal/vertical trunk
//    when both ends face the same axis; 2-segment L-bend when they don't).
function routeOrthogonalEdges(edges, nodesById) {
  const infos = [];
  edges.forEach(edge => {
    const sId = edge.sources && edge.sources[0];
    const tId = edge.targets && edge.targets[0];
    const sN = nodesById[sId];
    const tN = nodesById[tId];
    if (!sN || !tN) return;
    const sSide = pickSide(sN, tN);
    const tSide = pickSide(tN, sN);
    infos.push({ edge, sId, tId, sN, tN, sSide, tSide, sFrac: 0.5, tFrac: 0.5 });
  });

  // Group + sort + assign fractional slots.
  const groups = new Map();
  function add(key, entry) {
    if (!groups.has(key)) groups.set(key, []);
    groups.get(key).push(entry);
  }
  infos.forEach(info => {
    add(`${info.sId}:${info.sSide}`, { info, role: 'source' });
    add(`${info.tId}:${info.tSide}`, { info, role: 'target' });
  });
  groups.forEach((members, key) => {
    const side = key.split(':').pop();
    const isHorizSide = side === 'top' || side === 'bottom';
    // Sort along the side direction by the OTHER endpoint's center, so wires
    // don't cross when they fan out.
    members.sort((a, b) => {
      const aOther = a.role === 'source' ? a.info.tN : a.info.sN;
      const bOther = b.role === 'source' ? b.info.tN : b.info.sN;
      const aC = isHorizSide ? aOther.x + aOther.width / 2 : aOther.y + aOther.height / 2;
      const bC = isHorizSide ? bOther.x + bOther.width / 2 : bOther.y + bOther.height / 2;
      return aC - bC;
    });
    const total = members.length;
    if (total === 1) {
      // Single wire on this side — anchor it directly across from the other
      // endpoint instead of at the geometric center. Stops a single wire on a
      // wide node (e.g. a bus) from exiting at the middle and then traversing
      // a long horizontal trunk to reach a target on one end.
      const m = members[0];
      const self = m.role === 'source' ? m.info.sN : m.info.tN;
      const other = m.role === 'source' ? m.info.tN : m.info.sN;
      let frac;
      if (isHorizSide) {
        frac = (other.x + other.width / 2 - self.x) / self.width;
      } else {
        frac = (other.y + other.height / 2 - self.y) / self.height;
      }
      frac = Math.max(0.05, Math.min(0.95, frac));
      if (m.role === 'source') m.info.sFrac = frac;
      else m.info.tFrac = frac;
    } else {
      // For wide bus-like nodes, anchor each wire at its target's column
      // (clamped) so the wire drops straight to its child instead of via an
      // evenly-spaced slot — slot-spacing causes the wire to pass over OTHER
      // bus children, which then makes obstacle-avoidance flail. Non-bus
      // nodes keep slot-spacing so fan-out wires don't overlap.
      members.forEach((mm, i) => {
        const self = mm.role === 'source' ? mm.info.sN : mm.info.tN;
        const other = mm.role === 'source' ? mm.info.tN : mm.info.sN;
        const selfIsBus = self.width > 200 && self.height < 40;
        if (selfIsBus) {
          let frac = isHorizSide
            ? (other.x + other.width / 2 - self.x) / self.width
            : (other.y + other.height / 2 - self.y) / self.height;
          frac = Math.max(0.03, Math.min(0.97, frac));
          if (mm.role === 'source') mm.info.sFrac = frac;
          else mm.info.tFrac = frac;
        } else {
          const slot = (i + 1) / (total + 1);
          if (mm.role === 'source') mm.info.sFrac = slot;
          else mm.info.tFrac = slot;
        }
      });
    }
  });

  // Build orthogonal section per edge.
  infos.forEach(info => {
    const sP = anchorPoint(info.sN, info.sSide, info.sFrac);
    const tP = anchorPoint(info.tN, info.tSide, info.tFrac);
    const sVert = info.sSide === 'top' || info.sSide === 'bottom';
    const tVert = info.tSide === 'top' || info.tSide === 'bottom';
    let bendPoints;
    if (sVert && tVert) {
      const midY = (sP.y + tP.y) / 2;
      bendPoints = [{ x: sP.x, y: midY }, { x: tP.x, y: midY }];
    } else if (!sVert && !tVert) {
      const midX = (sP.x + tP.x) / 2;
      bendPoints = [{ x: midX, y: sP.y }, { x: midX, y: tP.y }];
    } else if (sVert) {
      bendPoints = [{ x: sP.x, y: tP.y }];
    } else {
      bendPoints = [{ x: tP.x, y: sP.y }];
    }
    info.edge.sections = [{ startPoint: sP, endPoint: tP, bendPoints }];
  });
}

function sectionToPath(section) {
  let p = `M${section.startPoint.x},${section.startPoint.y}`;
  (section.bendPoints || []).forEach(bp => { p += `L${bp.x},${bp.y}`; });
  p += `L${section.endPoint.x},${section.endPoint.y}`;
  return p;
}

// ─── OBSTACLE-AVOIDING POST-PASS ────────────────────────────────────────────
// ELK's ORTHOGONAL routing avoids nodes during initial layout, but the custom
// re-router (used after bus segmentation shifts the right segment) does not —
// so the dashed coupler → UPS-bus edge can pass straight through UPS modules.
// This pass walks every edge AFTER all routing is done and inserts orthogonal
// "C" detours around any node bboxes that segments cross (excluding the
// edge's own source and target). To avoid oscillation between adjacent
// obstacles, a single detour is computed around the UNION bbox of every node
// the segment crosses, rather than detouring around them one at a time.

function segCrossesRect(a, b, rect) {
  if (a.x === b.x) {
    const x = a.x;
    if (x <= rect.x1 || x >= rect.x2) return false;
    const y1 = Math.min(a.y, b.y), y2 = Math.max(a.y, b.y);
    return y2 > rect.y1 && y1 < rect.y2;
  }
  if (a.y === b.y) {
    const y = a.y;
    if (y <= rect.y1 || y >= rect.y2) return false;
    const x1 = Math.min(a.x, b.x), x2 = Math.max(a.x, b.x);
    return x2 > rect.x1 && x1 < rect.x2;
  }
  return false;
}

function detourAroundBBox(a, b, bbox) {
  // bbox is already padded. Returns a 4-point "C" detour from a toward b
  // around the bbox, or null if the segment doesn't actually cross it.
  if (a.x === b.x) {
    const x = a.x;
    if (x <= bbox.x1 || x >= bbox.x2) return null;
    const y1 = Math.min(a.y, b.y), y2 = Math.max(a.y, b.y);
    if (y2 <= bbox.y1 || y1 >= bbox.y2) return null;
    const goRight = (x - bbox.x1) >= (bbox.x2 - x);
    const detourX = goRight ? bbox.x2 : bbox.x1;
    const goingDown = a.y < b.y;
    const firstY  = goingDown ? bbox.y1 : bbox.y2;
    const secondY = goingDown ? bbox.y2 : bbox.y1;
    return [
      { x: x,       y: firstY  },
      { x: detourX, y: firstY  },
      { x: detourX, y: secondY },
      { x: x,       y: secondY },
    ];
  }
  if (a.y === b.y) {
    const y = a.y;
    if (y <= bbox.y1 || y >= bbox.y2) return null;
    const x1 = Math.min(a.x, b.x), x2 = Math.max(a.x, b.x);
    if (x2 <= bbox.x1 || x1 >= bbox.x2) return null;
    const goDown = (y - bbox.y1) >= (bbox.y2 - y);
    const detourY = goDown ? bbox.y2 : bbox.y1;
    const goingRight = a.x < b.x;
    const firstX  = goingRight ? bbox.x1 : bbox.x2;
    const secondX = goingRight ? bbox.x2 : bbox.x1;
    return [
      { x: firstX,  y: y       },
      { x: firstX,  y: detourY },
      { x: secondX, y: detourY },
      { x: secondX, y: y       },
    ];
  }
  return null;
}

// Counts segments of a polyline path that intersect any of `rects`.
function countCrossings(points, rects) {
  let n = 0;
  for (let i = 0; i < points.length - 1; i++) {
    const a = points[i], b = points[i + 1];
    for (const r of rects) if (segCrossesRect(a, b, r)) n++;
  }
  return n;
}

function routeAvoidObstacles(layout, model) {
  const PAD = 8;
  const nodes = layout.children || [];
  const byId = {};
  nodes.forEach(n => byId[n.id] = n);
  const rectsAll = nodes.map(n => ({ id: n.id, x1: n.x - PAD, y1: n.y - PAD, x2: n.x + n.width + PAD, y2: n.y + n.height + PAD }));

  (layout.edges || []).forEach(edge => {
    const sId = edge.sources && edge.sources[0];
    const tId = edge.targets && edge.targets[0];
    const sourceNode = byId[sId], targetNode = byId[tId];
    const rects = rectsAll.filter(r => r.id !== sId && r.id !== tId);

    // Bus → small-child edges: replace the path with a direct vertical drop at
    // the child's center X. ELK's slot-spaced staircase routes can put a bend
    // INSIDE a neighbor child's bbox, which then traps the detour logic in an
    // oscillation. A clean drop at target.cx avoids the problem entirely and
    // is the correct shape for an SLD bus drop anyway.
    const sourceIsBus = sourceNode && sourceNode.width > 200 && sourceNode.height < 40;
    const targetIsSmall = targetNode && targetNode.width < 200;
    const targetIsBus = targetNode && targetNode.width > 200 && targetNode.height < 40;
    const targetBelow = sourceNode && targetNode && targetNode.y > sourceNode.y + sourceNode.height;
    const targetAbove = sourceNode && targetNode && targetNode.y + targetNode.height < sourceNode.y;
    if (sourceIsBus && targetIsSmall && (targetBelow || targetAbove)) {
      const tCx = targetNode.x + targetNode.width / 2;
      const clampedX = Math.max(sourceNode.x + 4, Math.min(sourceNode.x + sourceNode.width - 4, tCx));
      const exitY  = targetBelow ? sourceNode.y + sourceNode.height : sourceNode.y;
      const entryY = targetBelow ? targetNode.y : targetNode.y + targetNode.height;
      edge.sections = [{
        startPoint: { x: clampedX, y: exitY },
        endPoint:   { x: tCx, y: entryY },
        bendPoints: clampedX === tCx ? [] : [{ x: clampedX, y: (exitY + entryY) / 2 }, { x: tCx, y: (exitY + entryY) / 2 }],
      }];
      return;
    }
    // Small-source → bus edges (e.g. coupler dropping to UPS-BUS): drop at the
    // source's center X into the target bus, again sidestepping slot anchors.
    if (targetIsBus && sourceNode && sourceNode.width < 200 && (targetBelow || targetAbove)) {
      const sCx = sourceNode.x + sourceNode.width / 2;
      const clampedX = Math.max(targetNode.x + 4, Math.min(targetNode.x + targetNode.width - 4, sCx));
      const exitY  = targetBelow ? sourceNode.y + sourceNode.height : sourceNode.y;
      const entryY = targetBelow ? targetNode.y : targetNode.y + targetNode.height;
      edge.sections = [{
        startPoint: { x: sCx, y: exitY },
        endPoint:   { x: clampedX, y: entryY },
        bendPoints: sCx === clampedX ? [] : [{ x: sCx, y: (exitY + entryY) / 2 }, { x: clampedX, y: (exitY + entryY) / 2 }],
      }];
      // This wire may still pass through UPS modules between source and
      // target buses. Fall through to the detour pass.
    }

    (edge.sections || []).forEach(section => {
      const original = [section.startPoint, ...(section.bendPoints || []), section.endPoint]
        .map(p => ({ x: p.x, y: p.y }));
      let points = original.map(p => ({ x: p.x, y: p.y }));

      // A few outer passes — each pass detours every segment that crosses any
      // obstacle, around the UNION bbox of all obstacles it crosses (so two
      // adjacent obstacles get cleared in one detour instead of bouncing).
      for (let pass = 0; pass < 4; pass++) {
        let any = false;
        for (let i = 0; i < points.length - 1; i++) {
          const a = points[i], b = points[i + 1];
          const hits = rects.filter(r => segCrossesRect(a, b, r));
          if (!hits.length) continue;
          const unionBox = {
            x1: Math.min(...hits.map(r => r.x1)),
            y1: Math.min(...hits.map(r => r.y1)),
            x2: Math.max(...hits.map(r => r.x2)),
            y2: Math.max(...hits.map(r => r.y2)),
          };
          const detour = detourAroundBBox(a, b, unionBox);
          if (detour) {
            points.splice(i + 1, 0, ...detour);
            any = true;
            i += detour.length;
          }
        }
        if (!any) break;
      }

      // Collapse duplicates + colinear midpoints.
      const cleaned = [points[0]];
      for (let i = 1; i < points.length; i++) {
        const p = points[i], q = cleaned[cleaned.length - 1];
        if (p.x !== q.x || p.y !== q.y) cleaned.push(p);
      }
      const simplified = [];
      for (let i = 0; i < cleaned.length; i++) {
        if (i === 0 || i === cleaned.length - 1) { simplified.push(cleaned[i]); continue; }
        const p = cleaned[i - 1], q = cleaned[i], r = cleaned[i + 1];
        const colinear = (p.x === q.x && q.x === r.x) || (p.y === q.y && q.y === r.y);
        if (!colinear) simplified.push(q);
      }

      // Safety net: if my detour made things worse (more crossings) or wildly
      // longer (10× points), revert to the original ELK/custom-router path.
      const origCrossings = countCrossings(original, rects);
      const newCrossings  = countCrossings(simplified, rects);
      const tooLong = simplified.length > original.length * 10 + 6;
      const final = (newCrossings <= origCrossings && !tooLong) ? simplified : original;

      section.startPoint = final[0];
      section.endPoint   = final[final.length - 1];
      section.bendPoints = final.slice(1, -1);
    });
  });
}

// Override ELK-computed positions with user-pinned x/y values. Any edge
// touching a moved node is re-routed orthogonally so the wire enters/exits
// the node along a 90° axis (matching the rest of the diagram).
function applyManualPositions(layout, model) {
  const manualIds = new Set();
  model.devices.forEach(d => {
    if (Number.isFinite(d.x) || Number.isFinite(d.y)) manualIds.add(d.id);
  });
  if (manualIds.size === 0) return;

  const layoutById = {};
  (layout.children || []).forEach(n => layoutById[n.id] = n);

  manualIds.forEach(id => {
    const node = layoutById[id];
    const dev = model.byId[id];
    if (!node || !dev) return;
    if (Number.isFinite(dev.x)) node.x = dev.x;
    if (Number.isFinite(dev.y)) node.y = dev.y;
    // Grow the layout extent if a node was pinned outside it.
    layout.width = Math.max(layout.width || 0, node.x + node.width);
    layout.height = Math.max(layout.height || 0, node.y + node.height);
  });

  // Build a routing map that uses each node's VISIBLE symbol bounds (not
  // the wider ELK box, which includes padding to clear label text). Keeps
  // the wire anchors consistent with what we draw during drag, so wires
  // don't jump when a drag releases.
  const visualById = {};
  (layout.children || []).forEach(n => {
    const dev = model.byId[n.id];
    if (!dev) return;
    const geom = DEVICE_GEOMETRY[dev.kind] || DEVICE_GEOMETRY.other;
    const isBus = dev.kind === 'main_bus' || dev.kind === 'secondary_bus' || dev.kind === 'ground_bus';
    const drawW = isBus ? n.width : geom.w;
    const offsetX = (n.width - drawW) / 2;
    visualById[n.id] = {
      x: n.x + offsetX,
      y: n.y,
      width: drawW,
      height: n.height
    };
  });

  // Collect every edge that touches a manual node and re-route them as a
  // group so wires sharing a side fan out instead of stacking on top of
  // each other.
  const affected = (layout.edges || []).filter(edge => {
    const srcId = edge.sources && edge.sources[0];
    const tgtId = edge.targets && edge.targets[0];
    return manualIds.has(srcId) || manualIds.has(tgtId);
  });
  routeOrthogonalEdges(affected, visualById);
}

